import { expect, toBe, test, suite, run } from "std/test"
import { count } from "./wordcount"
import { keys } from "std/object"
import { length } from "std/array"

val s = suite("wordcount", [
  test("counts repeated words", () =>
    val c = count([
      "a",
      "b",
      "a",
      "a",
      "b"
    ])
    [
      expect(c["a"]).toBe(3),
      expect(c["b"]).toBe(2)
    ]
  ),

  test("missing word reads back null", () =>
    val c = count(["a"])
    [
      expect(c["zzz"]).toBe(null)
    ]
  ),

  test("distinct key count", () =>
    val c = count([
      "x",
      "y",
      "z",
      "x",
      "y"
    ])
    [
      expect(keys(c).length()).toBe(3)
    ]
  ),

  test("empty input -> empty map", () =>
    val c = count([])
    [
      expect(keys(c).length()).toBe(0)
    ]
  )
])

run(s)
