export val square = (x: Int32): Int32 => x * x

export val cube = (x: Int32): Int32 => x * x * x

export val abs = (x: Int32): Int32 =>
  if x < 0 then 0 - x else x

export val max = (a: Int32, b: Int32): Int32 =>
  if a > b then a else b

export val min = (a: Int32, b: Int32): Int32 =>
  if a < b then a else b

export val clamp = (x: Int32, lo: Int32, hi: Int32): Int32 =>
  x.max(lo).min(hi)
