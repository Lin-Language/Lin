import { expect, toBe, test, suite, run } from "std/test"
import { solve } from "./solver"
import { dijkstra } from "./algorithm"
import { buildAdj, reconstructPath } from "./graph"
import { readJson, writeJson } from "std/fs"
import { join } from "std/string"

// End-to-end over the real entry point: drive solve() — the same fs -> buildAdj ->
// dijkstra -> reconstructPath -> writeJson flow main.lin runs — across the full graph
// topology (the same edges as graph.json). std/fs is mocked (ADR-071) so the whole
// orchestration is covered without disk: the read feeds the graph, and the write is
// captured by a spy. A final test checks the algorithm core directly, as a guard
// that the two agree.
val graph = {
  "nodes": [
    "A",
    "B",
    "C",
    "D",
    "E"
  ],
  "edges": [
    {
      "from": "A",
      "to": "B",
      "weight": 10
    },
    {
      "from": "A",
      "to": "C",
      "weight": 3
    },
    {
      "from": "C",
      "to": "B",
      "weight": 4
    },
    {
      "from": "C",
      "to": "D",
      "weight": 8
    },
    {
      "from": "B",
      "to": "D",
      "weight": 2
    },
    {
      "from": "D",
      "to": "E",
      "weight": 5
    },
    {
      "from": "B",
      "to": "E",
      "weight": 11
    }
  ]
}

replace readJson = (path: String): Json => graph

var savedPath = ""
var savedDistance = 0
var savedPathStr = ""
replace writeJson = (path: String, value: Json, opts: Json): Json =>
  savedPath = path
  savedDistance = value["distance"]
  savedPathStr = value["path"].join(" ")
  null

val nodes = [
  "A",
  "B",
  "C",
  "D",
  "E"
]

val s = suite("dijkstra end-to-end", [
  test("solve drives read -> dijkstra -> path for the optimal A -> E route", () =>
    val r = solve("graph.json", "A", "E", null)
    [
      expect(r["type"]).toBe("ok"),
      expect(r["path"].join(" ")).toBe("A C B D E"),
      expect(r["distance"]).toBe(14)
    ]),
  test("solve writes the resolved path + distance JSON to the output path", () =>
    val r = solve("graph.json", "A", "E", "result.json")
    [
      expect(savedPath).toBe("result.json"),
      expect(savedDistance).toBe(14),
      expect(savedPathStr).toBe("A C B D E")
    ]),
  test("the algorithm core agrees with solve on distances from A", () =>
    val result = dijkstra(buildAdj(graph["edges"]), "A", nodes)
    val dist = result["dist"]
    [
      expect(dist["A"]).toBe(0),
      expect(dist["C"]).toBe(3),
      expect(dist["B"]).toBe(7),
      expect(dist["D"]).toBe(9),
      expect(dist["E"]).toBe(14)
    ])
])
run(s)
