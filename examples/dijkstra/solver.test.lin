import { expect, toBe, test, suite, run } from "std/test"
import { solve } from "./solver"
import { readJson, writeJson } from "std/fs"
import { join } from "std/string"

// Unit tests for solve — the fs-driven orchestration. `readJson`/`writeJson` are
// mocked (ADR-046) so the whole flow is exercised without touching disk: the happy
// path, the file-read-error branch, the unreachable-target branch, and the optional
// JSON output write (captured via a var spy instead of hitting the filesystem).
// A small fixed graph returned by the mocked readJson for the "good file" path.
// "F" is listed as a node but has no incoming edges, so it is unreachable from A —
// it exercises solve's no-path branch (distance stays at the unreachable sentinel).
val sampleGraph = {
  "nodes": [
    "A",
    "B",
    "C",
    "D",
    "E",
    "F"
  ],
  "edges": [
    {
      "from": "A",
      "to": "B",
      "weight": 10
    },
    {
      "from": "A",
      "to": "C",
      "weight": 3
    },
    {
      "from": "C",
      "to": "B",
      "weight": 4
    },
    {
      "from": "C",
      "to": "D",
      "weight": 8
    },
    {
      "from": "B",
      "to": "D",
      "weight": 2
    },
    {
      "from": "D",
      "to": "E",
      "weight": 5
    },
    {
      "from": "B",
      "to": "E",
      "weight": 11
    }
  ]
}

// readJson dispatches on the path: a known file yields the graph, anything else an
// error object (the "file missing / bad JSON" case solve must surface).
replace readJson = (path: String): Json =>
  if path == "graph.json" then
    sampleGraph
  else
    { "type": "error", "message": "no such file: ${path}" }

// writeJson is a spy: record the last write instead of touching disk. Returns the
// success-ish null the real wrapper returns.
var wroteToPath = ""
var wroteDistance = 0
replace writeJson = (path: String, value: Json, opts: Json): Json =>
  wroteToPath = path
  wroteDistance = value["distance"]
  null

val s = suite("solver", [
  test("reads the graph and solves the shortest A->E route", () =>
    val r = solve("graph.json", "A", "E", null)
    [
      expect(r["type"]).toBe("ok"),
      expect(r["path"].join(" ")).toBe("A C B D E"),
      expect(r["distance"]).toBe(14)
    ]
  ),

  test("surfaces a read error as a tagged error result", () =>
    val r = solve("missing.json", "A", "E", null)
    [
      expect(r["type"]).toBe("error"),
      expect(r["message"]).toBe("no such file: missing.json")
    ]
  ),

  test("reports no-path when the target is unreachable", () =>
    // "F" is in the graph but has no incoming edges, so it stays at the sentinel.
    val r = solve("graph.json", "A", "F", null)
    [
      expect(r["type"]).toBe("no-path")
    ]
  ),

  test("writes the result JSON when an output path is given", () =>
    val r = solve("graph.json", "A", "E", "out.json")
    [
      expect(r["type"]).toBe("ok"),
      expect(wroteToPath).toBe("out.json"),
      expect(wroteDistance).toBe(14)
    ]
  ),

  test("does not write when no output path is given", () =>
    // wroteToPath still holds the previous write; a null outputPath must not change it.
    val r = solve("graph.json", "A", "E", null)
    [
      expect(r["type"]).toBe("ok"),
      expect(wroteToPath).toBe("out.json")
    ]
  )
])
run(s)
