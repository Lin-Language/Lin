import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { range, for } from "std/iter"
import { Expr, Num, BinOp, eval, num, binOp, chain } from "./ast"

// A parser-style cursor record: a sum-typed `node` field beside a scalar `pos`.
type Cursor = { "node": Expr, "pos": Int32 }

val leaf3: Expr = { "kind": "num", "value": 3 }
val leaf4: Expr = { "kind": "num", "value": 4 }

val s = suite("sumtree", [
  test("a bare number evaluates to itself", () =>
    [expect(eval(leaf3).toString()).toBe("3")]
  ),

  test("addition over two leaves", () =>
    val t: Expr = {
      "kind": "op",
      "op": 0,
      "left": leaf3,
      "right": leaf4
    }
    [expect(eval(t).toString()).toBe("7")]
  ),

  test("nested mixed-op tree ((3+4)*(10-6)) = 28", () =>
    val t: Expr = {
      "kind": "op",
      "op": 2,
      "left": {
        "kind": "op",
        "op": 0,
        "left": { "kind": "num", "value": 3 },
        "right": { "kind": "num", "value": 4 }
      },
      "right": {
        "kind": "op",
        "op": 1,
        "left": { "kind": "num", "value": 10 },
        "right": { "kind": "num", "value": 6 }
      }
    }
    [expect(eval(t).toString()).toBe("28")]
  ),

  test("repeated build + eval + drop in a loop is leak-free", () =>
    // Build and drop a fresh tree several times; a leak or double-free in the
    // recursive drop walk would corrupt a later iteration's result.
    var acc = 0
    range(0, 5).for(i =>
      val t: Expr = {
        "kind": "op",
        "op": 0,
        "left": { "kind": "num", "value": i },
        "right": { "kind": "num", "value": 1 }
      }
      acc = acc + eval(t)
    )
    // sum of (i + 1) for i in 0..4 = 1+2+3+4+5 = 15
    [expect(acc.toString()).toBe("15")]
  ),

  test("a tree built+returned from functions evaluates correctly", () =>
    // The TAIL-RETURN pushdown shape: every node here is built INSIDE a function
    // (`num`/`binOp`, the latter returning from an if-tail) and returned, then composed.
    // ((3+4)*(10-6)) = 28 — same value as the inline-built tree above.
    val t: Expr = binOp(2, binOp(0, num(3), num(4)), binOp(1, num(10), num(6)))
    [expect(eval(t).toString()).toBe("28")]
  ),

  // `chain(n)` recursively builds and RETURNS a fresh sub-tree at every level;
  // evaluating sums its `n` leaf 1's. Guards the tail-return pushdown at depth.
  test("a recursively built+returned spine evaluates correctly", () =>
    [
      expect(eval(chain(1)).toString()).toBe("1"),
      expect(eval(chain(7)).toString()).toBe("7")
    ]
  ),

  test("repeated build-and-return + drop in a loop is leak-free", () =>
    var acc = 0
    range(0, 5).for(i =>
      // Built and returned by `binOp` (if-tail) — the returned tree's children are
      // unboxed SumNodes that the recursive drop must free exactly once each iteration.
      val t: Expr = binOp(0, num(i), num(1))
      acc = acc + eval(t)
    )
    [expect(acc.toString()).toBe("15")]
  ),

  // unboxed-sumtype Stage 3 — a sum value crossing a CONTAINER boundary (a record/AnyVal
  // field, a `{String:Expr}` map) materializes to a real boxed object on store and
  // projects back to a correct SumNode on read, so the round-tripped tree evaluates to
  // the same value. (Before the Stage-3 boundary fix these crashed: a SumNode pointer
  // stored raw under TAG_OBJECT was read back as a LinObject → null-deref / wrong tag.)
  test("a tree stored in a cursor record reads back + evaluates correctly", () =>
    // The canonical parser-style cursor `{ "node": Expr, "pos": Int32 }`.
    val tree: Expr = binOp(2, binOp(0, num(3), num(4)), binOp(1, num(10), num(6)))
    val cur: Cursor = { "node": tree, "pos": 7 }
    [
      expect(eval(cur["node"]).toString()).toBe("28"),
      expect(cur["pos"].toString()).toBe("7")
    ]
  ),

  test("a tree stored in a {String:Expr} map reads back + evaluates correctly", () =>
    var m: { String: Expr } = {}
    m["root"] = binOp(0, num(3), num(4))
    val back = m["root"]
    val r = match back
      is Num => eval(back)
      is BinOp => eval(back)
      else => 0 - 1
    [expect(r.toString()).toBe("7")]
  ),

  test("repeated cursor-record store + read + eval in a loop is leak-free", () =>
    var acc = 0
    range(0, 50).for(i =>
      val cur: Cursor = { "node": binOp(0, num(i), num(1)), "pos": i }
      acc = acc + eval(cur["node"])
    )
    // sum of (i + 1) for i in 0..49 = (49*50/2) + 50 = 1225 + 50 = 1275
    [expect(acc.toString()).toBe("1275")]
  ),

  // unboxed-sumtype Stage 3 — the UNTYPED-object-literal store. Unlike the `Cursor`-typed
  // cases above, the binding has NO type annotation, so its inferred type is a plain `Object`
  // (not a sealed/named record). The read-back PROJECTS the stored sum value to a FRESH SumNode;
  // before this fix the projection was wrongly relocated via `lin_tagged_clone` (boxed-clone op
  // on a raw SumNode) → garbage result + heap-buffer-overflow. Guards that hole forever.
  test("a tree stored in an UNTYPED object reads back + evaluates correctly", () =>
    val tree: Expr = binOp(2, binOp(0, num(3), num(4)), binOp(1, num(10), num(6)))
    val cursor = { "node": tree, "pos": 7 }
    val back: Expr = cursor["node"]
    [expect(eval(back).toString()).toBe("28")]
  ),

  test("a tree stored in an UNTYPED object reads back + toStrings correctly", () =>
    // The genuinely-dynamic consumer: the projected sum value must materialize the REAL tree.
    val tree: Expr = binOp(0, num(3), num(4))
    val cursor = { "node": tree, "pos": 0 }
    [
      // Open objects use LinMap; toString serialises in insertion (declaration) order.
      expect(cursor["node"].toString()).toBe(
        "{\"kind\": \"op\", \"op\": 0, \"left\": {\"kind\": \"num\", \"value\": 3}, \"right\": {\"kind\": \"num\", \"value\": 4}}"
      )
    ]
  ),

  test("repeated UNTYPED-object store + read + eval in a loop is leak-free", () =>
    var acc = 0
    range(0, 50).for(i =>
      val tree: Expr = binOp(0, num(i), num(1))
      val cursor = { "node": tree, "pos": i }
      val back: Expr = cursor["node"]
      acc = acc + eval(back)
    )
    // sum of (i + 1) for i in 0..49 = 1275
    [expect(acc.toString()).toBe("1275")]
  )
])

run(s)
