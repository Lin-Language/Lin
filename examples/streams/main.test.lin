import { expect, toBe, test, suite, run } from "std/test"
import { readStream, readText } from "std/stream"
import { gunzip } from "std/compress"
import { manifest, untar } from "std/archive"
import { for } from "std/iter"
import { push, length } from "std/array"

// Covers the archive path added to the streams example. The fixture `sample.tar.gz` is committed
// beside this file and holds three small members (readme.txt, data.csv, big.log).
val archivePath = "examples/streams/sample.tar.gz"

val unwrapStr = (r: Json): String =>
  match r
    is Error => "err"
    else => r

val s = suite("streams example: archive", [
  test("manifest lists the archived members of the .tar.gz", () =>
    val names = []
    readStream(archivePath)
      .gunzip()
      .manifest()
      .for(m =>
        names.push(m["name"])
      )
    [
      expect(length(names)).toBe(3),
      expect(names[0]).toBe("readme.txt"),
      expect(names[2]).toBe("big.log")
    ]
  ),

  test("untar streams each member's body via the data sub-stream", () =>
    val texts = []
    readStream(archivePath)
      .gunzip()
      .untar((meta, data) =>
        texts.push(unwrapStr(data.readText()))
      )
    [
      expect(texts[0]).toBe("README for the archive example.\nThis tar.gz holds a few small text files.\n"),
      // big.log is ~6.8 KB — proves a multi-chunk body drains correctly through the sub-stream.
      expect(length(texts[2]) > 6000).toBe(true)
    ]
  )
])

run(s)
