import { suite, test, expect, run, toBe } from "std/test"
import { parsePacket, encodePacket, clampSpeed } from "./protocol"
import { length } from "std/array"
import { toFloat32 } from "std/number"

// Ports the Rust parse_packet tests from server/src/main.rs (and the encode
// round-trip / stop test from client/src/main.rs). Test bodies are Assertion[]
// arrays so every assertion runs.
//
// Everything stays in the Float32 wire domain (see protocol.lin): parsed speeds
// are Float32 and are compared against toFloat32(...) of the expected value.
// 1.0, -1.0, 0.0, 0.5, 0.25 are all exact in f32, so == comparison is safe.

val ONE: Float32 = toFloat32(1.0)
val NEG_ONE: Float32 = toFloat32(0.0 - 1.0)
val ZERO: Float32 = toFloat32(0.0)
val HALF: Float32 = toFloat32(0.5)
val QUARTER: Float32 = toFloat32(0.25)

val s = suite("raspberry-protocol", [
  // parse_forward
  test("parsePacket forward = [1, 1]", () => [
    expect(parsePacket(encodePacket(1.0, 1.0))[0]).toBe(ONE),
    expect(parsePacket(encodePacket(1.0, 1.0))[1]).toBe(ONE)
  ]),

  // parse_reverse
  test("parsePacket reverse = [-1, -1]", () => [
    expect(parsePacket(encodePacket(0.0 - 1.0, 0.0 - 1.0))[0]).toBe(NEG_ONE),
    expect(parsePacket(encodePacket(0.0 - 1.0, 0.0 - 1.0))[1]).toBe(NEG_ONE)
  ]),

  // parse_stop
  test("parsePacket stop = [0, 0]", () => [
    expect(parsePacket(encodePacket(0.0, 0.0))[0]).toBe(ZERO),
    expect(parsePacket(encodePacket(0.0, 0.0))[1]).toBe(ZERO)
  ]),

  // parse_turn (0.5 and 0.25 are exact in f32 so == is safe)
  test("parsePacket turn preserves distinct speeds", () => [
    expect(parsePacket(encodePacket(0.5, 0.25))[0]).toBe(HALF),
    expect(parsePacket(encodePacket(0.5, 0.25))[1]).toBe(QUARTER)
  ]),

  // parse_clamps_out_of_range: 5.0 -> 1.0, -3.0 -> -1.0
  test("parsePacket clamps out-of-range speeds to [-1, 1]", () => [
    expect(parsePacket(encodePacket(5.0, 0.0 - 3.0))[0]).toBe(ONE),
    expect(parsePacket(encodePacket(5.0, 0.0 - 3.0))[1]).toBe(NEG_ONE)
  ]),

  // clampSpeed unit (the pure clamp helper)
  test("clampSpeed clamps to [-1, 1] in the f32 domain", () => [
    expect(clampSpeed(HALF)).toBe(HALF),
    expect(clampSpeed(toFloat32(5.0))).toBe(ONE),
    expect(clampSpeed(toFloat32(0.0 - 3.0))).toBe(NEG_ONE)
  ]),

  // roundtrip_with_client_encoding: encode 0.5/-0.25, decode back exactly.
  test("encode/parse round-trip (f32-exact values)", () => [
    expect(parsePacket(encodePacket(0.5, 0.0 - 0.25))[0]).toBe(HALF),
    expect(parsePacket(encodePacket(0.5, 0.0 - 0.25))[1]).toBe(toFloat32(0.0 - 0.25))
  ]),

  // encode_stop: stop packet is all zero bytes
  test("encodePacket stop is 8 zero bytes", () => [
    expect(length(encodePacket(0.0, 0.0))).toBe(8),
    expect(encodePacket(0.0, 0.0)[0]).toBe(0),
    expect(encodePacket(0.0, 0.0)[3]).toBe(0),
    expect(encodePacket(0.0, 0.0)[7]).toBe(0)
  ]),
])

run(s)
