import { suite, test, expect, run, toBe } from "std/test"
import { parseNals, nalType, startCodeAt } from "./nal"
import { length } from "std/array"

// Ports the single-buffer tests from server/src/nal.rs. The stateful cross-call
// tests (chunked_input, start_code_split_across_chunks) are intentionally NOT
// ported — see the PARSER MODEL note in nal.lin: this is a whole-buffer parser
// with no carry-over between calls. Test bodies are Assertion[] arrays (assigned
// to `checks` then returned) so every assertion runs.
//
// Buffers are written as raw byte literals. Start codes: [0,0,0,1] (4-byte),
// [0,0,1] (3-byte). NAL types: 0x67&0x1F=7 (SPS), 0x68&0x1F=8 (PPS),
// 0x65&0x1F=5 (IDR), 0x41&0x1F=1.
//
val s = suite("raspberry-nal", [
  // nalType: the low 5 bits of a header byte. 0x67 (SPS) -> 7, 0x68 (PPS) -> 8,
  // 0x65 (IDR) -> 5; the top 3 bits (nal_ref_idc) are masked off. This is the
  // same field parseNals stores per unit and rtp.lin reads when fragmenting.
  test("nalType extracts the low 5 bits of a header byte", () => [
    expect(nalType(0x67)).toBe(7),
    expect(nalType(0x68)).toBe(8),
    expect(nalType(0x65)).toBe(5),
    expect(nalType(0x1F)).toBe(31),
    expect(nalType(0x41)).toBe(1)
  ]),

  // startCodeAt directly: 4-byte (00 00 00 01) -> 4, 3-byte (00 00 01) -> 3, and
  // every non-start-code shape -> 0. Exercises the nested length/byte guards
  // (the deepest branches in nal.lin) without going through parseNals.
  test("startCodeAt detects 4- and 3-byte start codes", () =>
    val sc4: UInt8[] = [
      0,
      0,
      0,
      1,
      0x67
    ]
    val sc3: UInt8[] = [0, 0, 1, 0x67]
    [
      expect(startCodeAt(sc4, 0)).toBe(4),
      expect(startCodeAt(sc3, 0)).toBe(3)
    ]
  ),

  test("startCodeAt returns 0 for non-start-code and truncated inputs", () =>
    val notZero: UInt8[] = [0x41, 0, 0, 1]
    val zeroNotZero: UInt8[] = [0, 0x41, 0, 1]
    val zerosThenJunk: UInt8[] = [0, 0, 0x41, 0x42]
    val short: UInt8[] = [0, 0]
    val threeZerosNoOne: UInt8[] = [0, 0, 0, 0x42]
    [
      expect(startCodeAt(notZero, 0)).toBe(0), // first byte != 0
      expect(startCodeAt(zeroNotZero, 0)).toBe(0), // second byte != 0
      expect(startCodeAt(zerosThenJunk, 0)).toBe(0), // third byte neither 0 nor 1
      expect(startCodeAt(short, 0)).toBe(0), // fewer than 3 bytes left
      expect(startCodeAt(threeZerosNoOne, 0)).toBe(0) // 00 00 00 not followed by 01
    ]
  ),

  // single_nal_unit: SC4 67 AA BB SC4 68  -> one NAL (type 7, data 67 AA BB),
  // trailing 68 not flushed (matches Rust).
  test("single_nal_unit: one complete NAL, trailing NAL not flushed", () =>
    val buf: UInt8[] = [
      0,
      0,
      0,
      1,
      0x67,
      0xAA,
      0xBB,
      0,
      0,
      0,
      1,
      0x68
    ]
    val nals = parseNals(buf)
    val checks = [
      expect(length(nals)).toBe(1),
      expect(nals[0]["nalType"]).toBe(7),
      expect(length(nals[0]["data"])).toBe(3),
      expect(nals[0]["data"][0]).toBe(0x67),
      expect(nals[0]["data"][1]).toBe(0xAA),
      expect(nals[0]["data"][2]).toBe(0xBB)
    ]
    checks
  ),

  // multiple_nal_units: three NALs, plus trailing SC + 0x41 to flush the third.
  test("multiple_nal_units: SPS, PPS, IDR in order", () =>
    val buf: UInt8[] = [
      0,
      0,
      0,
      1,
      0x67,
      0x01,
      0x02,
      0,
      0,
      0,
      1,
      0x68,
      0x03,
      0,
      0,
      0,
      1,
      0x65,
      0x04,
      0x05,
      0x06,
      0,
      0,
      0,
      1,
      0x41
    ]
    val nals = parseNals(buf)
    val checks = [
      expect(length(nals)).toBe(3),
      expect(nals[0]["nalType"]).toBe(7),
      expect(nals[1]["nalType"]).toBe(8),
      expect(nals[2]["nalType"]).toBe(5)
    ]
    checks
  ),

  // three_byte_start_codes
  test("three_byte_start_codes: 00 00 01 delimiters", () =>
    val buf: UInt8[] = [
      0,
      0,
      1,
      0x67,
      0xAA,
      0,
      0,
      1,
      0x68
    ]
    val nals = parseNals(buf)
    val checks = [
      expect(length(nals)).toBe(1),
      expect(nals[0]["nalType"]).toBe(7)
    ]
    checks
  ),

  // mixed_start_code_lengths: SC4 ... SC3 ... SC4 -> two complete NALs.
  test("mixed_start_code_lengths: 4- and 3-byte mixed", () =>
    val buf: UInt8[] = [
      0,
      0,
      0,
      1,
      0x67,
      0x01,
      0,
      0,
      1,
      0x68,
      0x02,
      0,
      0,
      0,
      1,
      0x65
    ]
    val nals = parseNals(buf)
    val checks = [
      expect(length(nals)).toBe(2),
      expect(nals[0]["nalType"]).toBe(7),
      expect(nals[1]["nalType"]).toBe(8)
    ]
    checks
  ),

  // no_start_code: bytes with no start code yield nothing.
  test("no_start_code: no NALs", () =>
    val buf: UInt8[] = [0x41, 0x42, 0x43]
    val nals = parseNals(buf)
    val checks = [expect(length(nals)).toBe(0)]
    checks
  ),

  // empty_input
  test("empty_input: no NALs", () =>
    val empty: UInt8[] = []
    val nals = parseNals(empty)
    val checks = [expect(length(nals)).toBe(0)]
    checks
  )
])

run(s)
