import { test, suite, run, expect, toBe } from "std/test"

import { nowMs, stamp } from "./clock"

replace nowMs = (): Int64 => 1609459200000

val tests = [
  test("nowMs is pinned by the mock", () => [expect(nowMs()).toBe(1609459200000)]),
  test("stamp sees the mocked clock via its internal nowMs call", () => [expect(stamp()).toBe("2021-01-01T00:00:00.000Z")]),
]

run(suite("clock", tests))
