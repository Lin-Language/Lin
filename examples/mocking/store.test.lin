// Unit tests for store.lin. `replace`ing the stdlib wrappers (`appendFile`,
// `readFile`) keeps the test off the real filesystem. The mocks close over a
// module-level `var` to SPY on the arguments the store passes through — the
// no-extra-framework spy pattern from ADR-071.

import { test, suite, run, expect, toBe, toSatisfy } from "std/test"
import { append, readAll } from "./store"
import { appendFile, readFile } from "std/fs"

// Spy cells: capture what the store hands to the fs layer.
var lastPath = ""
var lastWritten = ""
var appendCalls = 0

replace appendFile = (path: String, content: String): Json =>
  lastPath = path
  lastWritten = content
  appendCalls = appendCalls + 1
  { "type": "success" }

replace readFile = (path: String): Json => "stored contents of ${path}"

val tests = [
  test("append forwards path and newline-terminated line to fs", () => [
    expect(append("/var/log/audit", "hello")).toSatisfy(r => r["type"] == "success"),
    expect(lastPath).toBe("/var/log/audit"),
    expect(lastWritten).toBe("hello\n"),
    expect(appendCalls).toBe(1),
  ]),
  test("readAll delegates to the mocked readFile", () => [
    expect(readAll("/etc/config")).toBe("stored contents of /etc/config"),
  ]),
]

run(suite("store", tests))
