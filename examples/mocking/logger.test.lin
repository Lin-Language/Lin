// Unit tests for logger.lin — the composition under test. Both dependencies are
// mocked: `stamp` (from clock) for a deterministic timestamp, and `append` (from
// store) as a spy capturing the formatted line. The logger itself is unchanged;
// the mocks substitute its imports at link time (ADR-071).

import { test, suite, run, expect, toBe } from "std/test"
import { formatLine, log, info, error } from "./logger"
import { stamp } from "./clock"
import { append } from "./store"

replace stamp = (): String => "2021-01-01T00:00:00.000Z"

// Spy on the line the logger would persist.
var lastLine = ""
replace append = (path: String, line: String): Json =>
  lastLine = line
  { "type": "success" }

val tests = [
  test("formatLine uses the mocked stamp", () => [
    expect(formatLine("WARN", "low memory"))
      .toBe("2021-01-01T00:00:00.000Z [WARN] low memory"),
  ]),
  test("log writes the formatted line through the store", () =>
    val _ = log("/tmp/x.log", "DEBUG", "tick")
    [ expect(lastLine).toBe("2021-01-01T00:00:00.000Z [DEBUG] tick") ]
  ),
  test("info logs at INFO level", () =>
    val _ = info("/tmp/x.log", "up")
    [ expect(lastLine).toBe("2021-01-01T00:00:00.000Z [INFO] up") ]
  ),
  test("error logs at ERROR level", () =>
    val _ = error("/tmp/x.log", "down")
    [ expect(lastLine).toBe("2021-01-01T00:00:00.000Z [ERROR] down") ]
  ),
]

run(suite("logger", tests))
