// Tests for the optional iterator-callback index parameter (examples/indexed).
import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { map, filter, for, reduce, find, takeWhile, dropWhile } from "std/iter"

val s = suite("indexed callbacks", [
  test("map index", () =>
    [
      expect(["a", "b", "c"].map((x, i) => i).toString()).toBe("[0, 1, 2]")
    ]
  ),

  test("map 1-arg regression", () =>
    [
      expect([1, 2, 3].map(n => n * n).toString()).toBe("[1, 4, 9]")
    ]
  ),

  test("for accumulates with index", () =>
    var acc = ""
    ["a", "b"].for((x, i) => acc = "${acc}${i}${x}")
    [
      expect(acc).toBe("0a1b")
    ]
  ),

  test("filter index is source position", () =>
    [
      expect([10, 20, 30, 40].filter((x, i) => i % 2 == 0).toString()).toBe("[10, 30]")
    ]
  ),

  test("reduce third index param", () =>
    [
      expect([10, 10, 10].reduce(0, (acc, n, i) => acc + n * i)).toBe(30)
    ]
  ),

  test("find by index", () =>
    [
      expect([100, 200, 300].find((n, i) => i == 1)).toBe(200)
    ]
  ),

  test("takeWhile / dropWhile by index", () =>
    [
      expect([5, 6, 7, 8].takeWhile((n, i) => i < 3).toString()).toBe("[5, 6, 7]"),
      expect([5, 6, 7, 8].dropWhile((n, i) => i < 3).toString()).toBe("[8]")
    ]
  )
])

run(s)
