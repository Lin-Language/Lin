import { expect, toBe, test, suite, run } from "std/test"
import { contains } from "std/string"
import { HttpRequest as Request } from "std/http"
import { render, renderWith } from "std/template"
import { readJson } from "std/fs"
import { route } from "./router"
import { Config } from "./config"

// End-to-end: build a Request, dispatch it through `route` (which selects the
// handler), and assert the final Response — every route the service exposes plus
// the 404 fall-through. The /route endpoint runs the REAL routing engine (buildAdj
// -> dijkstra -> reconstructPath); only the boundaries are mocked: `render` (so /
// doesn't depend on the on-disk view path) and `readJson` (so the graph is fed
// in-memory instead of from disk).
replace render = (path: String, data: {  }): Json =>
  renderWith("<!DOCTYPE html><title>{{ title }}</title><h1>{{ heading }}</h1>", data)

val graph = {
  "nodes": [
    "A",
    "B",
    "C",
    "D",
    "E"
  ],
  "edges": [
    {
      "from": "A",
      "to": "B",
      "weight": 10
    },
    {
      "from": "A",
      "to": "C",
      "weight": 3
    },
    {
      "from": "C",
      "to": "B",
      "weight": 4
    },
    {
      "from": "C",
      "to": "D",
      "weight": 8
    },
    {
      "from": "B",
      "to": "D",
      "weight": 2
    },
    {
      "from": "D",
      "to": "E",
      "weight": 5
    },
    {
      "from": "B",
      "to": "E",
      "weight": 11
    }
  ]
}

replace readJson = (path: String): Json => graph

val config: Config = {
  "host": "0.0.0.0",
  "port": 3000,
  "debug": false,
  "name": "Lin Maps"
}

val makeReq = (path: String): Request =>
  {
    "method": "GET",
    "path": path,
    "query": "",
    "headers": {},
    "body": ""
  }

val s = suite("web-server integration", [
  test("GET / routes to the index page and renders the HTML body", () =>
    val resp = route(makeReq("/"), config)
    [
      expect(resp["status"]).toBe(200),
      expect(contains(resp["body"], "<!DOCTYPE html>")).toBe(true),
      expect(contains(resp["body"], "Lin Maps")).toBe(true)
    ]
  ),

  test("GET /api/status returns ok JSON", () =>
    val resp = route(makeReq("/api/status"), config)
    [
      expect(resp["status"]).toBe(200),
      expect(contains(resp["body"], "\"status\": \"ok\"")).toBe(true)
    ]
  ),

  test("GET /route/A/E runs Dijkstra and returns the optimal path + distance", () =>
    val resp = route(makeReq("/route/A/E"), config)
    [
      expect(resp["status"]).toBe(200),
      expect(contains(resp["body"], "\"distance\": 14")).toBe(true),
      expect(contains(resp["body"], "\"A\", \"C\", \"B\", \"D\", \"E\"")).toBe(true)
    ]
  ),

  test("GET /users/:id returns the user JSON", () =>
    val resp = route(makeReq("/users/42"), config)
    [
      expect(resp["status"]).toBe(200),
      expect(contains(resp["body"], "User 42")).toBe(true)
    ]
  ),

  test("an unmatched path falls through to a 404 Not Found", () =>
    val resp = route(makeReq("/no/such/route"), config)
    [
      expect(resp["status"]).toBe(404),
      expect(contains(resp["body"], "Not Found")).toBe(true)
    ]
  )
])
run(s)
