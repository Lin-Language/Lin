import { expect, toBe, test, suite, run } from "std/test"
import { parseInt32, parseInt64, parseUInt8, parseUInt16, parseUInt32, parseUInt64, parseFloat32, parseFloat64, toInt32, toFloat64, toFloat32, isInt32, isFloat64, tryParseInt32, tryParseInt64, tryParseUInt8, tryParseUInt16, tryParseUInt32, tryParseUInt64, tryParseFloat32, tryParseFloat64, MAX_UINT8, MIN_INT8, MAX_INT8, MAX_UINT32, MIN_INT32, MAX_INT32, MAX_UINT64, MIN_INT64, MAX_INT64 } from "std/number"
import { toUInt8, toInt8, toUInt16, toInt16, toUInt32, toUInt64 } from "std/number"
import { f32ToBe } from "std/bytes"
import { length } from "std/array"
import { toString } from "std/string"

val s = suite("std/number", [
  test("parseInt32 parses integer string", () => [
    expect("42".parseInt32()).toBe(42)
  ]),

  test("parseInt64 parses large integer string", () => [
    expect("9000000000".parseInt64()).toBe(9000000000)
  ]),

  test("parseUInt8 parses uint8 string", () => [
    expect("255".parseUInt8()).toBe(255)
  ]),

  test("parseUInt16 parses uint16 string", () => [
    expect("65535".parseUInt16()).toBe(65535)
  ]),

  test("parseUInt32 parses uint32 string", () => [
    expect("4000000000".parseUInt32()).toBe(4000000000)
  ]),

  test("parseUInt64 parses uint64 string", () => [
    expect("9000000000000000000".parseUInt64()).toBe(9000000000000000000)
  ]),

  test("parseFloat32 parses float32 string", () => [
    expect("3.14".parseFloat32() > 3.13).toBe(true),
    expect("3.14".parseFloat32() < 3.15).toBe(true)
  ]),

  test("parseFloat64 parses float string", () => [
    expect("3.14".parseFloat64()).toBe(3.14)
  ]),

  test("tryParseUInt32 returns null on bad input", () => [
    expect("bad".tryParseUInt32()).toBe(null)
  ]),

  test("tryParseUInt32 returns value on good input", () => [
    expect("4000000000".tryParseUInt32()).toBe(4000000000)
  ]),

  test("tryParseInt64 returns null on bad input", () => [
    expect("bad".tryParseInt64()).toBe(null)
  ]),

  test("tryParseFloat32 returns null on bad input", () => [
    expect("bad".tryParseFloat32()).toBe(null)
  ]),

  test("toInt32 truncates float", () => [
    expect(3.9.toInt32()).toBe(3)
  ]),

  test("toFloat64 converts int to float", () => [
    expect(5.toFloat64()).toBe(5.0)
  ]),

  test("toFloat32 narrows Float64 to a Float32 usable by f32ToBe", () => [
    // The only way to get a Float32 from a computed Float64. 0.5 is exact in f32:
    // big-endian bytes are 0x3F000000.
    expect(length(f32ToBe(toFloat32(0.5)))).toBe(4),
    expect(f32ToBe(toFloat32(0.5))[0]).toBe(63),
    expect(f32ToBe(toFloat32(0.5))[1]).toBe(0)
  ]),

  test("isInt32 true for integer string", () => [
    expect("42".isInt32()).toBe(true)
  ]),

  test("isInt32 false for float string", () => [
    expect("3.14".isInt32()).toBe(false)
  ]),

  test("isInt32 false for non-numeric string", () => [
    expect("abc".isInt32()).toBe(false)
  ]),

  test("isFloat64 true for float string", () => [
    expect("3.14".isFloat64()).toBe(true)
  ]),

  test("isFloat64 true for integer string", () => [
    expect("42".isFloat64()).toBe(true)
  ]),

  test("isFloat64 false for non-numeric string", () => [
    expect("abc".isFloat64()).toBe(false)
  ]),

  test("tryParseInt32 returns int for valid string", () => [
    expect("42".tryParseInt32()).toBe(42)
  ]),

  test("tryParseInt32 returns null for invalid string", () => [
    expect("abc".tryParseInt32()).toBe(null)
  ]),

  test("tryParseFloat64 returns float for valid string", () => [
    expect("3.14".tryParseFloat64()).toBe(3.14)
  ]),

  test("tryParseFloat64 returns null for invalid string", () => [
    expect("abc".tryParseFloat64()).toBe(null)
  ]),

  test("dot-syntax for number parsing", () =>
    [
      expect("99".parseInt32()).toBe(99),
      expect("2.5".parseFloat64()).toBe(2.5),
      expect("7".isInt32()).toBe(true)
    ]
  ),

  // --- numeric literal suffix typing (spec §3.6) ---
  // An `i64` suffix pins the literal to Int64, so a value far larger than Int32's range
  // (1_705_314_600_000) is preserved exactly rather than truncated to its low 32 bits
  // (212583488). Regression for the silent-truncation bug.
  test("i64 suffix preserves a value beyond Int32 range", () => [
    expect(toString(1705314600000i64)).toBe("1705314600000")
  ]),

  test("i64-suffixed literal round-trips through arithmetic", () =>
    val big = 1705314600000i64
    [
      expect(toString(big + 1i64)).toBe("1705314600001"),
      expect(big > 2147483647i64).toBe(true)
    ]
  ),

  test("Int64 annotation preserves a large literal", () =>
    val ts: Int64 = 1705314600000
    [expect(toString(ts)).toBe("1705314600000")]
  ),

  test("a small u8-suffixed literal types as UInt8", () => [
    // toString works regardless of width; the point is it compiles and keeps its value.
    expect(toString(200u8)).toBe("200")
  ]),

  // --- integer-limit constants (std/number) ---
  test("MAX_UINT8 is 255", () => [
    expect(toString(MAX_UINT8)).toBe("255")
  ]),

  test("MIN_INT8 is -128", () => [
    expect(toString(MIN_INT8)).toBe("-128")
  ]),

  test("MAX_INT8 is 127", () => [
    expect(toString(MAX_INT8)).toBe("127")
  ]),

  test("MAX_UINT32 is 4294967295", () => [
    expect(toString(MAX_UINT32)).toBe("4294967295")
  ]),

  test("MIN_INT32 is -2147483648", () => [
    expect(toString(MIN_INT32)).toBe("-2147483648")
  ]),

  test("MAX_INT32 is 2147483647", () => [
    expect(toString(MAX_INT32)).toBe("2147483647")
  ]),

  test("MAX_UINT64 is 18446744073709551615", () => [
    expect(toString(MAX_UINT64)).toBe("18446744073709551615")
  ]),

  test("MIN_INT64 is -9223372036854775808 (lexer-fix regression)", () => [
    expect(toString(MIN_INT64)).toBe("-9223372036854775808")
  ]),

  test("MAX_INT64 is 9223372036854775807", () => [
    expect(toString(MAX_INT64)).toBe("9223372036854775807")
  ]),

  // ── to* on a SIGNED Int64 source : fixed-width truncating casts ────────────
  // The to* family is overloaded (ADR-074/075): a signed/computed integer argument selects the
  // `Int64` overload (two's-complement truncation), the path an unsigned argument's `UInt64` overload
  // cannot provide since Int64 -> UInt64 is not an implicit coercion. A suffixless integer literal is
  // Int32, which widens only into the `Int64` overload, so these resolve there.
  test("to* truncate an in-range signed value unchanged", () => [
    expect(toString(toUInt8(200))).toBe("200"),
    expect(toString(toInt8(-5))).toBe("-5"),
    expect(toString(toUInt16(1000))).toBe("1000"),
    expect(toString(toInt16(-1000))).toBe("-1000"),
    expect(toString(toUInt32(70000))).toBe("70000"),
    expect(toString(toInt32(-70000))).toBe("-70000")
  ]),

  test("to* truncate an out-of-range signed value to its low bits", () => [
    expect(toString(toUInt8(300))).toBe("44"), // 300 & 0xFF
    expect(toString(toUInt8(256))).toBe("0"),
    expect(toString(toUInt16(70000))).toBe("4464"), // 70000 & 0xFFFF
    expect(toString(toInt8(255))).toBe("-1") // two's-complement reinterpret
  ]),

  test("toInt32 narrows a negative signed value (the toInt32-from-int gap)", () => [
    expect(toString(toInt32(0 - 44))).toBe("-44"),
    expect(toString(toInt32(2024))).toBe("2024")
  ]),

  test("toUInt64 reinterprets a negative signed value (signed->unsigned bridge)", () => [
    expect(toString(toUInt64(0 - 1))).toBe("18446744073709551615")
  ])
])

run(s)
