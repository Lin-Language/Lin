import { expect, toBe, test, suite, run } from "std/test"
import { toString, join } from "std/string"
import { push, length } from "std/array"
import { Bus, bus, on, once, off, emit, listenerCount, emitter, send, request, drain, stop } from "std/event"

// Handlers can't return into the assertions, so they append to a module-level log; tests assert on
// the log. A fresh log per test via `reset`.
var log: AnyVal = []
val reset = (): Null =>
  log = []
val record = (s: String): Null =>
  push(log, s)
val logStr = (): String =>
  join(log, ",")

// A small record payload, to show the bus is generic over any `T` (not just scalars).
type Leg = { "from": String, "to": String }

val s = suite("std/event", [
  // ── Layer 2: synchronous bus, generic over the payload type ──
  test("on + emit invokes listeners in order with the typed value, returns count", () =>
    reset()
    val b: Bus<Int32> = bus((x: Int32): Null => record("A${toString(x)}"))
    on(b, (x: Int32): Null => record("B${toString(x)}"))
    val fired = emit(b, 1)
    [
      expect(fired).toBe(2),
      expect(logStr()).toBe("A1,B1")
    ]
  ),

  test("emit with no listeners fires zero (empty-bus literal, no crash)", () =>
    val b: Bus<Int32> = { "entries": [], "nextId": 0 }
    [
      expect(emit(b, 7)).toBe(0)
    ]
  ),

  test("listenerCount reflects registrations", () =>
    val b: Bus<Int32> = { "entries": [], "nextId": 0 }
    on(b, (x: Int32): Null => null)
    on(b, (x: Int32): Null => null)
    [
      expect(listenerCount(b)).toBe(2)
    ]
  ),

  test("off removes a listener by its subscription handle", () =>
    reset()
    val b: Bus<Int32> = bus((x: Int32): Null => record("A"))
    val subB = on(b, (x: Int32): Null => record("B"))
    val removed = off(b, subB)
    val fired = emit(b, 0)
    [
      expect(removed).toBe(true),
      expect(fired).toBe(1),
      expect(logStr()).toBe("A"),
      expect(listenerCount(b)).toBe(1)
    ]
  ),

  test("off on an already-removed handle is a no-op returning false", () =>
    val b: Bus<Int32> = bus((x: Int32): Null => null)
    val sub = on(b, (x: Int32): Null => null)
    off(b, sub)
    [
      expect(off(b, sub)).toBe(false)
    ]
  ),

  test("once fires exactly one time then is removed", () =>
    reset()
    val b: Bus<Int32> = bus((x: Int32): Null => record("on${toString(x)}"))
    once(b, (x: Int32): Null => record("once${toString(x)}"))
    val first = emit(b, 1)
    val second = emit(b, 2)
    [
      expect(first).toBe(2),
      expect(second).toBe(1),
      expect(logStr()).toBe("on1,once1,on2"),
      expect(listenerCount(b)).toBe(1)
    ]
  ),

  test("the bus is generic over a record payload, not just scalars", () =>
    reset()
    val b: Bus<Leg> = bus((leg: Leg): Null => record("${leg["from"]}->${leg["to"]}"))
    val fired = emit(b, { "from": "A", "to": "B" })
    [
      expect(fired).toBe(1),
      expect(logStr()).toBe("A->B")
    ]
  ),

  // ── Layer 1: async, worker-backed emitter, generic over payload `T` and state `S` ──
  test("emitter folds sent values into worker-owned state, drain returns it", () =>
    val sink = emitter((x: Int32, sum: Int32): Int32 => sum + x, 0, 0)
    send(sink, 10)
    send(sink, 5)
    send(sink, 100)
    val total: Int32 | Error = drain(sink, 0)
    stop(sink)
    val n = match total
      is Error => 0 - 1
      else => total
    [
      expect(n).toBe(115)
    ]
  ),

  test("emitter built by a factory that RETURNS it keeps its var state (spec §24.6.4)", () =>
    val mkSink = (): AnyVal =>
      emitter((x: Int32, n: Int32): Int32 => n + 1, 0, 0)
    val sink = mkSink()
    send(sink, 0)
    send(sink, 0)
    val count: Int32 | Error = drain(sink, 0)
    stop(sink)
    val n = match count
      is Error => 0 - 1
      else => count
    [
      expect(n).toBe(2)
    ]
  ),

  test("request delivers a value synchronously and returns the folded state", () =>
    val sink = emitter((x: Int32, acc: Int32): Int32 => acc + x, 0, 0)
    val afterFirst: Int32 | Error = request(sink, 7)
    val afterSecond: Int32 | Error = request(sink, 3)
    stop(sink)
    val a = match afterFirst
      is Error => 0 - 1
      else => afterFirst
    val b = match afterSecond
      is Error => 0 - 1
      else => afterSecond
    [
      expect(a).toBe(7),
      expect(b).toBe(10)
    ]
  ),

  test("emitter folds a record payload into an array state (the RAPTOR index shape)", () =>
    val sink = emitter(
      (leg: Leg, acc: String[]): String[] =>
        push(acc, leg["from"])
        acc,
      [],
      { "from": "", "to": "" }
    )
    send(sink, { "from": "A", "to": "B" })
    send(sink, { "from": "X", "to": "Y" })
    val origins: String[] | Error = drain(sink, { "from": "", "to": "" })
    stop(sink)
    val n = match origins
      is Error => 0 - 1
      else => length(origins)
    [
      expect(n).toBe(2)
    ]
  )
])

run(s)
