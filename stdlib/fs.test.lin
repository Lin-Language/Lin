import { expect, toBe, toSucceed, toFail, test, suite, run } from "std/test"
import { toString } from "std/string"
import { length } from "std/array"
import { readFile, writeFile, appendFile, readLines, readJson, writeJson, exists, isFile, isDir, stat, ls, mkdir, rm, cp, mv, readFileBytes, writeFileBytes, writeLines } from "std/fs"
import { glob, withTempFile, withTempDir, tempFile, tempDir, chmod, symlink, readlink, isSymlink, lstat, touch, realpath } from "std/fs"

val tmpRead = "/tmp/lin_test_fs_read.txt"
val tmpExists = "/tmp/lin_test_fs_exists.txt"
val tmpAppend = "/tmp/lin_test_fs_append.txt"
val tmpJson = "/tmp/lin_test_fs_json.json"
val tmpStat = "/tmp/lin_test_fs_stat.txt"
val tmpDir = "/tmp/lin_test_fs_dir"
val tmpRename = "/tmp/lin_test_fs_rename_src.txt"
val tmpRenameDst = "/tmp/lin_test_fs_rename_dst.txt"

val s = suite("std/fs", [
  test("writeFile then readFile round-trips", () =>
    tmpRead.writeFile("hello lin")
    val content = tmpRead.readFile()
    [
      expect(content).toBe("hello lin")
    ]
  ),

  test("readFile missing path returns error", () =>
    val result = "/nonexistent/path/does/not/exist.txt".readFile()
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("exists false before write, true after", () =>
    tmpExists.rm({  })
    val before = tmpExists.exists()
    tmpExists.writeFile("x")
    val after = tmpExists.exists()
    [
      expect(before).toBe(false),
      expect(after).toBe(true)
    ]
  ),

  test("appendFile accumulates content", () =>
    tmpAppend.writeFile("line1\n")
    tmpAppend.appendFile("line2\n")
    val content = tmpAppend.readFile()
    [
      expect(content).toBe("line1\nline2\n")
    ]
  ),

  test("readLines splits on newlines", () =>
    tmpRead.writeFile("alpha\nbeta\ngamma")
    val lines = tmpRead.readLines()
    [
      expect(lines.length()).toBe(3)
    ]
  ),

  test("readLines returns error for missing file", () =>
    val result = "/nonexistent/path/that/does/not/exist.txt".readLines()
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("writeJson then readJson round-trips", () =>
    val data = { "name": "lin", "version": 1 }
    tmpJson.writeJson(data, {  })
    val loaded = tmpJson.readJson()
    [
      expect(loaded["name"]).toBe("lin")
    ]
  ),

  test("writeJson default is pretty (multiline)", () =>
    val data = { "name": "lin" }
    tmpJson.writeJson(data, {  })
    val content = tmpJson.readFile()
    [
      expect(tmpJson.isFile()).toBe(true)
    ]
  ),

  test("writeJson compact option writes compact JSON", () =>
    val data = { "name": "lin", "version": 1 }
    tmpJson.writeJson(data, { "compact": true })
    val content = tmpJson.readFile()
    [
      expect(content).toBe("{\"name\":\"lin\",\"version\":1}")
    ]
  ),

  test("isFile false before write, true after", () =>
    val tmpIsFile = "/tmp/lin_test_fs_isfile.txt"
    tmpIsFile.rm({  })
    val before = tmpIsFile.isFile()
    tmpIsFile.writeFile("hello")
    val after = tmpIsFile.isFile()
    [
      expect(before).toBe(false),
      expect(after).toBe(true)
    ]
  ),

  test("isDir returns true for temp dir, false for file", () =>
    tmpRead.writeFile("x")
    [
      expect("/tmp".isDir()).toBe(true),
      expect(tmpRead.isDir()).toBe(false)
    ]
  ),

  test("stat returns metadata for existing file", () =>
    tmpStat.writeFile("hello lin")
    val s = tmpStat.stat()
    [
      expect(s["size"]).toBe(9),
      expect(s["isFile"]).toBe(true),
      expect(s["isDir"]).toBe(false)
    ]
  ),

  test("stat returns error for missing path", () =>
    val s = "/nonexistent/path/that/does/not/exist.txt".stat()
    [
      expect(s["type"]).toBe("error")
    ]
  ),

  test("stat includes mode field", () =>
    tmpStat.writeFile("hello")
    val s = tmpStat.stat()
    val mode = s["mode"]
    [
      expect(mode != null).toBe(true)
    ]
  ),

  test("mkdir creates directory", () =>
    val mkdirPath = "/tmp/lin_test_fs_mkdir_once"
    mkdirPath.mkdir({  })
    [
      expect(mkdirPath.isDir()).toBe(true)
    ]
  ),

  test("mkdir with parents option creates nested directories", () =>
    val nested = "/tmp/lin_test_fs_mkdirall/a/b"
    nested.mkdir({ "parents": true })
    [
      expect(nested.isDir()).toBe(true)
    ]
  ),

  test("ls returns entries in a directory", () =>
    val listTmpDir = "/tmp/lin_test_fs_listdir"
    listTmpDir.mkdir({ "parents": true })
    "/tmp/lin_test_fs_listdir/x.txt".writeFile("x")
    "/tmp/lin_test_fs_listdir/y.txt".writeFile("y")
    val entries = listTmpDir.ls({  })
    [
      expect(entries.length()).toBe(2)
    ]
  ),

  test("ls returns error for missing directory", () =>
    val result = "/nonexistent/path/that/does/not/exist".ls({  })
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("ls with recursive option returns nested entries", () =>
    val recDir = "/tmp/lin_test_fs_ls_recursive"
    recDir.mkdir({ "parents": true })
    "/tmp/lin_test_fs_ls_recursive/sub".mkdir({ "parents": true })
    "/tmp/lin_test_fs_ls_recursive/a.txt".writeFile("a")
    "/tmp/lin_test_fs_ls_recursive/sub/b.txt".writeFile("b")
    val entries = recDir.ls({ "recursive": true })
    [
      expect(entries.length() >= 3).toBe(true)
    ]
  ),

  test("rm removes a file", () =>
    tmpRename.writeFile("to delete")
    val before = tmpRename.exists()
    tmpRename.rm({  })
    val after = tmpRename.exists()
    [
      expect(before).toBe(true),
      expect(after).toBe(false)
    ]
  ),

  test("rm returns error for missing file", () =>
    val result = "/nonexistent/path/that/does/not/exist.txt".rm({  })
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("rm with recursive option removes directory", () =>
    val rmDir = "/tmp/lin_test_fs_rm_recursive"
    rmDir.mkdir({ "parents": true })
    "/tmp/lin_test_fs_rm_recursive/file.txt".writeFile("x")
    rmDir.rm({ "recursive": true })
    [
      expect(rmDir.exists()).toBe(false)
    ]
  ),

  test("mv moves a file", () =>
    tmpRename.writeFile("hello rename")
    tmpRename.mv(tmpRenameDst)
    [
      expect(tmpRename.exists()).toBe(false),
      expect(tmpRenameDst.exists()).toBe(true),
      expect(tmpRenameDst.readFile()).toBe("hello rename")
    ]
  ),

  test("cp copies a file", () =>
    val cpSrc = "/tmp/lin_test_fs_cp_src.txt"
    val cpDst = "/tmp/lin_test_fs_cp_dst.txt"
    cpSrc.writeFile("copy me")
    cpDst.rm({  })
    cpSrc.cp(cpDst)
    [
      expect(cpSrc.exists()).toBe(true),
      expect(cpDst.exists()).toBe(true),
      expect(cpDst.readFile()).toBe("copy me")
    ]
  ),

  test("readFileBytes and writeFileBytes round-trip", () =>
    val byteFile = "/tmp/lin_test_fs_bytes.bin"
    // readFileBytes returns a packed UInt8[] byte buffer (§35.1), or an Error.
    val bytesIn = tmpRead.readFileBytes()
    match bytesIn
      is Error => [expect(false).toBe(true)]
      else =>
        byteFile.writeFileBytes(bytesIn)
        val bytesOut = byteFile.readFileBytes()
        match bytesOut
          is Error => [expect(false).toBe(true)]
          else =>
            [
              expect(bytesIn.length()).toBe(bytesOut.length()),
              expect(bytesIn[0]).toBe(bytesOut[0])
            ]
  ),

  test("writeLines and readLines round-trip", () =>
    val linesFile = "/tmp/lin_test_fs_lines_rt.txt"
    linesFile.writeLines(["foo", "bar", "baz"])
    val result = linesFile.readLines()
    [
      expect(result.length()).toBe(3)
    ]
  ),

  // --- std/fs extras (fs-extras proposal) ---
  // Sandbox tests create a unique scratch dir with tempDir() and `match` it to narrow the
  // `String | Error` union to a plain String, doing all work + cleanup in the `else` arm.
  test("glob matches *.txt in a sandbox dir", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/a.txt".writeFile("a")
        "${dir}/b.txt".writeFile("b")
        "${dir}/c.log".writeFile("c")
        val matches = glob("${dir}/*.txt")
        dir.rm({ "recursive": true })
        [
          expect(matches.length()).toBe(2)
        ]
  ),

  test("glob ** matches recursively", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/sub".mkdir({ "parents": true })
        "${dir}/top.lin".writeFile("x")
        "${dir}/sub/deep.lin".writeFile("y")
        val matches = glob("${dir}/**/*.lin")
        dir.rm({ "recursive": true })
        [
          expect(matches.length() >= 1).toBe(true)
        ]
  ),

  test("glob no-match returns empty array, not error", () =>
    val matches = glob("/tmp/lin_test_fs_glob_nomatch_dir/*.zzz")
    [
      expect(matches.length()).toBe(0)
    ]
  ),

  test("glob malformed pattern returns error", () =>
    val result = glob("/tmp/[")
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("symlink + readlink + isSymlink round-trip", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/target.txt".writeFile("contents")
        val link = "${dir}/link"
        "target.txt".symlink(link)
        val target = link.readlink()
        val isLink = link.isSymlink()
        val notLink = "${dir}/target.txt".isSymlink()
        dir.rm({ "recursive": true })
        [
          expect(target).toBe("target.txt"),
          expect(isLink).toBe(true),
          expect(notLink).toBe(false)
        ]
  ),

  test("isSymlink is false for a missing path", () =>
    [
      expect("/tmp/lin_test_fs_no_such_link".isSymlink()).toBe(false)
    ]
  ),

  test("readlink on a non-symlink returns error", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        val f = "${dir}/regular.txt"
        f.writeFile("x")
        val result = f.readlink()
        dir.rm({ "recursive": true })
        [
          expect(result["type"]).toBe("error")
        ]
  ),

  test("chmod sets mode reported by stat", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        val f = "${dir}/run.sh"
        f.writeFile("echo hi")
        f.chmod(493)
        val s = f.stat()
        match s
          is Error => [expect(false).toBe(true)]
          else =>
            val mode = s["mode"]
            dir.rm({ "recursive": true })
            [
              // mode includes the file-type bits; mask to the permission bits (0o777 == 511).
              expect(mode - (mode / 512) * 512).toBe(493)
            ]
  ),

  test("lstat reports isSymlink true for a link, stat reports false", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/real.txt".writeFile("x")
        val link = "${dir}/lnk"
        "real.txt".symlink(link)
        val raw = link.lstat()
        val followed = link.stat()
        val viaOpts = link.stat({ "follow": false })
        dir.rm({ "recursive": true })
        [
          expect(raw["isSymlink"]).toBe(true),
          expect(followed["isSymlink"]).toBe(false),
          expect(viaOpts["isSymlink"]).toBe(true)
        ]
  ),

  test("touch creates an empty file when absent", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        val f = "${dir}/stamp"
        val before = f.exists()
        f.touch()
        val after = f.exists()
        val content = f.readFile()
        dir.rm({ "recursive": true })
        [
          expect(before).toBe(false),
          expect(after).toBe(true),
          expect(content).toBe("")
        ]
  ),

  test("touch returns error when parent dir is missing", () =>
    val result = "/tmp/lin_test_fs_no_such_parent_dir/file.txt".touch()
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("realpath resolves .. and symlinks", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/sub".mkdir({ "parents": true })
        "${dir}/sub/file.txt".writeFile("x")
        val resolved = "${dir}/sub/../sub/file.txt".realpath()
        val canon = "${dir}/sub/file.txt".realpath()
        dir.rm({ "recursive": true })
        [
          expect(resolved).toBe(canon)
        ]
  ),

  test("realpath returns error for a missing path", () =>
    val result = "/nonexistent/path/that/does/not/exist.txt".realpath()
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("tempFile creates a unique 0600 file the caller deletes", () =>
    val path = tempFile({})
    match path
      is Error => [expect(false).toBe(true)]
      else =>
        val created = path.isFile()
        path.rm({  })
        [
          expect(created).toBe(true),
          expect(path.exists()).toBe(false)
        ]
  ),

  test("tempFile honours prefix and suffix", () =>
    val path = tempFile({ "prefix": "report-", "suffix": ".csv" })
    match path
      is Error => [expect(false).toBe(true)]
      else =>
        val created = path.isFile()
        path.rm({  })
        [
          expect(created).toBe(true)
        ]
  ),

  test("tempDir creates a unique directory the caller deletes", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        val created = dir.isDir()
        dir.rm({ "recursive": true })
        [
          expect(created).toBe(true),
          expect(dir.exists()).toBe(false)
        ]
  ),

  test("withTempFile runs fn and deletes the file after", () =>
    // withTempFile returns the closure's result (here the path String) and deletes the file.
    val captured = withTempFile((tmp: String): String =>
      tmp.writeFile("scratch")
      tmp
    )
    match captured
      is Error => [expect(false).toBe(true)]
      else =>
        [
          // captured is the path string; the file is gone now that withTempFile returned.
          expect(captured.exists()).toBe(false)
        ]
  ),

  test("withTempFile cleans up even when fn returns an Error", () =>
    val pathCell = withTempFile((tmp: String): AnyVal =>
      tmp.writeFile("x")
      {
        "type": "error",
        "message": "boom",
        "path": tmp
      }
    )
    val leftover = toString(pathCell["path"])
    [
      expect(pathCell["type"]).toBe("error"),
      // cleanup runs before withTempFile returns, even on the Error path.
      expect(leftover.exists()).toBe(false)
    ]
  ),

  test("withTempDir runs fn and removes the tree after", () =>
    val dirCell = withTempDir((dir: String): String =>
      "${dir}/nested.txt".writeFile("x")
      dir
    )
    match dirCell
      is Error => [expect(false).toBe(true)]
      else =>
        [
          expect(dirCell.exists()).toBe(false)
        ]
  ),

  test("glob via dot-application and f(x) form agree", () =>
    val dir = tempDir()
    match dir
      is Error => [expect(false).toBe(true)]
      else =>
        "${dir}/one.md".writeFile("1")
        val viaDot = "${dir}/*.md".glob()
        val viaCall = glob("${dir}/*.md")
        dir.rm({ "recursive": true })
        [
          expect(viaDot.length()).toBe(viaCall.length())
        ]
  )
])

run(s)
