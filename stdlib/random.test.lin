import { expect, toBe, test, suite, run } from "std/test"
import { seed, nextInt, randInt, float, boolean, choice, shuffle, shuffleInPlace, sample, reseed, next, int, real, flip, pick, shuffled, Rng } from "std/random"
import { length, slice, push } from "std/array"
import { range, for, map } from "std/iter"
import { join } from "std/string"

// ── Helpers ──────────────────────────────────────────────────────────────────────────────────
// Draw the first `n` raw Int32 outputs of a generator into an array (threading the handle). Pulling
// the values out into a named helper keeps the tests free of multiline inline match/closure bodies.
val firstInts = (r0: Rng, n: Int32): Int32[] =>
  var out: Int32[] = []
  var r = r0
  range(0, n).for(_ =>
    val d = nextInt(r)
    r = d["rng"]
    push(out, d["value"])
  )
  out

// Draw the first `n` bounded ints in [lo, hi).
val firstBounded = (r0: Rng, n: Int32, lo: Int32, hi: Int32): Int32[] =>
  var out: Int32[] = []
  var r = r0
  range(0, n).for(_ =>
    val d = randInt(r, lo, hi)
    r = d["rng"]
    push(out, d["value"])
  )
  out

// Are two Int32 arrays equal element-for-element?
val intArraysEqual = (a: Int32[], b: Int32[]): Boolean =>
  if length(a) != length(b) then
    false
  else
    var ok = true
    range(0, length(a)).for(i =>
      if a[i] != b[i] then ok = false
    )
    ok

// Sorted copy (insertion sort — small arrays only) so we can compare multisets.
val sortedInts = (xs: Int32[]): Int32[] =>
  val out = slice(xs, 0, length(xs))
  val n = length(out)
  range(1, n).for(i =>
    var j = i
    range(0, i).for(_ =>
      if j > 0 && out[j - 1] > out[j] then
        val t = out[j - 1]
        out[j - 1] = out[j]
        out[j] = t
        j = j - 1
    )
  )
  out

// True if every element of `a` lies in [lo, hi).
val allInRange = (a: Int32[], lo: Int32, hi: Int32): Boolean =>
  var ok = true
  a.for(x =>
    if x < lo || x >= hi then ok = false
  )
  ok

// True if `a` has no repeated element (used for the no-replacement check on small arrays).
val allDistinct = (a: Int32[]): Boolean =>
  val s = sortedInts(a)
  var ok = true
  range(1, length(s)).for(i =>
    if s[i] == s[i - 1] then ok = false
  )
  ok

// True if `a` and `b` are permutations of one another (same multiset).
val sameMultiset = (a: Int32[], b: Int32[]): Boolean =>
  intArraysEqual(sortedInts(a), sortedInts(b))

val s = suite("std/random", [
  // ── Reproducibility: same seed → identical sequence, pinned to exact values ──────────────────
  // These exact Int32 values are PCG XSH-RR 64/32 over a SplitMix64-seeded state for seed 42; they
  // are the contract — if the algorithm changes, this test must change deliberately.
  test("seed(42) reproduces an exact, pinned Int32 sequence", () => [
    expect(join(firstInts(seed(42u64), 5).map(x => "${x}"), ",")).toBe("-786574049,-1448063931,-1244038487,-1444235570,-163589631")
  ]),

  test("the same seed yields the same sequence twice", () => [
    expect(intArraysEqual(firstInts(seed(123u64), 16), firstInts(seed(123u64), 16))).toBe(true)
  ]),

  test("different seeds yield different sequences", () => [
    expect(intArraysEqual(firstInts(seed(1u64), 8), firstInts(seed(2u64), 8))).toBe(false)
  ]),

  test("a handle is immutable: drawing from the same Rng twice gives the same value", () => [
    expect(nextInt(seed(7u64))["value"]).toBe(nextInt(seed(7u64))["value"])
  ]),

  // ── randInt bounds [lo, hi) ──────────────────────────────────────────────────────────────────
  test("randInt stays within [lo, hi)", () => [
    expect(allInRange(firstBounded(seed(42u64), 200, 10, 20), 10, 20)).toBe(true)
  ]),

  test("randInt over a single-value range always returns lo", () => [
    expect(allInRange(firstBounded(seed(9u64), 50, 5, 6), 5, 6)).toBe(true)
  ]),

  test("randInt on an empty range (hi <= lo) returns lo", () => [
    expect(randInt(seed(3u64), 100, 100)["value"]).toBe(100)
  ]),

  test("randInt is reproducible and pinned for [0, 100)", () => [
    expect(join(firstBounded(seed(42u64), 8, 0, 100).map(x => "${x}"), ",")).toBe("47,65,9,26,65,79,81,8")
  ]),

  // ── float / boolean ──────────────────────────────────────────────────────────────────────────
  test("float lands in [0, 1)", () => [
    expect(float(seed(5u64))["value"] >= 0.0 && float(seed(5u64))["value"] < 1.0).toBe(true)
  ]),

  test("boolean is reproducible for a given seed", () => [
    expect(boolean(seed(11u64))["value"]).toBe(boolean(seed(11u64))["value"])
  ]),

  // ── shuffle: a permutation, non-mutating ─────────────────────────────────────────────────────
  test("shuffle preserves the multiset (it is a permutation)", () => [
    expect(sameMultiset(shuffle(seed(99u64), [1, 2, 3, 4, 5, 6])["value"], [1, 2, 3, 4, 5, 6])).toBe(true)
  ]),

  test("shuffle does not mutate its input", () => [
    expect(intArraysEqual(shuffleSourceUnchanged(), [1, 2, 3, 4, 5, 6])).toBe(true)
  ]),

  test("shuffle is reproducible for a given seed", () => [
    expect(intArraysEqual(
      shuffle(seed(99u64), [
        1,
        2,
        3,
        4,
        5,
        6
      ])["value"],
      shuffle(seed(99u64), [
        1,
        2,
        3,
        4,
        5,
        6
      ])["value"]
    )).toBe(true)
  ]),

  test("shuffleInPlace mutates the array into a permutation of the original", () => [
    expect(sameMultiset(shuffledInPlaceResult(), [10, 20, 30, 40, 50])).toBe(true)
  ]),

  // ── sample: size and no-replacement ──────────────────────────────────────────────────────────
  test("sample returns exactly k elements", () => [
    expect(length(sample(seed(99u64), [1, 2, 3, 4, 5, 6], 3)["value"])).toBe(3)
  ]),

  test("sample draws WITHOUT replacement (all distinct)", () => [
    expect(allDistinct(sample(seed(99u64), [1, 2, 3, 4, 5, 6], 4)["value"])).toBe(true)
  ]),

  test("sample is a subset of the source", () => [
    expect(allInRange(sample(seed(99u64), [1, 2, 3, 4, 5, 6], 3)["value"], 1, 7)).toBe(true)
  ]),

  test("sample with k >= length is a full permutation", () => [
    expect(sameMultiset(sample(seed(99u64), [1, 2, 3, 4, 5, 6], 10)["value"], [1, 2, 3, 4, 5, 6])).toBe(true)
  ]),

  test("sample with k <= 0 is empty", () => [
    expect(length(sample(seed(99u64), [1, 2, 3, 4, 5, 6], 0)["value"])).toBe(0)
  ]),

  // ── choice ───────────────────────────────────────────────────────────────────────────────────
  test("choice on a non-empty array returns a member", () => [
    expect(choiceIsMember()).toBe(true)
  ]),

  test("choice on an empty array returns null", () => [
    expect(choiceEmptyIsNull()).toBe(true)
  ]),

  test("choice on an empty array does not advance the generator", () => [
    expect(choiceEmptyPreservesRng()).toBe(true)
  ]),

  // ── global convenience API ───────────────────────────────────────────────────────────────────
  test("reseed makes the global stream reproducible (pinned)", () => [
    expect(globalReseededSequence()).toBe("-786574049,-1448063931,-1244038487")
  ]),

  test("global int respects [lo, hi)", () => [
    expect(globalIntInRange()).toBe(true)
  ]),

  test("global real lands in [0, 1)", () => [
    expect(globalRealInRange()).toBe(true)
  ]),

  test("global flip is reproducible after reseed", () => [
    expect(globalFlipReproducible()).toBe(true)
  ]),

  test("global pick on empty is null, on non-empty is a member", () => [
    expect(globalPickBehaviour()).toBe(true)
  ]),

  test("global shuffled preserves the multiset", () => [
    expect(globalShuffledIsPermutation()).toBe(true)
  ])
])

// ── Test bodies pulled out as named helpers (match/closure-heavy logic stays out of the inline
//    `test(...)` argument, which keeps the suite readable and sidesteps awkward multiline inline
//    bodies in a callback). ──────────────────────────────────────────────────────────────────────
val shuffleSourceUnchanged = (): Int32[] =>
  val src = [
    1,
    2,
    3,
    4,
    5,
    6
  ]
  val _ = shuffle(seed(99u64), src)
  src

val shuffledInPlaceResult = (): Int32[] =>
  val xs = [
    10,
    20,
    30,
    40,
    50
  ]
  val _ = shuffleInPlace(seed(99u64), xs)
  xs

val choiceIsMember = (): Boolean =>
  val v = choice(seed(99u64), [7, 8, 9])["value"]
  v == 7 || v == 8 || v == 9

val choiceEmptyIsNull = (): Boolean =>
  val empty: Int32[] = []
  choice(seed(1u64), empty)["value"] == null

val choiceEmptyPreservesRng = (): Boolean =>
  // With an empty array, choice must return the generator UNADVANCED, so the next draw from the
  // returned handle equals a fresh draw from the original seed.
  val empty: Int32[] = []
  val r0 = seed(1u64)
  val c = choice(r0, empty)
  nextInt(c["rng"])["value"] == nextInt(r0)["value"]

val globalReseededSequence = (): String =>
  reseed(42u64)
  val a = next()
  val b = next()
  val c = next()
  "${a},${b},${c}"

val globalIntInRange = (): Boolean =>
  reseed(7u64)
  var ok = true
  range(0, 100).for(_ =>
    val v = int(3, 9)
    if v < 3 || v >= 9 then ok = false
  )
  ok

val globalRealInRange = (): Boolean =>
  reseed(7u64)
  val v = real()
  v >= 0.0 && v < 1.0

val globalFlipReproducible = (): Boolean =>
  reseed(7u64)
  val a = flip()
  reseed(7u64)
  val b = flip()
  a == b

// `pick`/`shuffled` are the GLOBAL `Json`-array convenience helpers (see the workaround BUG note
// at the foot of this file), so these bodies compare against `Json` values directly.
val globalPickBehaviour = (): Boolean =>
  reseed(7u64)
  val empty: Int32[] = []
  val none = pick(empty)
  val some = pick([100, 200])
  none == null && (some == 100 || some == 200)

val globalShuffledIsPermutation = (): Boolean =>
  reseed(7u64)
  val out = shuffled([
    1,
    2,
    3,
    4,
    5
  ])
  // Same length, and every original value 1..5 still present exactly once (it is a 5-element
  // distinct set, so "all present" + "right length" ⇒ a permutation).
  if length(out) != 5 then
    false
  else
    var allPresent = true
    range(1, 6).for(v =>
      var found = false
      range(0, length(out)).for(i =>
        if out[i] == v then found = true
      )
      if found == false then allPresent = false
    )
    allPresent

run(s)
// ══ COMPILER BUGS encountered building this module (worked around in Lin; NOT fixed) ══════════════
//
// BUG 1 — in-place field mutation of a packed sealed record crashes.
//   With `type R = { "x": UInt64 }`, `val r: R = { "x": 1u64 }; r["x"] = 2u64` aborts in
//   `lin_object_set` (object.rs:195, `cap - 1` underflow): an all-scalar named record is laid out
//   as an unboxed packed struct with no hash index, but index-assignment routes through the boxed
//   `lin_object_set` path. WORKAROUND: `Rng` is treated as immutable — every draw builds a FRESH
//   `Rng` and returns it (the functional PCG style), so no field is ever mutated in place.
//
// BUG 2 — an EXPORTED GENERIC function that reads a module-level `var` and threads it through a
//   call miscompiles across the module boundary.
//   A `var g: Rng` at module scope, read inside an exported `<T>(xs: T[])` and passed as the first
//   argument to another function, is either (a) dropped from the emitted call — "Incorrect number
//   of arguments passed to called function!" at codegen, the packed `Rng` arg vanishing — or
//   (b) passed as a misaligned pointer (`misaligned pointer dereference: address … 0x…2`,
//   memory.rs:129) at run time. The NON-generic global wrappers (`next`/`int`/`real`/`flip`) that
//   read the same `g` are unaffected, and a LOCAL (non-exported / user-file) generic wrapper doing
//   the identical thing works — it is specifically the exported-generic-in-stdlib + module-var
//   combination. WORKAROUND: the two GLOBAL collection helpers `pick`/`shuffled` are declared over
//   `Json` (non-generic) instead of `T[]`. The fully-generic, type-safe equivalents remain the
//   EXPLICIT-HANDLE `choice`/`shuffle` (they take an `Rng` parameter rather than reading a global,
//   so neither bug fires).
//
// Minimal repro for BUG 2 (compile error), assuming `pick`/`shuffled` were generic:
//   import { shuffled } from "std/random"
//   val main = (): Null => print("${shuffled([1, 2, 3])}\n")
//   main()
//   ⇒ Build failed: codegen error: Incorrect number of arguments passed to called function!
//        %call_n = tail call ptr @std_random_shuffle(ptr %0)
//
// BUG 3 — building a record literal whose field reads a LOCAL BINDING leaks a box per call.
//   (Memory-safe — no UAF/double-free; clean under `detect_leaks=0` — but a steady per-call leak
//   under `detect_leaks=1`.)
//   Two equivalent shapes both leak, AddressSanitizer-verified linear in call count (~95–535
//   bytes/call across loop counts 200/2000):
//     (a) a record field initialised from an intermediate scalar `val`/`var`, and
//     (b) binding the RESULT of a record-returning call (`val s = f(x)`) and then re-wrapping its
//         fields into a new record (`{ "a": s["a"], "b": s["b"] }`).
//   Both vanish when every field is an INLINE expression over the parameters / a record index of a
//   value that is itself returned unchanged. This module's whole design threads state by returning
//   `{ value, rng }` pairs, so the draw functions hit shape (b) unavoidably. The single hottest
//   helper, `step`, IS written with fully-inline fields (see its comment) to stay allocation-clean;
//   the thin draw wrappers (`nextInt`/`randInt`/`float`/`boolean`) and `splitmix64` still incur the
//   small per-call leak. No further Lin workaround is applied: inlining `step` into every wrapper
//   would duplicate the generator and hurt readability for a bounded, memory-safe leak. This is a
//   compiler codegen bug to fix (a bound/transient heap record feeding an object-literal field is
//   never released); NOT a defect in this module's logic — it reproduces in ~8 lines of unrelated
//   pure Lin.
//
// Minimal repro for BUG 3 (run under ASan with detect_leaks=1):
//   type P = { "a": UInt64, "b": UInt64 }
//   val mk   = (x: UInt64): P => { "a": x * 3u64, "b": x + 1u64 }       // leak-free on its own
//   val wrap = (x: UInt64): P =>
//     val s = mk(x)                                                     // bind a record return…
//     { "a": s["a"], "b": s["b"] }                                      // …re-wrap ⇒ leaks/call
//   // loop `wrap` over 2000 iterations ⇒ ~190 KB leaked, linear.
//   // The intermediate-scalar variant `val y = x + 1u64; { "a": x, "b": y }` leaks identically;
//   // the all-inline `{ "a": x, "b": x + 1u64 }` leaks nothing.
