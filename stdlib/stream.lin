// std/stream тАФ opaque, lazy, effectful byte/value streams (streams brief, ADR-072).
//
// A `Stream<T>` is a lazy pull-source that owns an OS resource. Building a pipeline
// (readStream тЖТ lines тЖТ map тЖТ filter тЖТ writeStream) allocates lazy adapter nodes but reads
// NOTHING; a terminal driver (`.drain()`, `collect`, `readText`) pulls the graph to completion.
// IN-BAND error threading: the first read/transform Error short-circuits straight to the
// terminal op, so the chain stays fluent (no `is Error` between steps).
//
// Stream is opaque: `compat.rs` forbids every non-stream operation on a `Stream` value, so the
// only thing you can do with one is call these adapters/terminals. Transform closures operate on
// boxed `Json` items (a chunk is `UInt8[]`, a line is `String` тАФ both JSON-compatible), so map/
// filter take `(Json) => Json` / `(Json) => Boolean`.

// Source: open a file as a byte stream (`Stream<UInt8[]> | Error`). Return type inferred from the
// intrinsic (the opaque Stream type cannot drive a clean re-export annotation here).
export val readStream = (path: String) =>
  lin_fs_open(path)

// Adapters тАФ each returns a new Stream node; they are LAZY (no reads happen yet).
export val lines = (s: Stream): Stream =>
  lin_stream_lines(s)

export val chunks = (s: Stream, n: Int32): Stream =>
  lin_stream_chunks(s, n)

export val map = (s: Stream, f: Function): Stream =>
  lin_stream_map(s, f)

export val filter = (s: Stream, p: Function): Stream =>
  lin_stream_filter(s, p)

export val take = (s: Stream, n: Int32): Stream =>
  lin_stream_take(s, n)

// Sink: build a node that writes each item to `path`, one per line (lazy; nothing happens until
// a terminal driver runs it).
export val writeStream = (s: Stream, path: String): Stream =>
  lin_stream_write(s, path)

// Terminal drivers тАФ these consume the stream on the CALLING thread and close it afterwards.
// `drain` forces a sink (or any pipeline) to completion тЖТ `Null | Error`.
export val drain = (s: Stream): Json =>
  lin_stream_drain(s)

// `collect` pulls all bytes into a single `UInt8[]` тЖТ `UInt8[] | Error`.
export val collect = (s: Stream): Json =>
  lin_stream_collect(s)

// `readText` pulls all bytes into a single UTF-8 `String` тЖТ `String | Error`.
export val readText = (s: Stream): Json =>
  lin_stream_read_text(s)

// `close` releases the underlying resource explicitly (idempotent; the RC finalizer also closes
// a dropped stream, so this is for determinism).
export val close = (s: Stream): Null =>
  lin_stream_close(s)

// `for` consumes a Stream item-by-item on the calling thread тЖТ `Null | Error` (brief ┬з3): EOF
// ends the loop normally; the first read Error becomes the result. Typed against `Stream` (not
// the array `for`'s `Json`) so the Stream type reaches the IR lowerer's stream-`for` branch.
// Import this `for` (not std/array's) when consuming a stream: `stream.lines().for(println)`.
export val for = (s: Stream, f: Function): Json =>
  lin_for(s, f)

// `.promise()` тАФ drive the pipeline on a WORKER thread тЖТ `Promise<Null | Error>` (brief ┬з5).
// The stream is MOVED onto the worker (legal via CAP_MOVE, Stage 7): the worker owns the whole
// pipeline, drives it to EOF, and the result resolves to `Null` (success) or an `Error` (a
// read/transform fault is caught at the async boundary тАФ ADR-070 / ┬з32.2.2 тАФ and surfaces as the
// awaited `Error`). Real concurrency + fault isolation: run several with `parallel([...])`.
export val promise = (s: Stream): Json =>
  lin_stream_promise(s)
