// std/object — object introspection and transformation, plus Result/Option ergonomics.
//
//   import { keys, values, entries, fromEntries, get, merge, pick, omit, mapValues, isEmpty } from "std/object"
//
// `keys`/`values`/`entries` are tag-aware — they work on both a plain `{}`/`AnyVal` record and a typed
// index-signature map `{ String: T }`. `merge`/`pick`/`omit`/`mapValues` are generic over
// `{ String: T }` and return a typed map; pass them a value annotated `{ String: T }` (there is no
// implicit `AnyVal -> { String: T }` coercion). Over a typed map, key order is hash order, not insertion
// order. `get` is the idiomatic defaulted read (`m[k] ?? default`) — a bare `m[k]` already yields
// `T | Null`, so the helper folds in a fallback whose type `D` is independent of the value type `T`.
//
// This module also carries the Result/Option ergonomics folded in from the former std/result
// (error/isOk/isError/isNull/unwrapOr) — see the section lower in the file. Lin has no
// `Result`/`Option` wrapper type: a fallible call returns `T | Error`, an absence-y call returns
// `T | Null`, and the success value is the value with no unwrap ceremony on the happy path.
import foreign "lin-runtime"
  val lin_keys_any: (AnyVal) => String[]
  val lin_values_any: (AnyVal) => AnyVal[]
  val lin_entries_any: (AnyVal) => AnyVal[]

import { push, length } from "std/array"
import { for, some } from "std/iter"

// `keys`/`values`/`entries` are tag-aware at runtime, so one function serves both a record
// (`{}`/`{ String: T }`, insertion order) and an index-signature map (hash order). `keys` is generic
// over the key type `K`: its param `{ K: V } | {}` accepts a record literal, a typed map of ANY key
// type (`{ String: T }`, `{ UInt8: T }`, `{ DateNumber: T }`, …), or a `AnyVal` value — while
// REJECTING a non-object argument (`keys(1)`, `keys("s")`, `keys([…])` are compile errors).
//
// `keys` returns the keys in their NATIVE type `K[]` (ADR-086, revised): a `{ UInt8: V }` map yields
// a `UInt8[]` of integers (usable to re-index the map and in arithmetic), a `{ DateNumber: V }`
// (UInt32) map yields `UInt32[]`, and a `{ String: V }` map / plain record yields `String[]`. A
// `AnyVal` holding a non-object yields an empty result at runtime.
//
// Return the keys of an object or map.
// @param obj  a record, an index-signature map, or a `AnyVal` object.
// @returns a `K[]` of the keys in their native key type (insertion order for a record, hash order for a map).
// @example keys({ "a": 1, "b": 2 })   // ["a", "b"]
// @example { 3: "x", 10: "y" }.keys()   // [3, 10] : UInt8[]  (native integer keys)
export val keys = <K, V>(obj: { K: V }): K[] =>
  lin_keys(obj)

// Return the values of an object or map.
// @param obj  a record, an index-signature map, or a `AnyVal` object.
// @returns a `AnyVal[]` of the values, in key order.
// @example values({ "a": 1, "b": 2 })   // [1, 2]
export val values = (obj: { String: AnyVal } | {  }): AnyVal[] =>
  lin_values_any(obj)

// Return the key/value pairs of an object or map.
// @param obj  a record, an index-signature map, or a `AnyVal` object.
// @returns a `AnyVal[]` of `[key, value]` pairs, in key order.
// @example entries({ "a": 1, "b": 2 })   // [["a", 1], ["b", 2]]
export val entries = (obj: { String: AnyVal } | {  }): AnyVal[] =>
  lin_entries_any(obj)

// Iterate the key/value pairs of an object or map, calling `f` with each `[key, value]` pair.
// The callback-taking companion to the array-returning `entries` above — lets you write
// `obj.entries(([k, v]) => ...)` in dot-application style (like `for`/`map`).
// @param obj  a record, an index-signature map, or an `AnyVal` object.
// @param f    callback receiving each `[key, value]` pair.
// @example { "a": 1, "b": 2 }.entries(([k, v]) => print("${ k }=${ v }"))
export val entries = (obj: { String: AnyVal } | {  }, f: (AnyVal) => AnyVal): Null =>
  lin_entries_any(obj).for(f)

// Build an object from a list of `[key, value]` pairs (the inverse of `entries`). Later pairs with
// the same key overwrite earlier ones.
// @param pairs  an array of `[String, T]` pairs.
// @returns a `{ String: T }` map from each key to its value.
// @example fromEntries([["a", 1], ["b", 2]])   // { "a": 1, "b": 2 }
// @example entries(obj).map(([k, v]) => [k, v * 2]).fromEntries()   // double every value
export val fromEntries = <T>(pairs: [String, T][]): { String: T } =>
  var result: { String: T } = {}
  pairs.for(pair =>
    result[pair[0]] = pair[1]
  )
  result

// Merge two maps into a new one. Right-biased: keys present in `b` win over those in `a`.
// @param a  the base map.
// @param b  the overriding map; its entries take precedence on key collisions.
// @returns a new `{ String: T }` with the entries of both.
// @example a.merge(b)   // { "a": 1, "b": 99, "c": 3 }   (right-side values win on conflict)
export val merge = <T>(a: { String: T }, b: { String: T }): { String: T } =>
  // Built imperatively because a `{ ...a, ...b }` spread literal infers a fixed record `{ }`, not the
  // index-signature map type.
  var result: { String: T } = {}
  lin_keys_any(a).for(k =>
    result[k] = a[k]
  )
  lin_keys_any(b).for(k =>
    result[k] = b[k]
  )
  result

// Build a new map containing only the named keys that are present in `obj`.
// @param obj  the source map.
// @param ks   the keys to keep; keys absent from `obj` are skipped.
// @returns a new `{ String: T }` with just the selected present entries.
// @example m.pick(["a", "c"])   // { "a": 1, "c": 3 }
export val pick = <T>(obj: { String: T }, ks: String[]): { String: T } =>
  var result: { String: T } = {}
  ks.for(k =>
    val v = obj[k]
    if v != null then result[k] = v
  )
  result

// Build a new map with the named keys removed.
// @param obj  the source map.
// @param ks   the keys to drop.
// @returns a new `{ String: T }` with every entry of `obj` except those keyed in `ks`.
// @example m.omit(["b"])   // { "a": 1, "c": 3 }
export val omit = <T>(obj: { String: T }, ks: String[]): { String: T } =>
  val skip: { String: Boolean } = {}
  ks.for(k => skip[k] = true)
  val allKeys = lin_keys_any(obj)
  var result: { String: T } = {}
  allKeys.for(k =>
    if skip[k] == null then result[k] = obj[k]
  )
  result

// Transform every value of a map, keeping the keys unchanged.
// @param obj  the source map (value type `V`).
// @param f    `(value) => W` applied to each value.
// @returns a new `{ String: W }` with the same keys and mapped values.
// @example m.mapValues(v => v * 10)   // { "a": 10, "b": 20 } : { String: Int32 }
export val mapValues = <V, W>(obj: { String: V }, f: (V) => W): { String: W } =>
  val ks = lin_keys_any(obj)
  var result: { String: W } = {}
  ks.for(k =>
    result[k] = f(obj[k])
  )
  result

// Read the value at `key`, with a fallback when the key is absent. The default's type `D` is
// separate from the value type `T`, so the result is `T | D` and the default never pollutes `T`.
//   - `m.get(k)`        => `T | Null`
//   - `m.get(k, 0)`     => `T | Int32` (= `T` when `T = Int32`: the "definitely present" form)
//   - `m.get(k, "n/a")` => `T | String`
// @param m        the map to read from.
// @param key      the key to look up.
// @param default  value returned when `key` is absent; defaults to `null`, pinning `D`.
// @returns the value at `key`, or `default` (typed `T | D`) when the key is absent.
// @example counts.get("a", 0)        // 7
// @example counts.get("missing", 0)  // 0
// @example counts.get("z", "n/a")    // "n/a"   (independent default type -> Int32 | String)
export val get = <T, D>(m: { String: T }, key: String, default: D = null): T | D =>
  match m[key]
    is Null =>
      default
    else =>
      m[key]

// Test whether an object, map, array, or string is empty.
// @param x  any object, map, array, or string.
// @returns `true` iff `x` has zero entries/elements/characters.
// @example isEmpty({})        // true
// @example isEmpty([])        // true
// @example isEmpty({ "a": 1 })   // false
export val isEmpty = (x: AnyVal): Boolean =>
  length(x) == 0

// Result/Option ergonomics for the two fallible-value conventions: `T | Error` and `T | Null`.
//
// Lin has no `Result`/`Option` wrapper type. A fallible call returns `T | Error` (the canonical
// `Error` is `{ "type":"error","message":String }`, discriminated with `is Error`) and an absence-y
// call returns `T | Null`. The success value is the value — no unwrap ceremony on the happy path.
// This module adds small, total, side-effect-free helpers over those conventions: the `isOk` /
// `isError` / `isNull` predicates, the default-driven `unwrapOr` collapse, and the `error`
// constructor below.
//
// Construct the canonical Error value. Useful for fabricating an Error to feed a default arm, a
// test, or a hand-rolled fallible function.
// @param message  the human-readable error message.
// @returns the `Error` `{ "type": "error", "message": message }`, the exact value `is Error` discriminates on.
export val error = (message: String): Error =>
  { "type": "error", "message": message }

// Test whether `x` is the canonical Error — the `is Error` discriminant as a plain predicate, usable
// in `if`/`&&` positions and combinator callbacks (e.g. `xs.filter`).
// Note: this does not narrow the union — after `if isError(x)` the compiler still sees `x : T | Error`.
// Use the built-in `is Error` test to unlock the success arm's fields; this is for filtering/counting/branching.
// @param x  any value (typed `AnyVal`, the supertype any union flows into).
// @returns `true` iff `x` is the canonical Error.
export val isError = (x: AnyVal): Boolean =>
  match x
    is Error => true
    else => false

// Test whether `x` is not the canonical Error — the negation of `isError`. A `Null` `x` is "ok"
// here (it is not an Error); use `isNull` to test absence.
// @param x  any value (typed `AnyVal`).
// @returns `true` unless `x` is the canonical Error.
export val isOk = (x: AnyVal): Boolean =>
  match x
    is Error => false
    else => true

// Test whether `x` is the `Null` value (the absence arm of a `T | Null`).
// @param x  any value (typed `AnyVal`).
// @returns `true` iff `x` is `null`.
export val isNull = (x: AnyVal): Boolean =>
  match x
    is Null => true
    else => false

// Collapse the failure arm of a fallible value with a default. Handles both conventions: the
// success value is returned when `x` is neither an `Error` nor `Null`, otherwise `default`.
// @example val port: Int32 = parsePort(input).unwrapOr(8080)    // T | Error -> T
// @example val name: String = config["name"].unwrapOr("anon")   // T | Null  -> T
// @param x        any value (typed `AnyVal`, so any `T | Error` / `T | Null` union flows in).
// @param default  the fallback returned for the `Error`/`Null` arms; pins `D`.
// @returns the success value, or `default`, typed `AnyVal | D` (the static success type is recovered via `D`, as in `at`/`get`).
export val unwrapOr = <D>(x: AnyVal, default: D): AnyVal | D =>
  match x
    is Error => default
    is Null => default
    else => x
