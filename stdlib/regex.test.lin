import { expect, toBe, test, suite, run } from "std/test"
import { length } from "std/array"
import { map } from "std/iter"
import { trim } from "std/string"
import { compile, isMatch, find, findAll, replace, replaceAll, split, matches, Match } from "std/regex"

// Compile-once handles reused across tests below.
val word = compile("[a-z]+")
val digits = compile("^[0-9]+$")
val ws = compile("\\s+")

val s = suite("std/regex", [
  // ── compile ───────────────────────────────────────────────────────────────
  test("compile of a valid pattern is not an Error", () => [
    expect(compile("[0-9]{1,3}") is Error).toBe(false)
  ]),

  test("compile of an unbalanced group is an Error", () => [
    expect(compile("(unbalanced") is Error).toBe(true)
  ]),

  test("compile rejects backreferences (no backtracking engine)", () => [
    expect(compile("(\\w+)\\1") is Error).toBe(true)
  ]),

  test("compile rejects lookaround", () => [
    expect(compile("foo(?=bar)") is Error).toBe(true)
  ]),

  // ── isMatch ─────────────────────────────────────────────────────────────────
  test("isMatch true when pattern occurs", () => [
    expect(isMatch(word, "hello")).toBe(true)
  ]),

  test("isMatch dot-application form", () => [
    expect(digits.isMatch("12345")).toBe(true)
  ]),

  test("isMatch false on no match (anchored)", () => [
    expect(digits.isMatch("12a45")).toBe(false)
  ]),

  test("isMatch on empty string against anchored digits is false", () => [
    expect(isMatch(digits, "")).toBe(false)
  ]),

  test("loose email-ish anchored validator", () =>
    val email = compile("^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$")
    [
      expect(email.isMatch("ada@example.com")).toBe(true),
      expect(email.isMatch("not-an-email")).toBe(false),
      expect(email.isMatch("a@b.c d")).toBe(false)
    ]
  ),

  // ── find ──────────────────────────────────────────────────────────────────
  test("find returns the leftmost match with text and offsets", () =>
    val m = word.find("  hello world  ")
    [
      expect(m != null).toBe(true),
      expect(m["text"]).toBe("hello"),
      expect(m["start"]).toBe(2),
      expect(m["end"]).toBe(7)
    ]
  ),

  test("find returns Null when there is no match", () => [
    expect(word.find("12345") == null).toBe(true)
  ]),

  test("find groups[0] equals the whole match", () =>
    val pair = compile("([a-z]+)=([0-9]+)")
    val m = pair.find("x=10")
    [
      expect(m["groups"][0]).toBe("x=10"),
      expect(m["groups"][1]).toBe("x"),
      expect(m["groups"][2]).toBe("10")
    ]
  ),

  test("find: a non-participating positional group is a genuine Null hole", () =>
    // (a)|(b): exactly one of the two groups participates per match.
    val alt = compile("(a)|(b)")
    val m = alt.find("b")
    [
      expect(m["groups"][1] == null).toBe(true),
      expect(m["groups"][2]).toBe("b")
    ]
  ),

  test("find named captures via [\"named\"]", () =>
    val logLine = compile("(?P<ip>\\d+\\.\\d+\\.\\d+\\.\\d+) (?P<method>\\w+)")
    val m = logLine.find("127.0.0.1 GET")
    [
      expect(m["named"]["ip"]).toBe("127.0.0.1"),
      expect(m["named"]["method"]).toBe("GET"),
      expect(m["groups"][1]).toBe("127.0.0.1")
    ]
  ),

  test("find: an absent named group reads back as Null", () =>
    val re = compile("(?P<a>x)?y")
    val m = re.find("y")
    [
      expect(m["named"]["a"] == null).toBe(true)
    ]
  ),

  // ── codepoint offsets ───────────────────────────────────────────────────────
  test("offsets are codepoints, not bytes (accented)", () =>
    val cafe = compile("café")
    val m = cafe.find("a café here")
    [
      expect(m["start"]).toBe(2),
      expect(m["end"]).toBe(6),
      expect(m["text"]).toBe("café")
    ]
  ),

  test("offsets are codepoints across a multi-byte emoji prefix", () =>
    val endRe = compile("end")
    val m = endRe.find("🎉 the end")
    [
      // codepoints: 🎉(0) space(1) t(2)h(3)e(4) space(5) e(6)n(7)d(8) -> start 6, end 9
      expect(m["start"]).toBe(6),
      expect(m["end"]).toBe(9)
    ]
  ),

  // ── findAll ─────────────────────────────────────────────────────────────────
  test("findAll returns all non-overlapping matches left to right", () =>
    val num = compile("-?\\d+")
    val ms = num.findAll("a=1, b=-20, c=300")
    [
      expect(ms.length()).toBe(3),
      expect(ms.map((m: Match): String => m["text"])).toBe(["1", "-20", "300"])
    ]
  ),

  test("findAll returns an empty array when there are no matches", () => [
    expect(word.findAll("12345").length()).toBe(0)
  ]),

  test("findAll with named captures", () =>
    val pair = compile("(?P<k>\\w+)=(?P<v>[^&]+)")
    val ms = pair.findAll("a=1&b=two")
    [
      expect(ms.length()).toBe(2),
      expect(ms.map((m: Match): String => m["named"]["k"])).toBe(["a", "b"]),
      expect(ms.map((m: Match): String => m["named"]["v"])).toBe(["1", "two"])
    ]
  ),

  // ── replace / replaceAll ──────────────────────────────────────────────────
  test("replace collapses only the first match", () => [
    expect(ws.replace("a   b   c", "_")).toBe("a_b   c")
  ]),

  test("replace returns the string unchanged when there is no match", () => [
    expect(ws.replace("abc", "_")).toBe("abc")
  ]),

  test("replaceAll collapses every match", () => [
    expect(replaceAll(ws, "  hello   world  ", " ").trim()).toBe("hello world")
  ]),

  test("replaceAll with named-group substitution", () =>
    val date = compile("(?P<y>\\d{4})-(?P<m>\\d{2})-(?P<d>\\d{2})")
    [
      // `\${` escapes Lin's string interpolation so the literal `${name}` reaches the regex
      // replacer (which interprets `${name}` as a named-group reference).
      expect(date.replaceAll("2026-06-07", "\${d}/\${m}/\${y}")).toBe("07/06/2026")
    ]
  ),

  test("replaceAll with positional-group substitution", () =>
    val date = compile("(\\d{4})-(\\d{2})-(\\d{2})")
    [
      expect(date.replaceAll("2026-06-07", "$3/$2/$1")).toBe("07/06/2026")
    ]
  ),

  test("replaceAll swapping two captures", () =>
    val at = compile("(\\w+)@(\\w+)")
    [
      expect(at.replaceAll("a@b and c@d", "$2.$1")).toBe("b.a and d.c")
    ]
  ),

  test("replaceAll: $$ inserts a literal dollar sign", () => [
    expect(compile("x").replaceAll("axb", "$$")).toBe("a$b")
  ]),

  // ── split ────────────────────────────────────────────────────────────────
  test("split on a whitespace pattern", () => [
    expect(ws.split("the   quick\tbrown\nfox")).toBe(["the", "quick", "brown", "fox"])
  ]),

  test("split keeps empty pieces between consecutive matches", () => [
    expect(compile(",").split("a,b,,c")).toBe(["a", "b", "", "c"])
  ]),

  test("split returns [s] when the pattern never matches", () => [
    expect(compile("x").split("hello")).toBe(["hello"])
  ]),

  test("split with leading/trailing matches yields empty edges", () => [
    expect(compile(",").split(",a,")).toBe(["", "a", ""])
  ]),

  // ── matches (convenience) ──────────────────────────────────────────────────
  test("matches compiles and tests in one call", () => [
    expect(matches("^\\d+$", "42")).toBe(true)
  ]),

  test("matches returns false for a non-match", () => [
    expect(matches("^\\d+$", "4x2")).toBe(false)
  ]),

  test("matches propagates a compile Error for an invalid pattern", () => [
    expect(matches("(bad", "42") is Error).toBe(true)
  ])
])

run(s)
