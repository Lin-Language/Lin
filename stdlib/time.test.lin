import { expect, toBe, test, suite, run } from "std/test"
import { now, sleep, sleepMicros, startTimer, elapsed, toIso, format, fromIso, parse } from "std/time"
import { components, fromComponents, year, month, day, hour, minute, second, weekday, dayOfYear } from "std/time"
import { addDays, addHours, addMinutes, addSeconds, addMonths, addYears, diff, diffDays } from "std/time"
import { seconds, minutes, hours, days, formatDuration, componentsAt, formatAt } from "std/time"

val s = suite("std/time", [
  test("now returns a positive timestamp", () => [
    expect(now() > 0).toBe(true)
  ]),

  test("startTimer returns a positive value", () => [
    expect(startTimer() > 0).toBe(true)
  ]),

  test("elapsed is non-negative", () =>
    val t = startTimer()
    [
      expect(t.elapsed() >= 0).toBe(true)
    ]
  ),

  test("toIso of Unix epoch", () => [
    expect(toIso(0)).toBe("1970-01-01T00:00:00.000Z")
  ]),

  test("toIso of a known timestamp", () => [
    expect(toIso(1000)).toBe("1970-01-01T00:00:01.000Z")
  ]),

  test("toIso includes milliseconds", () => [
    expect(toIso(1500)).toBe("1970-01-01T00:00:01.500Z")
  ]),

  test("sleepMicros runs and elapsed stays non-negative", () =>
    val t = startTimer()
    sleepMicros(500)
    [
      expect(t.elapsed() >= 0).toBe(true)
    ]
  ),

  // --- format (strftime-style, UTC) ---
  test("format renders date and time fields", () => [
    expect(format(1705314600000, "%Y-%m-%dT%H:%M:%S")).toBe("2024-01-15T10:30:00"),
    expect(format(1705314600000, "%Y-%m-%d")).toBe("2024-01-15"),
    expect(format(1705314600000, "%H:%M:%S")).toBe("10:30:00")
  ]),

  test("format renders weekday/month names and literal percent", () => [
    expect(format(1705314600000, "%a %B %d")).toBe("Mon January 15"),
    expect(format(1705314600000, "%H%%")).toBe("10%")
  ]),

  // --- fromIso ---
  // NOTE: expected timestamps are bound as `Int64` vals; a bare >Int32 literal in
  // `toBe(...)` would default to Int32 and truncate (a separate literal-typing issue).
  test("fromIso parses a UTC datetime", () =>
    val expected: Int64 = 1705314600000
    [expect(fromIso("2024-01-15T10:30:00Z")).toBe(expected)]
  ),

  test("fromIso parses a bare date as UTC midnight", () =>
    val expected: Int64 = 1705276800000
    [expect(fromIso("2024-01-15")).toBe(expected)]
  ),

  test("fromIso respects a timezone offset", () => [
    expect(fromIso("2024-01-15T10:30:00+01:00")).toBe(fromIso("2024-01-15T09:30:00Z"))
  ]),

  test("fromIso returns an Error on garbage", () =>
    val r = fromIso("not a date")
    [expect(r["type"]).toBe("error")]
  ),

  // --- parse (strftime-style pattern) ---
  test("parse reads a pattern into a timestamp", () =>
    val midnight: Int64 = 1705276800000
    val withTime: Int64 = 1705314600000
    [
      expect(parse("2024-01-15", "%Y-%m-%d")).toBe(midnight),
      expect(parse("15/01/2024 10:30", "%d/%m/%Y %H:%M")).toBe(withTime)
    ]
  ),

  test("parse returns an Error on mismatch", () =>
    val r = parse("bad", "%Y-%m-%d")
    [expect(r["type"]).toBe("error")]
  ),

  // format and parse round-trip
  test("format and parse round-trip a timestamp", () =>
    val ts: Int64 = 1705314600000
    [
      expect(parse(format(ts, "%Y-%m-%dT%H:%M:%S"), "%Y-%m-%dT%H:%M:%S")).toBe(ts)
    ]
  ),

  // === components ===
  test("components decomposes the epoch", () =>
    val c = components(0)
    [
      expect(c["year"]).toBe(1970),
      expect(c["month"]).toBe(1),
      expect(c["day"]).toBe(1),
      expect(c["hour"]).toBe(0),
      expect(c["minute"]).toBe(0),
      expect(c["second"]).toBe(0),
      expect(c["millis"]).toBe(0),
      expect(c["weekday"]).toBe(4),
      expect(c["yearDay"]).toBe(1)
    ]
  ),

  test("components decomposes a known datetime (with weekday/yearDay)", () =>
    val ts: Int64 = 1705314600000
    val c = components(ts)
    [
      expect(c["year"]).toBe(2024),
      expect(c["month"]).toBe(1),
      expect(c["day"]).toBe(15),
      expect(c["hour"]).toBe(10),
      expect(c["minute"]).toBe(30),
      expect(c["weekday"]).toBe(1),
      expect(c["yearDay"]).toBe(15)
    ]
  ),

  test("components handles millis and pre-1970 negative timestamps", () =>
    val c = components(1500)
    val neg = components(-1)
    [
      expect(c["second"]).toBe(1),
      expect(c["millis"]).toBe(500),
      // -1 ms == 1969-12-31T23:59:59.999Z (floor decomposition)
      expect(neg["year"]).toBe(1969),
      expect(neg["month"]).toBe(12),
      expect(neg["day"]).toBe(31),
      expect(neg["hour"]).toBe(23),
      expect(neg["minute"]).toBe(59),
      expect(neg["second"]).toBe(59),
      expect(neg["millis"]).toBe(999)
    ]
  ),

  // === fromComponents ===
  test("fromComponents builds a UTC timestamp", () =>
    val expected: Int64 = 1705314600000
    [
      expect(fromComponents({
        "year": 2024,
        "month": 1,
        "day": 15,
        "hour": 10,
        "minute": 30,
        "second": 0,
        "millis": 0
      })).toBe(expected)
    ]
  ),

  test("fromComponents accepts a leap-day (Feb 29 2024)", () =>
    val expected: Int64 = 1709164800000
    [
      expect(fromComponents({
        "year": 2024,
        "month": 2,
        "day": 29,
        "hour": 0,
        "minute": 0,
        "second": 0,
        "millis": 0
      })).toBe(expected)
    ]
  ),

  test("fromComponents rejects Feb 29 in a non-leap year", () =>
    val r = fromComponents({
      "year": 2023,
      "month": 2,
      "day": 29,
      "hour": 0,
      "minute": 0,
      "second": 0,
      "millis": 0
    })
    [expect(r["type"]).toBe("error")]
  ),

  test("fromComponents rejects an out-of-range month", () =>
    val r = fromComponents({
      "year": 2024,
      "month": 13,
      "day": 1,
      "hour": 0,
      "minute": 0,
      "second": 0,
      "millis": 0
    })
    [expect(r["type"]).toBe("error")]
  ),

  test("fromComponents rejects an out-of-range hour/minute/second/millis", () => [
    expect(fromComponents({
      "year": 2024,
      "month": 1,
      "day": 1,
      "hour": 24,
      "minute": 0,
      "second": 0,
      "millis": 0
    })["type"]).toBe("error"),
    expect(fromComponents({
      "year": 2024,
      "month": 1,
      "day": 1,
      "hour": 0,
      "minute": 60,
      "second": 0,
      "millis": 0
    })["type"]).toBe("error"),
    expect(fromComponents({
      "year": 2024,
      "month": 1,
      "day": 1,
      "hour": 0,
      "minute": 0,
      "second": 60,
      "millis": 0
    })["type"]).toBe("error"),
    expect(fromComponents({
      "year": 2024,
      "month": 1,
      "day": 1,
      "hour": 0,
      "minute": 0,
      "second": 0,
      "millis": 1000
    })["type"]).toBe("error")
  ]),

  // === round-trip corpus: fromComponents(components(ts)) == ts ===
  // The real guard for the civil-date math. Includes pre-1970/negative, leap-year
  // Feb 29 (in and out), and year boundaries. Each `val` pins Int64 (a bare literal
  // would default to Int32 and truncate).
  test("components round-trips at the epoch", () =>
    val ts: Int64 = 0
    [expect(fromComponents(components(ts))).toBe(ts)]
  ),

  test("components round-trips a known datetime", () =>
    val ts: Int64 = 1705314600000
    [expect(fromComponents(components(ts))).toBe(ts)]
  ),

  test("components round-trips a negative (pre-1970) timestamp", () =>
    val ts: Int64 = -1
    val ts2: Int64 = -86400000
    val ts3: Int64 = -100000000000
    [
      expect(fromComponents(components(ts))).toBe(ts),
      expect(fromComponents(components(ts2))).toBe(ts2),
      expect(fromComponents(components(ts3))).toBe(ts3)
    ]
  ),

  test("components round-trips leap-day boundaries (Feb 29 2024)", () =>
    val start: Int64 = 1709164800000
    val end: Int64 = 1709251199999
    [
      expect(fromComponents(components(start))).toBe(start),
      expect(fromComponents(components(end))).toBe(end)
    ]
  ),

  test("components round-trips a year 2000 leap day and year boundaries", () =>
    val leap2000: Int64 = 951782400000
    val dec31: Int64 = 1704067199999
    val jan01: Int64 = 1704067200000
    [
      expect(fromComponents(components(leap2000))).toBe(leap2000),
      expect(fromComponents(components(dec31))).toBe(dec31),
      expect(fromComponents(components(jan01))).toBe(jan01)
    ]
  ),

  // === single-field extractors ===
  test("single-field extractors agree with components", () =>
    val ts: Int64 = 1705314600000
    [
      expect(year(ts)).toBe(2024),
      expect(month(ts)).toBe(1),
      expect(day(ts)).toBe(15),
      expect(hour(ts)).toBe(10),
      expect(minute(ts)).toBe(30),
      expect(second(ts)).toBe(0),
      expect(weekday(ts)).toBe(1),
      expect(dayOfYear(ts)).toBe(15)
    ]
  ),

  // === addDays / addHours / addMinutes / addSeconds ===
  test("addDays/addHours/addMinutes/addSeconds are exact offsets", () =>
    val day1: Int64 = 86400000
    val negHour: Int64 = -3600000
    [
      expect(addDays(0, 1)).toBe(day1),
      expect(addHours(0, -1)).toBe(negHour),
      expect(addMinutes(0, 1)).toBe(60000),
      expect(addSeconds(0, 1)).toBe(1000),
      // dot-application form
      expect(0.addDays(2)).toBe(172800000)
    ]
  ),

  // === addMonths clamping ===
  test("addMonths clamps Jan 31 + 1mo to Feb 28 (non-leap 2023)", () =>
    val jan31: Int64 = 1675123200000
    val feb28: Int64 = 1677542400000
    [expect(addMonths(jan31, 1)).toBe(feb28)]
  ),

  test("addMonths clamps Jan 31 + 1mo to Feb 29 in leap 2024", () =>
    val jan31: Int64 = 1706659200000
    val feb29: Int64 = 1709164800000
    [expect(addMonths(jan31, 1)).toBe(feb29)]
  ),

  test("addMonths handles negative n with clamping (Mar 31 - 1mo)", () =>
    val mar31: Int64 = 1711843200000
    val feb29: Int64 = 1709164800000
    [expect(addMonths(mar31, -1)).toBe(feb29)]
  ),

  test("addMonths preserves time-of-day and crosses a year boundary", () =>
    // 2023-11-15T10:30:00Z + 3 months -> 2024-02-15T10:30:00Z
    val nov: Int64 = 1700044200000
    val feb: Int64 = 1707993000000
    [expect(addMonths(nov, 3)).toBe(feb)]
  ),

  // === addYears ===
  test("addYears clamps Feb 29 + 1yr to Feb 28 in a non-leap year", () =>
    val feb29: Int64 = 1709164800000
    val feb28: Int64 = 1740700800000
    [expect(addYears(feb29, 1)).toBe(feb28)]
  ),

  // === diff / diffDays ===
  test("diff is the signed millisecond difference", () => [
    expect(diff(0, 90000)).toBe(90000),
    expect(diff(90000, 0)).toBe(-90000)
  ]),

  test("diffDays counts civil date boundaries crossed", () =>
    val jan15: Int64 = 1705276800000
    val jan20: Int64 = 1705708800000
    // 23:00 -> next 01:00 is one calendar day even though 2h elapsed
    val late: Int64 = 1705359600000
    val early: Int64 = 1705366800000
    [
      expect(diffDays(jan15, jan20)).toBe(5),
      expect(diffDays(jan20, jan15)).toBe(-5),
      expect(diffDays(late, early)).toBe(1)
    ]
  ),

  // === duration constructors ===
  test("duration constructors scale to milliseconds and compose", () => [
    expect(seconds(2)).toBe(2000),
    expect(minutes(1)).toBe(60000),
    expect(hours(1)).toBe(3600000),
    expect(days(1)).toBe(86400000),
    expect(hours(1) + minutes(30)).toBe(5400000),
    expect(minutes(-5)).toBe(-300000)
  ]),

  // === formatDuration ===
  test("formatDuration renders compact human strings", () => [
    expect(formatDuration(0)).toBe("0ms"),
    expect(formatDuration(1500)).toBe("1s 500ms"),
    expect(formatDuration(5400000)).toBe("1h 30m"),
    expect(formatDuration(90061000)).toBe("1d 1h 1m 1s"),
    expect(formatDuration(-3600000)).toBe("-1h"),
    expect(formatDuration(999)).toBe("999ms")
  ]),

  // === componentsAt / formatAt ===
  test("componentsAt applies a fixed UTC offset", () =>
    val ts: Int64 = 1705314600000
    // 2024-01-15T10:30:00Z viewed at UTC-5 == 05:30 local
    val c = componentsAt(ts, -300)
    [
      expect(c["hour"]).toBe(5),
      expect(c["minute"]).toBe(30),
      expect(c["day"]).toBe(15)
    ]
  ),

  test("formatAt renders at a fixed offset; offset 0 matches format", () =>
    val ts: Int64 = 1705314600000
    [
      expect(formatAt(ts, "%Y-%m-%d %H:%M", 330)).toBe("2024-01-15 16:00"),
      expect(formatAt(ts, "%H:%M", 0)).toBe(format(ts, "%H:%M"))
    ]
  )
])

run(s)
