import { expect, toBe, test, suite, run } from "std/test"
import { udpBind, udpRecv, udpRecvFrom, udpSendTo, udpSetNonblocking, udpClose, tcpListen, tcpAccept, tcpConnect, tcpRecv, tcpSend, tcpSetNonblocking, tcpClose } from "std/net"
import { sleep } from "std/time"

// std/net: UDP loopback on a single thread is deterministic — send to self on
// 127.0.0.1, then a blocking recv returns the buffered datagram. The TCP
// round-trip is single-threaded on loopback, but NOT instantaneous:
//   - a non-blocking listener's accept() returns Null (would-block) until a
//     connection is pending, and never blocks;
//   - connect() to a listening loopback socket queues onto the listen backlog,
//     but the 3-way handshake is completed asynchronously by the kernel — on
//     Linux it is typically done by the time the next accept() runs, but on
//     macOS (BSD socket stack) the connection often is not yet pending, so a
//     single non-blocking accept() returns Null. This is the macOS CI flake.
//     `acceptWithRetry` therefore polls accept() with a short sleep until the
//     connection lands (bounded, so it can never hang);
//   - data written with send() is buffered in the kernel and is available to a
//     recv() on the peer fd straight away on loopback.
// High ports are used to avoid privileged-port and collision issues. Nothing
// here can block indefinitely: the listener is non-blocking, accept is bounded,
// and recv only runs after a successful send has buffered the bytes on loopback.
// Poll a non-blocking listener until accept() yields a connection (or the retry
// budget is exhausted). Forward-declared at module scope so the self-recursion
// type-checks (a function-valued `val` is pre-scanned; ADR-012).
val acceptWithRetry = (lis: Json, tries: Int32): Json =>
  val acc = tcpAccept(lis)
  if acc == null && tries > 0 then
    sleep(2)
    acceptWithRetry(lis, tries - 1)
  else
    acc
val s = suite("std/net", [
  test("udpBind returns a non-error fd handle", () =>
    val sock = udpBind(39301)
    val ok = sock["type"] != "error"
    udpClose(sock)
    [
      expect(ok).toBe(true)
    ]
  ),

  test("non-blocking udpRecv with no data returns Null", () =>
    val sock = udpBind(39302)
    udpSetNonblocking(sock, true)
    val empty: UInt8[] = [0, 0, 0, 0]
    val r = udpRecv(sock, empty)
    udpClose(sock)
    [
      expect(r == null).toBe(true)
    ]
  ),

  test("UDP loopback send-to-self round-trips bytes", () =>
    val sock = udpBind(39303)
    val msg: UInt8[] = [72, 105, 33]
    val sent = udpSendTo(sock, "127.0.0.1", 39303, msg)
    val buf: UInt8[] = [
      0,
      0,
      0,
      0,
      0,
      0,
      0,
      0
    ]
    val res = udpRecvFrom(sock, buf)
    udpClose(sock)
    [
      expect(sent).toBe(3),
      expect(res["len"]).toBe(3),
      expect(res["addr"]).toBe("127.0.0.1"),
      expect(buf[0]).toBe(72),
      expect(buf[1]).toBe(105),
      expect(buf[2]).toBe(33)
    ]
  ),

  test("tcpListen returns a non-error fd handle", () =>
    val lis = tcpListen(39401)
    val ok = lis["type"] != "error"
    tcpClose(lis)
    [
      expect(ok).toBe(true)
    ]
  ),

  test("non-blocking tcpAccept with no pending connection returns Null", () =>
    val lis = tcpListen(39402)
    tcpSetNonblocking(lis, true)
    val acc = tcpAccept(lis)
    tcpClose(lis)
    [
      expect(acc == null).toBe(true)
    ]
  ),

  test("TCP loopback connect/accept/send/recv round-trips bytes", () =>
    val lis = tcpListen(39403)
    tcpSetNonblocking(lis, true)
    val cli = tcpConnect("127.0.0.1", 39403)
    val connectOk = cli["type"] != "error"
    val acc = acceptWithRetry(lis, 50)
    val srvFd = acc["fd"]
    val msg: UInt8[] = [65, 66, 67]
    val sent = tcpSend(cli, msg)
    val buf: UInt8[] = [
      0,
      0,
      0,
      0
    ]
    val got = tcpRecv(srvFd, buf)
    tcpClose(cli)
    tcpClose(srvFd)
    tcpClose(lis)
    [
      expect(connectOk).toBe(true),
      expect(acc["addr"]).toBe("127.0.0.1"),
      expect(sent).toBe(3),
      expect(got).toBe(3),
      expect(buf[0]).toBe(65),
      expect(buf[1]).toBe(66),
      expect(buf[2]).toBe(67)
    ]
  )
])

run(s)
