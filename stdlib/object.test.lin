import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { keys, values, entries, fromEntries, merge, pick, omit, mapValues, isEmpty, get } from "std/object"
import { length } from "std/array"
import { range, for } from "std/iter"
import { error, isOk, isError, isNull, unwrapOr } from "std/object"
import { filter } from "std/iter"

val s = suite("std/object", [
  test("keys returns object keys", () =>
    val k = { "a": 1, "b": 2 }.keys()
    [
      expect(k.length()).toBe(2)
    ]
  ),

  // `keys` over a plain `{}`/`AnyVal` record preserves insertion order (TAG_OBJECT). Over a typed
  // `{ String: T }` map it is hash order — that distinction is covered in the typed-map section.
  test("keys order is insertion order", () =>
    val k = { "x": 1, "y": 2 }.keys()
    [
      expect(k[0]).toBe("x")
    ]
  ),

  test("values returns object values", () =>
    val obj = { "a": 10, "b": 20 }
    val v = obj.values()
    [
      expect(v.length()).toBe(2)
    ]
  ),

  test("entries returns key-value pairs", () =>
    val obj = { "a": 1 }
    val e = obj.entries()
    [
      expect(e[0][0]).toBe("a")
    ]
  ),

  // ADR-086: keys/values/entries accept a map with a non-String key type and return the keys
  // STRINGIFIED (a `{ UInt8: V }` map's int key 3 reads back as "3").
  test("keys over an int-keyed map are stringified", () =>
    var m: { UInt8: String } = {}
    m[3] = "three"
    m[10] = "ten"
    val k = m.keys()
    val v = m.values()
    val e = m.entries()
    [
      expect(k.length()).toBe(2),
      expect(k[0]).toBe("3"),
      expect(k[1]).toBe("10"),
      expect(v[0]).toBe("three"),
      expect(e[0][0]).toBe("3")
    ]
  ),

  test("missing key returns null", () =>
    val obj = { "a": 1 }
    [
      expect(obj["missing"]).toBe(null)
    ]
  ),

  test("spread merges objects", () =>
    val a = { "x": 1 }
    val b = { ...a, "y": 2 }
    [
      expect(b["x"]).toBe(1)
    ]
  ),

  test("spread override takes last value", () =>
    val a = { "x": 1 }
    val b = { ...a, "x": 99 }
    [
      expect(b["x"]).toBe(99)
    ]
  ),

  test("fromEntries builds object from pairs", () =>
    val obj = fromEntries([["a", 1], ["b", 2]])
    [
      expect(obj["a"]).toBe(1)
    ]
  ),

  test("fromEntries second value is correct", () =>
    val obj = fromEntries([["a", 1], ["b", 2]])
    [
      expect(obj["b"]).toBe(2)
    ]
  ),

  test("fromEntries empty array produces empty object", () =>
    val obj = fromEntries([])
    [
      expect(obj.keys().length()).toBe(0)
    ]
  ),

  test("merge combines two objects", () =>
    val a: { String: Int32 } = { "a": 1, "b": 2 }
    val b: { String: Int32 } = { "c": 3 }
    val merged = a.merge(b)
    [
      expect(merged["a"]).toBe(1)
    ]
  ),

  test("merge right wins on conflict", () =>
    val a: { String: Int32 } = { "a": 1, "b": 2 }
    val b: { String: Int32 } = { "b": 3, "c": 4 }
    val merged = a.merge(b)
    [
      expect(merged["b"]).toBe(3)
    ]
  ),

  test("merge includes all keys", () =>
    val a: { String: Int32 } = { "a": 1 }
    val b: { String: Int32 } = { "b": 2 }
    val merged = a.merge(b)
    [
      expect(merged.keys().length()).toBe(2)
    ]
  ),

  test("pick returns only specified keys", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val p = obj.pick(["a", "c"])
    [
      expect(p.keys().length()).toBe(2)
    ]
  ),

  test("pick includes correct values", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val p = obj.pick(["a", "c"])
    [
      expect(p["a"]).toBe(1)
    ]
  ),

  test("pick second included value is correct", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val p = obj.pick(["a", "c"])
    [
      expect(p["c"]).toBe(3)
    ]
  ),

  test("pick excludes unspecified keys", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val p = obj.pick(["a", "c"])
    [
      expect(p["b"]).toBe(null)
    ]
  ),

  test("omit returns object without specified keys", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val o = obj.omit(["b"])
    [
      expect(o.keys().length()).toBe(2)
    ]
  ),

  test("omit excluded key is absent", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val o = obj.omit(["b"])
    [
      expect(o["b"]).toBe(null)
    ]
  ),

  test("omit keeps remaining keys", () =>
    val obj: { String: Int32 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    val o = obj.omit(["b"])
    [
      expect(o["a"]).toBe(1)
    ]
  ),

  test("mapValues transforms all values", () =>
    val obj: { String: Int32 } = { "a": 1, "b": 2 }
    val m = obj.mapValues(x => x * 2)
    [
      expect(m["a"]).toBe(2)
    ]
  ),

  test("mapValues second value is transformed", () =>
    val obj: { String: Int32 } = { "a": 1, "b": 2 }
    val m = obj.mapValues(x => x * 2)
    [
      expect(m["b"]).toBe(4)
    ]
  ),

  test("mapValues preserves all keys", () =>
    val obj: { String: Int32 } = { "a": 1, "b": 2 }
    val m = obj.mapValues(x => x * 2)
    [
      expect(m.keys().length()).toBe(2)
    ]
  ),

  test("isEmpty returns true for empty object", () => [
    expect(isEmpty({  })).toBe(true)
  ]),

  test("isEmpty returns true for empty array", () => [
    expect(isEmpty([])).toBe(true)
  ]),

  test("isEmpty returns true for empty string", () => [
    expect(isEmpty("")).toBe(true)
  ]),

  test("isEmpty returns false for non-empty object", () => [
    expect(isEmpty({ "a": 1 })).toBe(false)
  ]),

  test("isEmpty returns false for non-empty array", () => [
    expect(isEmpty([1])).toBe(false)
  ]),

  test("isEmpty returns false for non-empty string", () => [
    expect(isEmpty("hi")).toBe(false)
  ]),

  // --- heap/union value coverage for object index-assign (`result[k] = v`) ---
  // String values exercise the object-set store's retain semantics; scalar values
  // hide RC bugs. The ASan CI leg also runs these.
  test("mapValues producing string values", () =>
    val obj: { String: Int32 } = { "a": 1, "b": 2 }
    val m = obj.mapValues(v => "v${v}")
    [
      expect(m["a"]).toBe("v1"),
      expect(m["b"]).toBe("v2")
    ]
  ),

  test("pick copies string values", () =>
    val obj: { String: String } = {
      "a": "x",
      "b": "y",
      "c": "z"
    }
    val p = obj.pick(["a", "c"])
    [
      expect(p["a"]).toBe("x"),
      expect(p["c"]).toBe("z"),
      expect(p["b"]).toBe(null)
    ]
  ),

  test("omit copies remaining string values", () =>
    val obj: { String: String } = {
      "a": "x",
      "b": "y",
      "c": "z"
    }
    val o = obj.omit(["b"])
    [
      expect(o["a"]).toBe("x"),
      expect(o["c"]).toBe("z"),
      expect(o["b"]).toBe(null)
    ]
  ),

  test("fromEntries with string values", () =>
    val r = fromEntries([["a", "x"], ["b", "y"]])
    [
      expect(r["a"]).toBe("x"),
      expect(r["b"]).toBe("y")
    ]
  ),

  // --- typed index-signature map `{ String: T }` (ADR-055) ---
  // The hashed LinMap backing: O(1) lookup, T-typed values, missing key -> Null.
  test("typed map: insert and lookup", () =>
    var counts: { String: Int32 } = {}
    counts["apple"] = 3
    counts["banana"] = 7
    [
      expect(counts["apple"]).toBe(3),
      expect(counts["banana"]).toBe(7),
      expect(counts["missing"]).toBe(null)
    ]
  ),

  test("typed map: overwrite a key", () =>
    var m: { String: Int32 } = {}
    m["k"] = 1
    m["k"] = 42
    [
      expect(m["k"]).toBe(42)
    ]
  ),

  test("typed map: keys/values flow over a map", () =>
    var m: { String: Int32 } = {}
    m["a"] = 1
    m["b"] = 2
    m["c"] = 3
    [
      expect(m.keys().length()).toBe(3),
      expect(m.values().length()).toBe(3)
    ]
  ),

  test("typed map: string values (heap RC)", () =>
    var m: { String: String } = {}
    m["greeting"] = "hello"
    m["name"] = "world"
    [
      expect(m["greeting"]).toBe("hello"),
      expect(m["name"]).toBe("world")
    ]
  ),

  test("typed map: empty map isEmpty", () =>
    var m: { String: Int32 } = {}
    [
      expect(isEmpty(m)).toBe(true)
    ]
  ),

  test("typed map: many distinct keys (forces grow)", () =>
    var m: { String: Int32 } = {}
    range(0, 100).for(i =>
      m["k${toString(i)}"] = i
    )
    [
      expect(m.keys().length()).toBe(100),
      expect(m["k0"]).toBe(0),
      expect(m["k99"]).toBe(99),
      expect(m["k50"]).toBe(50)
    ]
  ),

  // --- flat-scalar UNBOXED values (ADR-055 follow-up) ---
  // A flat-scalar `T` stores the value unboxed inline in the slot (no per-value heap box).
  test("typed map: Int64 flat-scalar value reads back T-correct", () =>
    var m: { String: Int64 } = {}
    m["a"] = 100i64
    m["b"] = 200i64
    m["a"] = 111i64
    [
      expect(m["a"]).toBe(111i64),
      expect(m["b"]).toBe(200i64),
      expect(m["missing"]).toBe(null),
      expect(m.values().length()).toBe(2),
      expect(m.entries().length()).toBe(2)
    ]
  ),

  test("typed map: Int32 source widens into a { String: Int64 } map", () =>
    // A narrower Int32 value stored into an Int64 map must read back as Int64-correct (the store
    // widens to T before storing) — not the source's narrower tag.
    var m: { String: Int64 } = {}
    range(0, 50).for(i => m["k${toString(i)}"] = i)
    var sum = 0i64
    range(0, 50).for(i =>
      val v = m["k${toString(i)}"]
      match v
        is Int64 => sum = sum + v
        else => sum = sum
    )
    [
      // sum_{i=0..49} i = 49*50/2 = 1225 (would be 0 if the tag were wrong)
      expect(sum).toBe(1225i64)
    ]
  ),

  test("typed map: Float64 flat-scalar value", () =>
    var m: { String: Float64 } = {}
    m["x"] = 1.5
    m["y"] = 2.25
    [
      expect(m["x"]).toBe(1.5),
      expect(m["y"]).toBe(2.25)
    ]
  ),

  test("typed map: flat-scalar map literal", () =>
    val m: { String: Int64 } = {
      "a": 1,
      "b": 2,
      "c": 3
    }
    [
      expect(m["a"]).toBe(1i64),
      expect(m["c"]).toBe(3i64),
      expect(m["z"]).toBe(null),
      expect(m.values().length()).toBe(3)
    ]
  ),

  // The re-typed map-producing ops thread the element type through: `mapValues` over a
  // `{ String: Int32 }` returns a `{ String: W }` (here `W = Int32`) — a genuinely typed map whose
  // values read back at the mapped type, not an opaque `AnyVal`. The `: { String: Int32 }` annotation
  // on `doubled` only type-checks because the result really is that map type.
  test("typed map: mapValues yields a typed { String: W } result", () =>
    var src: { String: Int32 } = {}
    src["a"] = 1
    src["b"] = 2
    val doubled: { String: Int32 } = src.mapValues(v => v * 2)
    [
      expect(doubled["a"]).toBe(2),
      expect(doubled["b"]).toBe(4)
    ]
  ),

  // --- get: defaulted read (`m[k] ?? default`) ---
  test("get returns the value when the key is present", () =>
    var m: { String: Int32 } = {}
    m["a"] = 7
    [
      expect(m.get("a", 0)).toBe(7)
    ]
  ),

  test("get returns the default when the key is absent", () =>
    var m: { String: Int32 } = {}
    m["a"] = 7
    [
      expect(m.get("missing", 99)).toBe(99)
    ]
  ),

  test("get returns string values and defaults", () =>
    var m: { String: String } = {}
    m["k"] = "hi"
    [
      expect(m.get("k", "x")).toBe("hi"),
      expect(m.get("z", "fallback")).toBe("fallback")
    ]
  ),

  // The default's type `D` is INDEPENDENT of the value type `T`: the result is `T | D`. With a
  // matching default (`D = T`, here both Int32) over a known-Int32 map the union collapses, so a
  // `get(k, 0)` result is usable as a bare `Int32` (annotated, then composed in arithmetic).
  test("get returns a definitely-present value usable in arithmetic", () =>
    var m: { String: Int32 } = {}
    m["a"] = 7
    val present: Int32 = m.get("a", 0)
    val fallback: Int32 = m.get("missing", 5)
    val total: Int32 = present + fallback
    [
      expect(total).toBe(12)
    ]
  ),

  // An independent default type `D` ≠ value type `T`: `get(k, "n/a")` over an Int32 map is
  // `Int32 | String` — the default never pollutes `T`.
  test("get default has an independent type D (T | D)", () =>
    var m: { String: Int32 } = {}
    m["a"] = 7
    val present: Int32 | String = m.get("a", "n/a")
    val fallback: Int32 | String = m.get("z", "n/a")
    [
      expect(present).toBe(7),
      expect(fallback).toBe("n/a")
    ]
  )
])

// A fallible function in the `T | Error` convention.
val parsePort = (str: String): Int32 | Error =>
  if str == "" then error("empty port") else 8080

// An absence-y function in the `T | Null` convention.
val cfgGet = (k: String): String | Null =>
  if k == "name" then "alice" else null

val resultSuite = suite("std/object", [
  // ── error constructor ──────────────────────────────────────────────────────
  test("error builds the canonical Error value", () =>
    val e = error("boom")
    [
      expect(e is Error).toBe(true),
      expect(e["type"]).toBe("error"),
      expect(e["message"]).toBe("boom")
    ]
  ),

  // ── isError ─────────────────────────────────────────────────────────────────
  test("isError is true for an Error", () => [
    expect(isError(error("x"))).toBe(true)
  ]),

  test("isError is false for a plain success value", () => [
    expect(isError(8080)).toBe(false),
    expect(isError("hello")).toBe(false)
  ]),

  test("isError is false for Null", () => [
    expect(isError(null)).toBe(false)
  ]),

  // A decoded object that merely HAS a "type" field is NOT an Error (ADR-031):
  // `is Error` requires type == "error".
  test("isError is false for a non-error object with a type field", () => [
    expect(isError({ "type": "user", "name": "alice" })).toBe(false)
  ]),

  test("isError dot-application form", () => [
    expect(error("x").isError()).toBe(true)
  ]),

  // ── isOk ──────────────────────────────────────────────────────────────────
  test("isOk is the negation of isError", () => [
    expect(isOk(8080)).toBe(true),
    expect(isOk("hi")).toBe(true),
    expect(isOk(error("x"))).toBe(false)
  ]),

  // Null is "not an Error", so isOk(null) is true; use isNull to test absence.
  test("isOk is true for Null (Null is not an Error)", () => [
    expect(isOk(null)).toBe(true)
  ]),

  // ── isNull ───────────────────────────────────────────────────────────────
  test("isNull is true only for the Null value", () => [
    expect(isNull(null)).toBe(true),
    expect(isNull(0)).toBe(false),
    expect(isNull("")).toBe(false),
    expect(isNull(error("x"))).toBe(false)
  ]),

  // ── unwrapOr over T | Error ──────────────────────────────────────────────
  test("unwrapOr passes the success value through (T | Error)", () =>
    val a: Int32 = unwrapOr(parsePort("80"), 1234)
    [expect(a).toBe(8080)]
  ),

  test("unwrapOr returns default on Error (T | Error)", () =>
    val b: Int32 = unwrapOr(parsePort(""), 1234)
    [expect(b).toBe(1234)]
  ),

  test("unwrapOr dot-application form (T | Error)", () =>
    val b: Int32 = parsePort("").unwrapOr(1234)
    [expect(b).toBe(1234)]
  ),

  // ── unwrapOr over T | Null ────────────────────────────────────────────────
  test("unwrapOr passes the present value through (T | Null)", () =>
    val c: String = unwrapOr(cfgGet("name"), "anon")
    [expect(c).toBe("alice")]
  ),

  test("unwrapOr returns default on Null (T | Null)", () =>
    val d: String = unwrapOr(cfgGet("missing"), "anon")
    [expect(d).toBe("anon")]
  ),

  test("unwrapOr dot-application form (T | Null)", () =>
    val d: String = cfgGet("missing").unwrapOr("anon")
    [expect(d).toBe("anon")]
  ),

  // ── predicate use in a filter callback ────────────────────────────────────
  test("isOk filters successes out of a mixed AnyVal array", () =>
    val xs: AnyVal = [
      parsePort("80"),
      parsePort(""),
      parsePort("443")
    ]
    val oks = xs.filter(isOk)
    [expect(oks.length()).toBe(2)]
  ),

  test("isError filters failures out of a mixed AnyVal array", () =>
    val xs: AnyVal = [
      parsePort("80"),
      parsePort(""),
      parsePort("443")
    ]
    val errs = xs.filter(isError)
    [expect(errs.length()).toBe(1)]
  )
])

run([s, resultSuite])
