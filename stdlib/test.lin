import { print } from "std/io"
import { toString, join, split } from "std/string"
import { length } from "std/array"
import { filter, for, map } from "std/iter"
import { exit } from "std/io"
import { getEnv } from "std/env"
import { toJsonString, toJson } from "std/json"
import { startTimer, elapsed } from "std/time"

// An Assertion is the result of a single matcher: a pass, or a fail carrying a message (and,
// for comparison matchers, the raw expected/actual pair). Assertion VALUES flow as `Json`: a
// failing assertion carries OPEN extra keys (`message`/`expected`/`actual`) that downstream
// consumers (the reporter, the VSCode Test Explorer) read by name, so the value must NOT be
// projected to a fixed field set. Under sealed-records (a named `type T = {…}` is a sealed,
// fixed-layout record that DROPS extra fields on assignment), a concrete `Assertion = {type}`
// return type would lossily project away those extra keys — so the helpers/matchers return `Json`.
// The "every test returns an ARRAY of assertions" guard is preserved at the array level: test
// bodies are typed `() => Json[]` (an array is still required), and `docs/STDLIB.md` documents the
// `[ expect(...).toBe(...), … ]` form.
val _pass = (): Json =>
  { "type": "pass" }

val _fail = (message: String): Json =>
  { "type": "fail", "message": message }

// A failing assertion that ALSO carries the raw expected/actual pair, so consumers (the VSCode
// Test Explorer) can render a structured diff without re-parsing the human message. Returns `Json`
// so the open extra keys survive (a sealed concrete return type would project them away).
val _failCompare = (message: String, expected: Json, actual: Json): Json =>
  {
    "type": "fail",
    "message": message,
    "expected": expected,
    "actual": actual
  }

val _evalResult = (name: String, results: Json[], ms: Int64): Json =>
  val failures = results.filter(a => a["type"] == "fail")
  if length(failures) == 0 then
    {
      "type": "pass",
      "name": name,
      "ms": ms
    }
  else
    {
      "type": "fail",
      "name": name,
      "failures": failures,
      "ms": ms
    }

val _printFail = (r: Json): Null =>
  print("  FAIL  ${r["name"]}")
  r["failures"].for(f => print("    ${f["message"]}"))

val _printSuiteResults = (suiteResult: Json): Null =>
  print(suiteResult["name"])
  suiteResult["results"].for(r =>
    if r["type"] == "pass" then
      print("  ok  ${r["name"]}")
    else
      _printFail(r)
  )

// Begin an assertion by wrapping `value` in an asserter for a matcher to inspect.
// @param value  the value under test.
// @returns an asserter `{ "value": value }`; chain a matcher via dot-syntax, e.g.
//   `expect(x).toBe(42)`.
export val expect = (value: Json): Json =>
  { "value": value }

// Assert the asserter's value equals `expected` (structural `==`).
// @param asserter  the asserter from `expect`.
// @param expected  the value it should equal.
// @returns a passing assertion, or a failing one carrying the expected/actual pair.
export val toBe = (asserter: Json, expected: Json): Json =>
  val value = asserter["value"]
  if value == expected then
    _pass()
  else
    _failCompare(
      "expected: ${toString(expected)}\n    actual:   ${toString(value)}",
      expected,
      value
    )

// Assert the asserter's value is `null`.
// @param asserter  the asserter from `expect`.
// @returns a passing assertion, or a failing one carrying the actual value.
export val toBeNull = (asserter: Json): Json =>
  val value = asserter["value"]
  if value == null then
    _pass()
  else
    _failCompare("expected null, got: ${toString(value)}", null, value)

// Assert the asserter's value satisfies a predicate.
// @param asserter  the asserter from `expect`.
// @param pred      a `(Json) => Boolean` predicate the value must satisfy.
// @returns a passing assertion if `pred(value)` is true, otherwise a failing one.
export val toSatisfy = (asserter: Json, pred: Function): Json =>
  val value = asserter["value"]
  if pred(value) then
    _pass()
  else
    _fail("value did not satisfy predicate: ${toString(value)}")

// Assert the asserter's value is a success result (`{ "type": "success" }`).
// @param asserter  the asserter from `expect`.
// @returns a passing assertion if it is a success, otherwise a failing one.
export val toSucceed = (asserter: Json): Json =>
  val value = asserter["value"]
  if value["type"] == "success" then
    _pass()
  else
    _fail("expected success, got: ${toString(value)}")

// Assert the asserter's value is a failure result (`{ "type": "failure" }`).
// @param asserter  the asserter from `expect`.
// @returns a passing assertion if it is a failure, otherwise a failing one.
export val toFail = (asserter: Json): Json =>
  val value = asserter["value"]
  if value["type"] == "failure" then
    _pass()
  else
    _fail("expected failure, got: ${toString(value)}")

// Assert the asserter's value is a failure result whose `error` equals `message`.
// @param asserter  the asserter from `expect`.
// @param message   the expected failure error message.
// @returns a passing assertion if it is a failure with that message, otherwise a failing one
//   carrying the expected/actual pair.
export val toFailWith = (asserter: Json, message: String): Json =>
  val value = asserter["value"]
  if value["type"] == "failure" && value["error"] == message then
    _pass()
  else
    _failCompare(
      "expected failure with \"${message}\", got: ${toString(value)}",
      message,
      value["error"]
    )

// Is this test selected to run? When the `LIN_TEST_ONLY` env var is set (by `lin test
// --filter-test`), it holds the newline-separated set of test names to run; a test whose name
// isn't in that set is skipped. When the var is unset, every test is selected (the default).
val _isSelected = (name: String): Boolean =>
  val only = getEnv("LIN_TEST_ONLY")
  if only == null then
    true
  else
    val wanted = split(only, "\n").filter(n => n == name)
    length(wanted) > 0

// Define a test: eagerly run its body and store the result alongside the name.
// @param name  the test name (also used by `--filter-test` selection).
// @param body  a thunk returning an `Assertion[]` (use the `[ expect(...).toBe(...), ... ]` form,
//   even for a single assertion); every assertion is evaluated and the test fails if any fails.
// @returns a result record. When `--filter-test` (via LIN_TEST_ONLY) did not select this test, the
//   body is NOT evaluated (no side effects, no fixture setup/teardown) and a `{ "type": "skip" }`
//   sentinel is produced, which `report` counts as neither pass nor fail.
export val test = (name: String, body: () => Json[]): Json =>
  if _isSelected(name) then
    val timer = startTimer()
    val results = body()
    _evalResult(name, results, elapsed(timer))
  else
    { "type": "skip", "name": name }

// Run a test with per-test setup/teardown and dependency injection (ADR-046): build a fixture,
// inject it into the body, and tear it down — all within a single `test`. The functional
// alternative to keyword beforeEach/afterEach; compose via partial application into a per-fixture
// helper, e.g. `val withDb = withFixture(openDb, closeDb,)`, then `withDb("name", db => [ ... ])`.
// @param setup     builds the fixture value.
// @param teardown  releases the fixture; always runs, even when the body's assertions fail (because
//   assertion failures are VALUES, not exceptions).
// @param name      the test name.
// @param body      receives the fixture and returns an `Assertion[]`.
// @returns the test result record (same as `test`).
export val withFixture = (setup: () => Json, teardown: (Json) => Null, name: String, body: (Json) => Json[]): Json =>
  test(name, () =>
    val fixture = setup()
    val results = body(fixture)
    teardown(fixture)
    results
  )

// Group test results into a named suite for `report`/`run`.
// @param name   the suite name.
// @param tests  the array of test result records (from `test`/`withFixture`).
// @returns a suite record `{ "name", "tests" }`.
export val suite = (name: String, tests: Json[]): Json =>
  { "name": name, "tests": tests }

// Machine-readable NDJSON emission, gated on the LIN_TEST_JSON env var (see `report`).
// Each test result becomes ONE marker-prefixed line. The `##LINTEST## ` prefix lets the CLI
// distinguish runner records from arbitrary `print` output the user's own code may emit on the
// same stdout stream. `toJsonString` already quotes+escapes its argument, so the name/message
// are interpolated raw. Failure messages (which themselves contain `expected:…\nactual:…`
// newlines) are joined with `\n` and handed to `toJsonString` for escaping.
val _reportJsonResult = (r: Json): Null =>
  if r["type"] == "skip" then
    null
  else if r["type"] == "pass" then
    print(
      "##LINTEST## {\"event\":\"test\",\"name\":${toJsonString(r["name"])},\"status\":\"pass\",\"ms\":${toString(r["ms"])}}"
    )
  else
    val messages = r["failures"].map(f => f["message"])
    val joined = messages.join("\n")
    // Structured expected/actual is emitted ONLY when EXACTLY ONE failure carries a pair (the
    // common one-assertion-per-test case). With multiple failing assertions there is no single
    // pair to surface, so we omit the fields and let the joined `message` convey everything. The
    // values are arbitrary Json (objects/arrays/quoted strings), so they MUST go through `toJson`
    // (the recursive serializer), never raw interpolation or the string-only `toJsonString`.
    val structured = r["failures"].filter(f => f["expected"] != null || f["actual"] != null)
    if length(structured) == 1 then
      val f = structured[0]
      print(
        "##LINTEST## {\"event\":\"test\",\"name\":${toJsonString(r["name"])},\"status\":\"fail\",\"message\":${toJsonString(joined)},\"expected\":${toJson(f["expected"])},\"actual\":${toJson(f["actual"])},\"ms\":${toString(r["ms"])}}"
      )
    else
      print(
        "##LINTEST## {\"event\":\"test\",\"name\":${toJsonString(r["name"])},\"status\":\"fail\",\"message\":${toJsonString(joined)},\"ms\":${toString(r["ms"])}}"
      )

// Print a suite's results and return the failure count. Unlike `run`, does NOT call `exit`, so
// statements after it run regardless of outcome — the building block for guaranteed afterAll
// teardown: `val failures = report(s); cleanup(); if failures > 0 then exit(1)`.
// @param s  the suite from `suite`.
// @returns the number of failed tests (0 = all passed). Skipped tests (from `--filter-test`) are
//   excluded from both pass and fail counts. When LIN_TEST_JSON is set, the human-readable lines
//   are suppressed and one NDJSON record is emitted per test (for `lin test --reporter json`); the
//   return value is identical in both modes.
export val report = (s: Json): Int32 =>
  val failed = s["tests"].filter(r => r["type"] == "fail")
  val skipped = s["tests"].filter(r => r["type"] == "skip")
  val passCount = length(s["tests"]) - length(failed) - length(skipped)
  val failCount = length(failed)
  if getEnv("LIN_TEST_JSON") != null then
    s["tests"].for(r => _reportJsonResult(r))
  else
    val shown = s["tests"].filter(r => r["type"] != "skip")
    _printSuiteResults({ "name": s["name"], "results": shown })
    if failCount == 0 then
      print("${toString(passCount)} passed")
    else
      print("${toString(failCount)} failed, ${toString(passCount)} passed")
  failCount

// Run a suite: print results and `exit(1)` if any test failed (the common case — a non-zero status
// fails CI). For guaranteed post-run teardown even on failure, use `report` instead.
// @param s  the suite from `suite`.
export val run = (s: Json): Null =>
  if report(s) > 0 then
    exit(1)
  else
    null
