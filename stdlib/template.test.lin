import { expect, toBe, test, suite, run } from "std/test"
import { writeFile, mkdir } from "std/fs"
import { contains } from "std/string"
import { renderWith, render } from "std/template"

val tmpTpl = "/tmp/lin_test_template.tpl"
// Directory for the layout/inheritance test: base + child live side by side so the
// path loader can resolve `{% extends %}` by basename.
val tmpDir = "/tmp/lin_test_template_layout"

val s = suite("std/template", [
  test("renderWith substitutes variables", () =>
    val result = renderWith("Hello, {{ name }}!", { "name": "Lin" })
    [
      expect(result).toBe("Hello, Lin!")
    ]
  ),

  test("renderWith handles multiple variables", () =>
    val result = renderWith("{{ greeting }}, {{ name }}!", { "greeting": "Hi", "name": "world" })
    [
      expect(result).toBe("Hi, world!")
    ]
  ),

  test("renderWith renders missing variables as empty string", () =>
    val result = renderWith("[{{ missing }}]", { "name": "Lin" })
    [
      expect(result).toBe("[]")
    ]
  ),

  test("renderWith iterates with a for loop", () =>
    val result = renderWith("{% for n in items %}{{ n }},{% endfor %}", { "items": [1, 2, 3] })
    [
      expect(result).toBe("1,2,3,")
    ]
  ),

  test("renderWith branches with an if", () =>
    val result = renderWith("{% if show %}yes{% else %}no{% endif %}", { "show": true })
    [
      expect(result).toBe("yes")
    ]
  ),

  test("renderWith combines loop and conditional", () =>
    val tpl = "{% for u in users %}{{ u.name }}{% if u.admin %}*{% endif %} {% endfor %}"
    val result = renderWith(tpl, { "users": [
      { "name": "ada", "admin": true },
      { "name": "bob", "admin": false }
    ] })
    [
      expect(result).toBe("ada* bob ")
    ]
  ),

  test("renderWith returns Error on template syntax error", () =>
    val result = renderWith("{% for x in %}", {})
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("render reads template from file", () =>
    writeFile(tmpTpl, "Value: {{ v }}")
    val result = render(tmpTpl, { "v": "42" })
    [
      expect(result).toBe("Value: 42")
    ]
  ),

  test("render returns error for missing file", () =>
    val result = render("/nonexistent/template.tpl", {})
    [
      expect(result["type"]).toBe("error")
    ]
  ),

  test("render resolves template inheritance via the path loader", () =>
    mkdir(tmpDir, { "parents": true })
    // A base layout with a fillable block, and a child that extends it. The loader
    // resolves the `{% extends %}` name against the child's own directory.
    writeFile("${tmpDir}/base.jinja", "<html><body>{% block body %}{% endblock %}</body></html>")
    writeFile("${tmpDir}/child.jinja", "{% extends \"base.jinja\" %}{% block body %}Hi {{ name }}{% endblock %}")
    val result = render("${tmpDir}/child.jinja", { "name": "Lin" })
    [
      expect(result.contains("<body>Hi Lin</body>")).toBe(true)
    ]
  ),
])

run(s)
