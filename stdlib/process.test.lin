import { expect, toBe, toSatisfy, test, suite, run } from "std/test"
import { contains } from "std/string"
import { spawn, readStdout, wait, exec, shell, cwd, chdir, kill } from "std/process"
import { hostname, platform, arch, cpuCount, pid, ppid } from "std/process"
import { username, homeDir, tempDir, uptime, loadAverage, memInfo } from "std/process"
import { isDir } from "std/fs"
import { length } from "std/array"

// std/process over real subprocesses is deterministic. We run small `sh`/`printf`
// commands, so this touches no stdin/TTY state and is CI-safe.
val s = suite("std/process", [
  // --- streaming: spawn / readStdout / wait ---
  test("spawn + readStdout returns the child's output bytes", () =>
    val h = spawn("sh", ["-c", "printf hello"])
    val buf: UInt8[] = [
      0,
      0,
      0,
      0,
      0,
      0,
      0,
      0
    ]
    if h is Error then
      [expect(false).toBe(true)]
    else
      val n = readStdout(h, buf)
      val code = wait(h)
      [
        expect(n).toBe(5),
        expect(buf[0]).toBe(104),
        expect(buf[1]).toBe(101),
        expect(buf[2]).toBe(108),
        expect(buf[3]).toBe(108),
        expect(buf[4]).toBe(111),
        expect(code).toBe(0)
      ]
  ),

  test("wait returns the child's exit code", () =>
    val h = spawn("sh", ["-c", "exit 3"])
    if h is Error then
      [expect(false).toBe(true)]
    else
      val code = wait(h)
      [
        expect(code).toBe(3)
      ]
  ),

  // --- batch: exec / shell / cwd ---
  test("exec collects status and stdout", () =>
    val r = exec("printf", ["batch-out"])
    [
      expect(r["status"]).toBe(0),
      expect(r["stdout"]).toBe("batch-out")
    ]
  ),

  test("exec reports a non-zero exit status", () =>
    val r = exec("sh", ["-c", "exit 7"])
    [
      expect(r["status"]).toBe(7)
    ]
  ),

  test("shell runs a command through /bin/sh", () =>
    val r = shell("printf one; printf two")
    [
      expect(r["status"]).toBe(0),
      expect(r["stdout"]).toBe("onetwo")
    ]
  ),

  test("cwd returns a non-empty absolute path", () =>
    val here = cwd()
    [
      expect(contains(here, "/")).toBe(true)
    ]
  ),

  test("exec captures the child's stderr", () =>
    // Write to fd 2 only; stdout stays empty, stderr carries the text.
    val r = exec("sh", ["-c", "printf oops 1>&2"])
    [
      expect(r["status"]).toBe(0),
      expect(r["stdout"]).toBe(""),
      expect(r["stderr"]).toBe("oops")
    ]
  ),

  test("chdir moves the cwd and reports an Error for a bad path", () =>
    // cwd is process-wide, so capture it first and restore it before returning
    // to keep this test self-contained and order-independent.
    val original = cwd()
    val ok = chdir("/")
    val moved = cwd()
    val bad = chdir("/no/such/dir/lin-test-xyz")
    chdir(original)
    [
      expect(ok == null).toBe(true),
      expect(moved).toBe("/"),
      expect(bad is Error).toBe(true),
      expect(cwd()).toBe(original)
    ]
  ),

  test("kill terminates a spawned child", () =>
    // Spawn a long sleeper, kill it (SIGTERM), then reap it. A child killed by a
    // signal reports a -1 exit code via wait().
    val h = spawn("sh", ["-c", "sleep 30"])
    if h is Error then
      [expect(false).toBe(true)]
    else
      val k = kill(h)
      val code = wait(h)
      [
        expect(k == null).toBe(true),
        expect(code).toBe(-1)
      ]
  )
])

// All assertions here are PORTABLE / non-brittle: they check structural invariants (a value is
// in the documented closed set, is positive, is non-empty, names a real directory) rather than
// exact machine values, so the suite passes on any host/CI runner regardless of platform.
// platform() must be one of the documented closed set.
val knownPlatform = (p: AnyVal): Boolean =>
  p == "linux" || p == "macos" || p == "windows" || p == "freebsd" || p == "openbsd" || p == "netbsd" || p == "unknown"

// arch() must be one of the documented closed set.
val knownArch = (a: AnyVal): Boolean =>
  a == "x86_64" || a == "aarch64" || a == "arm" || a == "x86" || a == "riscv64" || a == "wasm32" || a == "unknown"

val osSuite = suite("std/process", [
  test("platform returns a value from the known set", () => [
    expect(knownPlatform(platform())).toBe(true)
  ]),

  test("platform is non-empty and not 'unknown' on a supported host", () => [
    // We don't assert WHICH platform, only that it is a real, non-empty string.
    expect(platform().length() > 0).toBe(true)
  ]),

  test("arch returns a value from the known set", () => [
    expect(knownArch(arch())).toBe(true)
  ]),

  test("arch is non-empty", () => [
    expect(arch().length() > 0).toBe(true)
  ]),

  test("cpuCount is at least 1", () => [
    expect(cpuCount() >= 1).toBe(true)
  ]),

  test("cpuCount composes as a bare Int32 (no match needed)", () => [
    // The headline integration: cpuCount() feeds threadPool(n) directly. Here we just
    // confirm it is usable in plain arithmetic without unwrapping.
    expect(cpuCount() + 0 >= 1).toBe(true)
  ]),

  test("pid is positive", () => [
    expect(pid() > 0).toBe(true)
  ]),

  test("ppid is non-negative", () => [
    // ppid may be 0 where the parent cannot be determined; never negative.
    expect(ppid() >= 0).toBe(true)
  ]),

  test("hostname is a non-empty string (or Error)", () => [
    expect(hostname()).toSatisfy((h: AnyVal) =>
      match h
        is Error => true
        else => length(h) > 0
    )
  ]),

  test("username resolves to a non-empty string (or Error)", () => [
    expect(username()).toSatisfy((u: AnyVal) =>
      match u
        is Error => true
        else => length(u) > 0
    )
  ]),

  test("homeDir resolves to a non-empty path (or Error)", () => [
    expect(homeDir()).toSatisfy((h: AnyVal) =>
      match h
        is Error => true
        else => length(h) > 0
    )
  ]),

  test("tempDir returns an existing directory", () => [
    expect(isDir(tempDir())).toBe(true)
  ]),

  test("tempDir is a non-empty path", () => [
    expect(tempDir().length() > 0).toBe(true)
  ]),

  test("uptime is a positive whole number of seconds (or Error)", () => [
    expect(uptime()).toSatisfy((u: AnyVal) =>
      match u
        is Error => true
        else => u >= 0
    )
  ]),

  test("loadAverage is a 3-element array on Unix, Error elsewhere", () => [
    expect(loadAverage()).toSatisfy((la: AnyVal) =>
      match la
        is Error => true
        else => la.length() == 3 && la[0] >= 0.0
    )
  ]),

  test("memInfo reports total > free >= 0 (or Error)", () => [
    expect(memInfo()).toSatisfy((m: AnyVal) =>
      match m
        is Error => true
        else => m["total"] > 0 && m["free"] >= 0
    )
  ]),

  test("dot-application form: cpuCount via plain call equals itself", () => [
    // cpuCount has no argument, so exercise dot-application on a string-touching call instead:
    // platform().length() is the dot form of length(platform()).
    expect(platform().length()).toBe(length(platform()))
  ])
])

run([s, osSuite])
