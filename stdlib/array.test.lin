import { expect, toBe, test, suite, run } from "std/test"
import { toString } from "std/string"
import { indexOf, reverse, push, length, partition, zip, unique, chunk, compact, sort, sortBy, sum, product, min, max, minBy, maxBy, append, prepend, scan, groupBy, countBy, arrayAllocate, arrayAllocateFilled, set, at, atOr, slice } from "std/array"
import { map, filter, reduce, find, some, every, flatMap, concat, range, rangeStep, for, take, drop, takeWhile, dropWhile, flatten, iterOf } from "std/iter"

val s = suite("std/array", [
  test("length of array", () => [
    expect([1, 2, 3].length()).toBe(3)
  ]),

  test("length of empty array", () => [
    expect([].length()).toBe(0)
  ]),

  test("push mutates array", () =>
    val arr = [1, 2]
    arr.push(3)
    [
      expect(arr.length()).toBe(3)
    ]
  ),

  test("concat two arrays", () =>
    val result = [1, 2].concat([3, 4])
    [
      expect(result.length()).toBe(4)
    ]
  ),

  test("range produces correct values", () =>
    val result: Int32[] = []
    range(0, 3).for(i => result.push(i))
    [
      expect(result.toString()).toBe("[0, 1, 2]")
    ]
  ),

  test("iterOf iterates over array elements", () =>
    val result: Int32[] = []
    iterOf([10, 20, 30]).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[10, 20, 30]")
    ]
  ),

  test("iterOf over empty array produces nothing", () =>
    val result: Int32[] = []
    iterOf([]).for(x => result.push(x))
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("map doubles values", () =>
    val result = [1, 2, 3].map(x => x * 2)
    [
      expect(result.toString()).toBe("[2, 4, 6]")
    ]
  ),

  test("filter keeps evens", () =>
    val result = [1, 2, 3, 4].filter(x => x % 2 == 0)
    [
      expect(result.toString()).toBe("[2, 4]")
    ]
  ),

  // Regression (ADR-069 R2): filtering an array of OBJECTS pushes each kept element (BORROWED from
  // the source) into the result; the result array must take its own reference, else releasing both
  // the source and the filtered array at teardown double-frees the shared objects (heap UAF).
  test("filter over object array does not double-free kept elements", () =>
    val items = [
      { "type": "a", "v": 1 },
      { "type": "b", "v": 2 },
      { "type": "a", "v": 3 }
    ]
    val kept = items.filter(i => i["type"] == "a")
    [
      expect(length(kept)).toBe(2),
      expect(kept[0]["v"]).toBe(1),
      expect(kept[1]["v"]).toBe(3),
      // the source must remain intact and independently usable after the filter
      expect(length(items)).toBe(3)
    ]
  ),

  test("reduce sums values", () =>
    val result = [1, 2, 3, 4].reduce(0, (acc, x) => acc + x)
    [
      expect(result).toBe(10)
    ]
  ),

  test("find returns first match", () =>
    val result = [1, 2, 3, 4].find(x => x > 2)
    [
      expect(result).toBe(3)
    ]
  ),

  test("find returns null when no match", () =>
    val result = [1, 2, 3].find(x => x > 10)
    [
      expect(result).toBe(null)
    ]
  ),

  test("some returns true when any match", () =>
    val result = [1, 2, 3].some(x => x == 2)
    [
      expect(result).toBe(true)
    ]
  ),

  test("some returns false when none match", () =>
    val result = [1, 2, 3].some(x => x == 99)
    [
      expect(result).toBe(false)
    ]
  ),

  test("every returns true when all match", () =>
    val result = [2, 4, 6].every(x => x % 2 == 0)
    [
      expect(result).toBe(true)
    ]
  ),

  test("every returns false when any fail", () =>
    val result = [2, 3, 6].every(x => x % 2 == 0)
    [
      expect(result).toBe(false)
    ]
  ),

  test("flatMap flattens one level", () =>
    val result = [1, 2, 3].flatMap(x => [x, x * 10])
    [
      expect(result.toString()).toBe("[1, 10, 2, 20, 3, 30]")
    ]
  ),

  test("indexOf returns index of found element", () =>
    val result = [10, 20, 30].indexOf(20)
    [
      expect(result).toBe(1)
    ]
  ),

  test("indexOf returns -1 when not found", () =>
    val result = [10, 20, 30].indexOf(99)
    [
      expect(result).toBe(-1)
    ]
  ),

  // at/set/indexOf carry generic <T>(T[], ...) signatures (ADR-067): they
  // preserve the element type so concrete Int32[]/String[] callers stay
  // representation-consistent. Cover both element representations and the
  // negative-index wrap.
  test("at returns element on Int32[]", () =>
    [
      expect([10, 20, 30].at(1)).toBe(20)
    ]
  ),

  test("at wraps negative index on String[]", () =>
    [
      expect(["a", "b", "c"].at(-1)).toBe("c")
    ]
  ),

  test("at returns null on out-of-bounds positive index", () =>
    [
      expect([10, 20, 30].at(5)).toBe(null)
    ]
  ),

  test("at returns null on out-of-bounds negative index", () =>
    [
      expect([10, 20, 30].at(-5)).toBe(null)
    ]
  ),

  test("atOr returns the element when in bounds", () =>
    [
      expect([10, 20, 30].atOr(1, -1)).toBe(20)
    ]
  ),

  test("atOr returns the default when out of bounds", () =>
    [
      expect([10, 20, 30].atOr(5, -1)).toBe(-1)
    ]
  ),

  test("atOr wraps a negative index", () =>
    [
      expect([10, 20, 30].atOr(-1, -1)).toBe(30)
    ]
  ),

  test("atOr returns the default for an out-of-range negative index", () =>
    [
      expect([10, 20, 30].atOr(-9, 99)).toBe(99)
    ]
  ),

  // The whole point of atOr: the result is a bare T, usable in arithmetic with no null guard.
  test("atOr returns a bare T usable in arithmetic", () =>
    val sum: Int32 = [10, 20, 30].atOr(1, 0) + [10, 20, 30].atOr(7, 5)
    [
      expect(sum).toBe(25)
    ]
  ),

  test("indexOf on String[]", () =>
    [
      expect(["a", "b", "c"].indexOf("c")).toBe(2)
    ]
  ),

  // indexOf fromIndex: search from a start offset; negatives count from the end.
  test("indexOf with fromIndex finds later occurrence", () =>
    [
      expect([1, 2, 1, 2].indexOf(2, 2)).toBe(3)
    ]
  ),

  test("indexOf with negative fromIndex starts near the end", () =>
    [
      expect([1, 2, 1, 2].indexOf(1, -1)).toBe(-1)
    ]
  ),

  test("indexOf without fromIndex is unchanged", () =>
    [
      expect([10, 20, 30].indexOf(20)).toBe(1),
      expect([10, 20, 30].indexOf(99)).toBe(-1)
    ]
  ),

  // slice: optional end (defaults to length) and negative indices count from the end.
  test("slice with start only goes to end", () =>
    [
      expect([1, 2, 3, 4, 5].slice(1).toString()).toBe("[2, 3, 4, 5]")
    ]
  ),

  test("slice with negative end", () =>
    [
      expect([1, 2, 3, 4, 5].slice(1, -1).toString()).toBe("[2, 3, 4]")
    ]
  ),

  test("slice with negative start", () =>
    [
      expect([1, 2, 3, 4, 5].slice(-2).toString()).toBe("[4, 5]")
    ]
  ),

  test("slice with explicit start and end is unchanged", () =>
    [
      expect([1, 2, 3, 4, 5].slice(1, 3).toString()).toBe("[2, 3]")
    ]
  ),

  test("set then at round-trips on Int32[]", () =>
    val a = [1, 2, 3]
    set(a, 1, 99)
    [
      expect(a.at(1)).toBe(99)
    ]
  ),

  test("reverse reverses array", () =>
    val result = [1, 2, 3].reverse()
    [
      expect(result.toString()).toBe("[3, 2, 1]")
    ]
  ),

  test("partition splits into passing and failing", () =>
    val result = [1, 2, 3, 4, 5].partition(x => x % 2 == 0)
    [
      expect(result[0].toString()).toBe("[2, 4]"),
      expect(result[1].toString()).toBe("[1, 3, 5]")
    ]
  ),

  test("partition with empty array", () =>
    // `partition` is `<T>(T[], …): T[][]`; an empty literal cannot pin `T`, so the input is
    // annotated to determine it (the same empty-literal inference limitation as `flatten`).
    val empty: Int32[] = []
    val result = empty.partition(x => x == 1)
    [
      expect(result[0].length()).toBe(0),
      expect(result[1].length()).toBe(0)
    ]
  ),

  test("zip pairs elements at same index", () =>
    val result = [1, 2, 3].zip(["a", "b", "c"])
    [
      expect(result.toString()).toBe("[[1, \"a\"], [2, \"b\"], [3, \"c\"]]")
    ]
  ),

  test("zip truncates to shortest array", () =>
    val result = [1, 2].zip([3, 4, 5])
    [
      expect(result.toString()).toBe("[[1, 3], [2, 4]]")
    ]
  ),

  test("unique removes duplicates preserving order", () =>
    val result = [1, 2, 1, 3, 2].unique()
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("unique on array with no duplicates", () =>
    val result = [1, 2, 3].unique()
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("take returns first n elements", () =>
    val result = [1, 2, 3, 4, 5].take(3)
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("take when n exceeds length returns whole array", () =>
    val result = [1, 2].take(10)
    [
      expect(result.toString()).toBe("[1, 2]")
    ]
  ),

  test("drop removes first n elements", () =>
    val result = [1, 2, 3, 4, 5].drop(2)
    [
      expect(result.toString()).toBe("[3, 4, 5]")
    ]
  ),

  test("drop when n exceeds length returns empty array", () =>
    val result = [1, 2].drop(10)
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("takeWhile returns elements while predicate holds", () =>
    val result = [1, 2, 3, 4].takeWhile(x => x < 3)
    [
      expect(result.toString()).toBe("[1, 2]")
    ]
  ),

  test("takeWhile stops at first false", () =>
    val result = [1, 3, 2, 4].takeWhile(x => x < 3)
    [
      expect(result.toString()).toBe("[1]")
    ]
  ),

  test("dropWhile skips elements while predicate holds", () =>
    val result = [1, 2, 3, 4].dropWhile(x => x < 3)
    [
      expect(result.toString()).toBe("[3, 4]")
    ]
  ),

  test("dropWhile returns all when predicate is immediately false", () =>
    val result = [3, 4, 5].dropWhile(x => x < 3)
    [
      expect(result.toString()).toBe("[3, 4, 5]")
    ]
  ),

  test("sort numbers ascending", () =>
    val result = [3, 1, 2].sort((a, b) => a - b)
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("sort numbers descending", () =>
    val result = [3, 1, 2].sort((a, b) => b - a)
    [
      expect(result.toString()).toBe("[3, 2, 1]")
    ]
  ),

  test("sort strings lexicographically", () =>
    val result = ["banana", "apple", "cherry"].sort((a, b) =>
      if a < b then -1 else if a > b then 1 else 0
    )
    [
      expect(result.toString()).toBe("[\"apple\", \"banana\", \"cherry\"]")
    ]
  ),

  test("sort does not mutate original array", () =>
    val original = [3, 1, 2]
    val result = original.sort((a, b) => a - b)
    [
      expect(original.toString()).toBe("[3, 1, 2]"),
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("sort empty array returns empty array", () =>
    val result = [].sort((a, b) => a - b)
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("sort single element returns copy", () =>
    val result = [42].sort((a, b) => a - b)
    [
      expect(result.toString()).toBe("[42]")
    ]
  ),

  test("sortBy numbers by value", () =>
    val result = [3, 1, 2].sortBy(x => x)
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("sortBy objects by field", () =>
    val result = [{ "name": "Bob" }, { "name": "Alice" }, { "name": "Charlie" }].sortBy(x => x["name"])
    [
      expect(result[0]["name"]).toBe("Alice"),
      expect(result[1]["name"]).toBe("Bob"),
      expect(result[2]["name"]).toBe("Charlie")
    ]
  ),

  test("sortBy does not mutate original array", () =>
    val original = [3, 1, 2]
    val result = original.sortBy(x => x)
    [
      expect(original.toString()).toBe("[3, 1, 2]")
    ]
  ),

  test("sort is stable: equal keys keep input order", () =>
    // Records share key 1; their `id` field records input order. A stable sort must
    // emit the key-1 group as 0,3,5 (input order), never reordered.
    val items = [
      { "k": 1, "id": 0 },
      { "k": 0, "id": 1 },
      { "k": 1, "id": 2 },
      { "k": 0, "id": 3 },
      { "k": 1, "id": 4 },
      { "k": 0, "id": 5 }
    ]
    val sorted = items.sort((a, b) => a["k"] - b["k"])
    [
      // key-0 group first, stable: ids 1,3,5; then key-1 group, stable: ids 0,2,4
      expect(sorted[0]["id"]).toBe(1),
      expect(sorted[1]["id"]).toBe(3),
      expect(sorted[2]["id"]).toBe(5),
      expect(sorted[3]["id"]).toBe(0),
      expect(sorted[4]["id"]).toBe(2),
      expect(sorted[5]["id"]).toBe(4)
    ]
  ),

  test("sort handles non-power-of-two length", () =>
    val result = [5, 3, 8, 1, 9, 2, 7].sort((a, b) => a - b)
    [
      expect(result.toString()).toBe("[1, 2, 3, 5, 7, 8, 9]")
    ]
  ),

  test("sum of integers", () =>
    val result = [1, 2, 3, 4].sum()
    [
      expect(result).toBe(10)
    ]
  ),

  test("sum of empty array returns 0", () =>
    val result = [].sum()
    [
      expect(result).toBe(0)
    ]
  ),

  test("product of integers", () =>
    val result = [1, 2, 3, 4].product()
    [
      expect(result).toBe(24)
    ]
  ),

  test("product of empty array returns 1", () =>
    val result = [].product()
    [
      expect(result).toBe(1)
    ]
  ),

  test("min returns smallest value", () =>
    val result = [3, 1, 4, 1, 5].min()
    [
      expect(result).toBe(1)
    ]
  ),

  test("max returns largest value", () =>
    val result = [3, 1, 4, 1, 5].max()
    [
      expect(result).toBe(5)
    ]
  ),

  test("minBy returns element with smallest key", () =>
    val result = [{ "n": 3 }, { "n": 1 }, { "n": 2 }].minBy(x => x["n"])
    [
      expect(result["n"]).toBe(1)
    ]
  ),

  test("maxBy returns element with largest key", () =>
    val result = [{ "n": 3 }, { "n": 1 }, { "n": 2 }].maxBy(x => x["n"])
    [
      expect(result["n"]).toBe(3)
    ]
  ),

  test("rangeStep with positive step 2", () =>
    val result: Int32[] = []
    rangeStep(0, 6, 2).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[0, 2, 4]")
    ]
  ),

  test("rangeStep with positive step 3", () =>
    val result: Int32[] = []
    rangeStep(0, 10, 3).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[0, 3, 6, 9]")
    ]
  ),

  test("rangeStep with negative step", () =>
    val result: Int32[] = []
    rangeStep(5, 0, -1).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[5, 4, 3, 2, 1]")
    ]
  ),

  test("rangeStep with negative step -2", () =>
    val result: Int32[] = []
    rangeStep(10, 0, -2).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[10, 8, 6, 4, 2]")
    ]
  ),

  test("rangeStep with step 0 returns empty iterator", () =>
    val result: Int32[] = []
    rangeStep(0, 10, 0).for(x => result.push(x))
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("rangeStep with step 1 matches range", () =>
    val result: Int32[] = []
    rangeStep(0, 4, 1).for(x => result.push(x))
    [
      expect(result.toString()).toBe("[0, 1, 2, 3]")
    ]
  ),

  test("flatten flattens one level of nesting", () =>
    val result = [[1, 2], [3, 4]].flatten()
    [
      expect(result.toString()).toBe("[1, 2, 3, 4]")
    ]
  ),

  test("flatten with empty inner arrays", () =>
    // The element type cannot be inferred from the empty inner literals alone, so the outer
    // array is annotated to pin `flatten`'s `T` to Int32 (the generic <T>(T[][]): T[] signature).
    val nested: Int32[][] = [[], [1], []]
    val result = nested.flatten()
    [
      expect(result.toString()).toBe("[1]")
    ]
  ),

  test("chunk splits into equal-sized pieces", () =>
    val result = [1, 2, 3, 4].chunk(2)
    [
      expect(result.toString()).toBe("[[1, 2], [3, 4]]")
    ]
  ),

  test("chunk last piece may be shorter", () =>
    val result = [1, 2, 3, 4, 5].chunk(2)
    [
      expect(result.toString()).toBe("[[1, 2], [3, 4], [5]]")
    ]
  ),

  test("chunk whole array in one piece", () =>
    val result = [1, 2, 3].chunk(3)
    [
      expect(result.toString()).toBe("[[1, 2, 3]]")
    ]
  ),

  test("chunk empty array returns empty array", () =>
    val result = [].chunk(2)
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("compact removes nulls", () =>
    val result = [1, null, 2, null, 3].compact()
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("compact all nulls returns empty array", () =>
    val result = [null, null].compact()
    [
      expect(result.length()).toBe(0)
    ]
  ),

  test("compact with no nulls returns unchanged array", () =>
    val result = [1, 2, 3].compact()
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("append adds item to end of array", () =>
    val result = [1, 2, 3].append(4)
    [
      expect(result.toString()).toBe("[1, 2, 3, 4]")
    ]
  ),

  test("append does not mutate original array", () =>
    val original = [1, 2, 3]
    val result = original.append(4)
    [
      expect(original.toString()).toBe("[1, 2, 3]"),
      expect(result.toString()).toBe("[1, 2, 3, 4]")
    ]
  ),

  test("append on empty array returns single-element array", () =>
    val result = [].append(1)
    [
      expect(result.toString()).toBe("[1]")
    ]
  ),

  test("prepend adds item to front of array", () =>
    val result = [2, 3].prepend(1)
    [
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("prepend does not mutate original array", () =>
    val original = [2, 3]
    val result = original.prepend(1)
    [
      expect(original.toString()).toBe("[2, 3]"),
      expect(result.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("prepend on empty array returns single-element array", () =>
    val result = [].prepend(1)
    [
      expect(result.toString()).toBe("[1]")
    ]
  ),

  test("append on a flat UInt8[] preserves the byte value (not zero)", () =>
    val b: UInt8[] = [1, 2]
    val b2: UInt8[] = b.append(3)
    [
      expect(b2.toString()).toBe("[1, 2, 3]"),
      // The latent-bug check: a tagged result would read 0 here.
      expect(b2[2]).toBe(3)
    ]
  ),

  test("prepend on a flat UInt8[] preserves the byte value", () =>
    val b: UInt8[] = [2, 3]
    val b2: UInt8[] = b.prepend(1)
    [
      expect(b2.toString()).toBe("[1, 2, 3]"),
      expect(b2[0]).toBe(1)
    ]
  ),

  test("append/prepend on a String[] keep the strings (tagged RC)", () =>
    val ss = ["a", "b"]
    [
      expect(ss.append("c").toString()).toBe("[\"a\", \"b\", \"c\"]"),
      expect(ss.prepend("z").toString()).toBe("[\"z\", \"a\", \"b\"]"),
      // original unchanged
      expect(ss.toString()).toBe("[\"a\", \"b\"]")
    ]
  ),

  test("scan returns all intermediate accumulator values including initial", () =>
    val result = [1, 2, 3].scan(0, (acc, x) => acc + x)
    [
      expect(result.toString()).toBe("[0, 1, 3, 6]")
    ]
  ),

  test("scan on empty array returns array with only initial value", () =>
    val result = [].scan(0, (acc, x) => acc + x)
    [
      expect(result.toString()).toBe("[0]")
    ]
  ),

  test("scan with multiplication", () =>
    val result = [1, 2, 3, 4].scan(1, (acc, x) => acc * x)
    [
      expect(result.toString()).toBe("[1, 1, 2, 6, 24]")
    ]
  ),

  test("groupBy groups elements by key function", () =>
    val result = [1, 2, 3, 4].groupBy(x => if x % 2 == 0 then "even" else "odd")
    [
      expect(result["odd"].toString()).toBe("[1, 3]"),
      expect(result["even"].toString()).toBe("[2, 4]")
    ]
  ),

  test("groupBy with single key puts all in one group", () =>
    val result = [1, 2, 3].groupBy(x => "all")
    [
      expect(result["all"].toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("groupBy empty array returns empty object", () =>
    val empty: Int32[] = []
    val result = empty.groupBy(x => "k")
    [
      expect(result["k"]).toBe(null)
    ]
  ),

  test("groupBy preserves order within each group across many items", () =>
    // One lookup + in-place push per item (lin_object_get_or_insert_array): items must
    // accumulate in encounter order within each bucket.
    val result = [1, 2, 3, 4, 5, 6].groupBy(x => if x % 2 == 0 then "even" else "odd")
    [
      expect(result["odd"].toString()).toBe("[1, 3, 5]"),
      expect(result["even"].toString()).toBe("[2, 4, 6]")
    ]
  ),

  test("groupBy of strings keeps the values (heap-element RC)", () =>
    // String elements stress the tagged-payload retain path: the group arrays must own their
    // own references so the values print correctly (a UAF would corrupt these assertions).
    val result = ["apple", "avocado", "banana", "cherry"].groupBy(s =>
      if s == "banana" then "b" else if s == "cherry" then "c" else "a"
    )
    [
      expect(result["a"].toString()).toBe("[\"apple\", \"avocado\"]"),
      expect(result["b"].toString()).toBe("[\"banana\"]"),
      expect(result["c"].toString()).toBe("[\"cherry\"]")
    ]
  ),

  test("countBy counts occurrences of each key", () =>
    val result = ["a", "b", "a", "c", "b", "a"].countBy(x => x)
    [
      expect(result["a"]).toBe(3),
      expect(result["b"]).toBe(2),
      expect(result["c"]).toBe(1)
    ]
  ),

  test("countBy groups even and odd counts", () =>
    val result = [1, 2, 3, 4, 5].countBy(x => if x % 2 == 0 then "even" else "odd")
    [
      expect(result["odd"]).toBe(3),
      expect(result["even"]).toBe(2)
    ]
  ),

  test("countBy empty array returns empty object", () =>
    val empty: String[] = []
    val result = empty.countBy(x => x)
    [
      expect(result["anything"]).toBe(null)
    ]
  ),

  // --- heap/union element coverage for index-assign (`result[i] = x`) ---
  // These exercise the array/object index-assign store with STRING and ARRAY
  // (heap) elements, where the fresh-vs-borrowed and consume-vs-retain ownership
  // rules matter (scalar elements hide RC bugs). Read the stored value back so a
  // use-after-free corrupts the assertion; the ASan CI leg also runs these.
  test("map producing strings (fresh union element)", () =>
    val result = [1, 2, 3].map(x => "n${x}")
    [
      expect(result.toString()).toBe("[\"n1\", \"n2\", \"n3\"]")
    ]
  ),

  test("map producing arrays (fresh nested-heap element)", () =>
    val result = [1, 2, 3].map(x => [x, x])
    [
      expect(result.toString()).toBe("[[1, 1], [2, 2], [3, 3]]")
    ]
  ),

  test("reverse of string elements (borrowed union)", () =>
    val result = ["a", "b", "c"].reverse()
    [
      expect(result.toString()).toBe("[\"c\", \"b\", \"a\"]")
    ]
  ),

  test("take of string elements (borrowed union)", () =>
    val result = ["a", "b", "c"].take(2)
    [
      expect(result.toString()).toBe("[\"a\", \"b\"]")
    ]
  ),

  test("append a string element", () =>
    val result = ["a", "b"].append("c")
    [
      expect(result.toString()).toBe("[\"a\", \"b\", \"c\"]")
    ]
  ),

  test("prepend a string element", () =>
    val result = ["b", "c"].prepend("a")
    [
      expect(result.toString()).toBe("[\"a\", \"b\", \"c\"]")
    ]
  ),

  test("zip of string elements", () =>
    val result = [1, 2].zip(["a", "b"])
    [
      expect(result.toString()).toBe("[[1, \"a\"], [2, \"b\"]]")
    ]
  ),

  test("sort of string elements (in-place index-assign swaps)", () =>
    val result = ["c", "a", "b"].sort((a, b) => if a < b then -1 else if a > b then 1 else 0)
    [
      expect(result.toString()).toBe("[\"a\", \"b\", \"c\"]")
    ]
  ),

  test("groupBy collecting string elements into array values", () =>
    val result = ["a", "a", "b"].groupBy(x => x)
    [
      expect(result["a"].toString()).toBe("[\"a\", \"a\"]"),
      expect(result["b"].toString()).toBe("[\"b\"]")
    ]
  ),

  test("arrayAllocate produces n nulls", () =>
    val b = arrayAllocate(3)
    [
      expect(length(b)).toBe(3),
      expect(b.toString()).toBe("[null, null, null]")
    ]
  ),

  test("arrayAllocateFilled fills with a scalar", () => [
    expect(arrayAllocateFilled(3, 0).toString()).toBe("[0, 0, 0]"),
    expect(arrayAllocateFilled(2, 7).toString()).toBe("[7, 7]"),
    expect(arrayAllocateFilled(3, true).toString()).toBe("[true, true, true]"),
    expect(arrayAllocateFilled(0, 9).toString()).toBe("[]")
  ]),

  test("arrayAllocateFilled fills with a string", () => [
    expect(arrayAllocateFilled(2, "x").toString()).toBe("[\"x\", \"x\"]")
  ]),

  test("arrayAllocateFilled fills with a heap value (shared, but each slot reads it back)", () =>
    val b = arrayAllocateFilled(3, [1, 2])
    [
      expect(b.toString()).toBe("[[1, 2], [1, 2], [1, 2]]"),
      expect(b[0].toString()).toBe("[1, 2]"),
      expect(b[2].toString()).toBe("[1, 2]")
    ]
  ),

  test("arrayAllocate + set fills a pre-sized buffer by index", () =>
    val b = arrayAllocate(3)
    set(b, 0, "a")
    set(b, 1, "b")
    [
      expect(b.toString()).toBe("[\"a\", \"b\", null]")
    ]
  ),

  test("arrayAllocateFilled with a concrete scalar element type is flat and correct", () =>
    // An annotated scalar element type must allocate a FLAT array matching the flat read path
    // (a tagged array read flat returns garbage). `set` then writes the same representation.
    val a: Int32[] = arrayAllocateFilled(4, 7)
    set(a, 1, 99)
    val f: Float64[] = arrayAllocateFilled(2, 1.5)
    set(f, 0, 2.5)
    [
      expect(a.toString()).toBe("[7, 99, 7, 7]"),
      expect(f.toString()).toBe("[2.5, 1.5]")
    ]
  ),

  // --- Optional 0-based Int32 source index callback parameter ---
  test("map with an optional index param", () =>
    val r = ["a", "b", "c"].map((x, i) => i)
    [
      expect(r.toString()).toBe("[0, 1, 2]")
    ]
  ),

  test("map without an index param still works (regression)", () =>
    [
      expect([1, 2, 3].map(x => x * 2).toString()).toBe("[2, 4, 6]")
    ]
  ),

  test("for accumulates with the index", () =>
    var acc = ""
    ["a", "b", "c"].for((x, i) => acc = "${acc}${i}:${x},")
    [
      expect(acc).toBe("0:a,1:b,2:c,")
    ]
  ),

  test("filter index is the SOURCE position", () =>
    // Keeps source indices 0 and 2 (values 10 and 30), even though output positions differ.
    val r = [10, 20, 30, 40].filter((x, i) => i % 2 == 0)
    [
      expect(r.toString()).toBe("[10, 30]")
    ]
  ),

  // 0 + 0 + 1 + 2 = 3
  test("reduce with a third index param", () =>
    [
      expect([1, 1, 1].reduce(0, (acc, x, i) => acc + i)).toBe(3)
    ]
  ),

  test("reduce without an index param still works (regression)", () =>
    [
      expect([1, 2, 3].reduce(0, (acc, x) => acc + x)).toBe(6)
    ]
  ),

  test("find with a 2-arg index callback", () =>
    [
      expect([10, 20, 30].find((x, i) => i == 2)).toBe(30)
    ]
  ),

  test("some/every with an index callback", () =>
    [
      expect([10, 20, 30].some((x, i) => i == 1)).toBe(true),
      expect([5, 6, 7].every((x, i) => i < 3)).toBe(true)
    ]
  ),

  test("takeWhile index correctness", () =>
    [
      expect([5, 6, 7, 8].takeWhile((x, i) => i < 2).toString()).toBe("[5, 6]")
    ]
  ),

  test("dropWhile index correctness", () =>
    [
      expect([5, 6, 7, 8].dropWhile((x, i) => i < 2).toString()).toBe("[7, 8]")
    ]
  ),

  test("flatMap with an index callback", () =>
    val r = ["a", "b"].flatMap((x, i) => [x, "${i}"])
    [
      expect(r.toString()).toBe("[\"a\", \"0\", \"b\", \"1\"]")
    ]
  ),

  test("partition with an index callback", () =>
    val parts = [10, 20, 30, 40].partition((x, i) => i % 2 == 0)
    [
      expect(parts[0].toString()).toBe("[10, 30]"),
      expect(parts[1].toString()).toBe("[20, 40]")
    ]
  ),

  // --- generic element typing flows through (Category 1 of the stdlib Json-typing audit) ---
  // These lock in that the re-typed `<T>` collection ops PRESERVE the element type `T` rather than
  // erasing to `Json`, so the result can be consumed by a `T`-typed context. `reverse`/`slice`/
  // `unique` over String[] keep String elements; `String`-typed locals below would not type-check
  // if the result were `Json`-erased.
  test("reverse preserves the String element type through to a typed binding", () =>
    val names = ["alice", "bob", "carol"]
    val first: String = names.reverse()[0]
    [
      expect(first).toBe("carol")
    ]
  ),

  test("slice preserves the element type", () =>
    val xs = [10, 20, 30, 40]
    val mid: Int32 = xs.slice(1, 3)[0]
    [
      expect(mid).toBe(20)
    ]
  ),

  test("unique result element flows into a String-typed binding", () =>
    val tags = ["a", "b", "a", "c"]
    val u: String = tags.unique()[1]
    [
      expect(u).toBe("b")
    ]
  ),

  // Regression: `unique` returns `T[]`, so a scalar `T` (Int32) element must be read back through
  // the FLAT array path. `unique` builds its result via `[]` + push, which is tagged unless the
  // accumulator is annotated `T[]` — without that annotation a typed `u[2]` read decoded garbage
  // (the tagged bytes reinterpreted as a packed Int32). The `result: T[]` annotation in `unique`
  // forces the flat representation that matches the declared return type.
  test("unique preserves the flat Int32 representation for typed element reads", () =>
    val u = [1, 1, 2, 3].unique()
    val third: Int32 = u[2]
    [
      expect(third).toBe(3),
      expect(u.toString()).toBe("[1, 2, 3]")
    ]
  ),

  test("partition returns T[][] whose inner arrays carry the element type", () =>
    val parts = [1, 2, 3, 4].partition(x => x > 2)
    val pass: Int32[] = parts[0]
    val n: Int32 = pass[0]
    [
      expect(n).toBe(3)
    ]
  ),

  test("zip pairs flow the two element types into a typed access", () =>
    val pairs = [1, 2].zip(["a", "b"])
    val k: Int32 = pairs[0][0]
    val v: String = pairs[1][1]
    [
      expect(k).toBe(1),
      expect(v).toBe("b")
    ]
  ),

  test("chunk preserves the element type in nested chunks", () =>
    val cs = [1, 2, 3, 4].chunk(2)
    val firstChunkHead: Int32 = cs[0][0]
    [
      expect(firstChunkHead).toBe(1)
    ]
  )
])

run(s)
