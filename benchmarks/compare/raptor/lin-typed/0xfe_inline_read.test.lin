import { expect, toBe, test, suite, run } from "std/test"

type Pt = { "x": Int32, "y": Int32 }

val sumPoints = (): Int32 =>
  val pts: Pt[] = [{ "x": 1, "y": 2 }, { "x": 3, "y": 4 }, { "x": 5, "y": 6 }]
  pts[0]["x"] + pts[1]["y"] + pts[2]["x"]

val readEach = (): Int32 =>
  val pts: Pt[] = [{ "x": 10, "y": 20 }, { "x": 30, "y": 40 }]
  pts[0]["x"] + pts[0]["y"] + pts[1]["x"] + pts[1]["y"]

val main = (): AnyVal =>
  run([
    suite("0xFE inline read correctness", [
      test("sum local read-only record array", () => [
        expect(sumPoints()).toBe(10)
      ]),

      test("read every field of every element", () => [
        expect(readEach()).toBe(100)
      ])
    ])
  ])
