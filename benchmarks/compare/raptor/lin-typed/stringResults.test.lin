import { expect, toSatisfy, test, suite, run } from "std/test"
import { for, range } from "std/iter"
import { keys } from "std/object"
import { length, push, set } from "std/array"
import { t, st } from "./testutil"
import { makeStringResults, add, finalize, StringResults, StringSet } from "./stringResults"
import { Conn, Boarding } from "./types"

// Deep equality over the typed `{ String: StringSet }` result (the typed-map rep lacks the
// structural `toBe`/`toString` the `AnyVal` rep had, so the result is checked with a typed walk).
val setEq = (a: StringSet, b: StringSet): Boolean =>
  if length(keys(a)) != length(keys(b)) then
    false
  else
    var ok = true
    keys(a).for(k =>
      val av = a[k] ?? false
      val bv = b[k] ?? false
      if av != bv then ok = false
    )
    ok

val resultsEq = (actual: { String: StringSet }, expected: { String: StringSet }): Boolean =>
  if length(keys(actual)) != length(keys(expected)) then
    false
  else
    var ok = true
    var emptySet: StringSet = {}
    keys(expected).for(k =>
      val ea = expected[k] ?? emptySet
      val aa = actual[k] ?? emptySet
      if setEq(aa, ea) == false then ok = false
    )
    ok

// Build a typed `{ String: StringSet }` from [key, set] entries (a non-empty record literal
// infers a closed record, not a map).
type ResultEntry = [String, StringSet]

val resultsOf = (entries: ResultEntry[]): { String: StringSet } =>
  var m: { String: StringSet } = {}
  entries.for(e => m[e[0]] = e[1])
  m

// Build the synthetic kConnections the reference spec feeds in:
//   for i in 1..path.length: kConnections[path[i]][i] = [Trip(stopTimes:[{stop: path[i-1]}]), 0, 1]
// then tree.add(kConnections). walkPath reads connection[0]["stopTimes"][connection[1]==0]["stop"].
// The round dimension is an ARRAY indexed by the round number (Null-padded up to round i) — the
// structure under test.
val mergePath = (tree: StringResults, path: String[]): Null =>
  var kConnections: { String: (Conn | Null)[] } = {}
  range(1, length(path)).for(i =>
    val origin = path[i - 1]
    val destination = path[i]
    var conns: (Conn | Null)[] = []
    range(0, i + 1).for(j => push(conns, null))
    val boarding: Boarding = [t([st(origin, null, 1000)]), 0, 1]
    set(conns, i, boarding)
    kConnections[destination] = conns
  )
  add(tree, kConnections)

// A Set is modelled as an object keyed by member (value true).
val setOf = (members: String[]): StringSet =>
  var s: StringSet = {}
  members.for(m => s[m] = true)
  s

val build = (paths: String[][]): { String: StringSet } =>
  val tree = makeStringResults()
  paths.for(p => mergePath(tree, p))
  finalize(tree)

val s = suite("StringResults", [
  test("Merges duplicate paths", () => [
    expect(build([["A", "B", "C", "D"], ["A", "B", "C"]])).toSatisfy(r =>
      resultsEq(r, resultsOf([
        ["AB", setOf([""])],
        ["AC", setOf(["B"])],
        ["AD", setOf(["B,C"])]
      ]))
    )
  ]),

  test("Orders results", () => [
    expect(build([["C", "B", "A"], ["C", "D", "B"], ["C", "B", "E"]])).toSatisfy(r =>
      resultsEq(r, resultsOf([
        ["AC", setOf(["B"])],
        ["BC", setOf(["", "D"])],
        ["CE", setOf(["B"])],
        ["CD", setOf([""])]
      ]))
    )
  ]),

  test("Adds different paths", () => [
    expect(build([["A", "B", "C", "D"], ["A", "C", "B", "D"]])).toSatisfy(r =>
      resultsEq(r, resultsOf([
        ["AC", setOf(["", "B"])],
        ["AB", setOf(["", "C"])],
        ["AD", setOf(["B,C", "C,B"])]
      ]))
    )
  ])
])
run(s)
