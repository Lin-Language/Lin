import { expect, toSatisfy, test, suite, run } from "std/test"
import { j, st, journeysEq } from "./testutil"
import { apply } from "./filter"

val s = suite("MultipleCriteriaFilter", [
  test("removes slower journeys", () => [
    expect(apply([
      j([[st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]]),
      j([[st("A", null, 900), st("B", 1030, 1035), st("C", 1100, null)]]),
      j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
      j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
    ])).toSatisfy(actual =>
      journeysEq(actual, [
        j([[st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]]),
        j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
        j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
      ])
    )
  ]),

  test("keeps slower journeys if they have fewer changes", () => [
    expect(apply([
      j([[st("A", null, 1000), st("B", 1030, 1035)], [st("C", 1100, null)]]),
      j([[st("A", null, 900), st("C", 1100, null)]]),
      j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
      j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
    ])).toSatisfy(actual =>
      journeysEq(actual, [
        j([[st("A", null, 900), st("C", 1100, null)]]),
        j([[st("A", null, 1000), st("B", 1030, 1035)], [st("C", 1100, null)]]),
        j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
        j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
      ])
    )
  ]),

  test("sorts journeys before filtering them", () => [
    expect(apply([
      j([[st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]]),
      j([[st("A", null, 900), st("B", 1030, 1035), st("C", 1100, null)]]),
      j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
      j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]]),
      j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1330, null)]])
    ])).toSatisfy(actual =>
      journeysEq(actual, [
        j([[st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]]),
        j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
        j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
      ])
    )
  ])
])
run(s)
