import { expect, toBe, test, suite, run } from "std/test"
import { getTime } from "./timeParser"

val s = suite("TimeParser", [
  test("turns a time string into seconds from midnight", () => [
    expect(getTime("00:00:00")).toBe(0),
    expect(getTime("00:00:10")).toBe(10),
    expect(getTime("00:02:10")).toBe(130),
    expect(getTime("03:02:10")).toBe(10930)
  ])
])
run(s)
