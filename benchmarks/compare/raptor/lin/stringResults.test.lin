import { expect, toBe, test, suite, run } from "std/test"
import { for, range } from "std/iter"
import { length, push } from "std/array"
import { makeStringResults, add, finalize } from "./stringResults"
import { Conn } from "./types"

// Build the synthetic kConnections the reference spec feeds in:
//   for i in 1..path.length:
//     kConnections[path[i]] = { i: [{stopTimes:[{stop: path[i-1]}]}, 0, 1] }
// then tree.add(kConnections).
val mergePath = (tree: AnyVal, path: AnyVal): Null =>
  var kConnections: { String: { String: Conn } } = {}
  range(1, length(path)).for(i =>
    val origin = path[i - 1]
    val destination = path[i]
    kConnections[destination] = {}
    kConnections[destination]["${i}"] = [{ "stopTimes": [{ "stop": origin }] }, 0, 1]
  )
  add(tree, kConnections)

// A Set is modelled as an object keyed by member (value true).
val setOf = (members: AnyVal): AnyVal =>
  var s: AnyVal = {}
  members.for(m => s[m] = true)
  s

val build = (paths: AnyVal): AnyVal =>
  val tree = makeStringResults()
  paths.for(p => mergePath(tree, p))
  finalize(tree)

val s = suite("StringResults", [
  test("Merges duplicate paths", () => [
    expect(build([["A", "B", "C", "D"], ["A", "B", "C"]])).toBe({
      "AB": setOf([""]),
      "AC": setOf(["B"]),
      "AD": setOf(["B,C"])
    })
  ]),

  test("Orders results", () => [
    expect(build([["C", "B", "A"], ["C", "D", "B"], ["C", "B", "E"]])).toBe({
      "AC": setOf(["B"]),
      "BC": setOf(["", "D"]),
      "CE": setOf(["B"]),
      "CD": setOf([""])
    })
  ]),

  test("Adds different paths", () => [
    expect(build([["A", "B", "C", "D"], ["A", "C", "B", "D"]])).toBe({
      "AC": setOf(["", "B"]),
      "AB": setOf(["", "C"]),
      "AD": setOf(["B,C", "C,B"])
    })
  ])
])
run(s)
