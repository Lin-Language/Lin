// RangeQuery.spec.ts — profile queries: plan at time=1, then re-plan one second
// after the earliest departure of each result set until none are found.
//
// The reference `new RangeQuery(raptor, journeyFactory)` passes NO filters, so we
// call planRange with an empty filter list. maxSearchDays defaults to 3.
import { expect, toSatisfy, test, suite, run } from "std/test"
import { t, st, j, setDefaultTrip, journeysEq } from "./testutil"
import { createRaptor } from "./raptor"
import { planRange } from "./query"
import { parseDate } from "./dateUtil"

val plan = (trips: Json, origin: String, dest: String, dateStr: String): Json =>
  val raptor = createRaptor(trips, {}, {}, null)
  val result = planRange(raptor, origin, dest, parseDate(dateStr), 3, [])
  setDefaultTrip(result)
  result

val s = suite("RangeQuery", [
  test("performs profile queries", () => [
    expect(plan(
      [
        t([st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]),
        t([st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]),
        t([st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)])
      ],
      "A", "C", "2018-10-16"
    )).toSatisfy(r => journeysEq(r, [
      j([[st("A", null, 1000), st("B", 1030, 1035), st("C", 1100, null)]]),
      j([[st("A", null, 1100), st("B", 1130, 1135), st("C", 1200, null)]]),
      j([[st("A", null, 1200), st("B", 1230, 1235), st("C", 1300, null)]])
    ]))
  ]),

  // Profile queries do not share bestArrivals or the route scanner between departure
  // times: an earlier slower direct journey is kept, and the 1400 departure shows up
  // twice (once per profile step that re-discovers it). See the spec comment.
  test("does not share bestArrivals or routeScanner", () => [
    expect(plan(
      [
        t([st("A", null, 1359), st("C", 1501, null)]),
        t([st("A", null, 1400), st("B", 1430, null)]),
        t([st("B", null, 1430), st("C", 1500, null)])
      ],
      "A", "C", "2018-10-16"
    )).toSatisfy(r => journeysEq(r, [
      j([[st("A", null, 1359), st("C", 1501, null)]]),
      j([[st("A", null, 1400), st("B", 1430, null)], [st("B", null, 1430), st("C", 1500, null)]]),
      j([[st("A", null, 1400), st("B", 1430, null)], [st("B", null, 1430), st("C", 1500, null)]])
    ]))
  ])
])
run(s)
