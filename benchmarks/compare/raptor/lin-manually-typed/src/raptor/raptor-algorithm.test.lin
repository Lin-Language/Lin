import { expect, toBe, test, suite, run } from "std/test"
import { createRaptorAlgorithm } from "./raptor-algorithm"
import { Route, RouteIntId, StopTimeEntry, Timetable, RouteStopIndex, Interchange, TransfersByOrigin } from "./timetable"
import { QueueFactory } from "./queue-factory"
import { RouteScannerFactory, createRouteScanner } from "./route-scanner"
import { Service } from "../gtfs/service"

// Only the constructor shape is unit-tested here. `scan` is integration-level (drives the
// RouteScanner / ScanResultsFactory) and is covered by the query specs.
val s = suite("raptor/raptor-algorithm", [
  test("createRaptorAlgorithm returns a record with the expected fields", () =>
    val routeStopIndex: RouteStopIndex = {}
    val routes: Route[] = []
    val routeStops: UInt32[] = []
    val gStopTimes: StopTimeEntry[] = []
    val services: Service[] = []
    val tripServiceId: UInt32[] = []
    val tripIds: String[] = []
    val transfers: TransfersByOrigin = {}
    val interchange: Interchange = {}
    val queueFactory: QueueFactory = { "stopRoutes": [], "stopRoutesBase": [], "routeStopIndex": {} }
    val routeScannerFactory: RouteScannerFactory = createRouteScanner
    val stopIndexOf: { String: UInt32 } = {}
    val stopNames: String[] = []

    val timetable: Timetable = {
      "routes": routes,
      "routeStops": routeStops,
      "stopTimes": gStopTimes,
      "tripServiceId": tripServiceId,
      "services": services,
      "tripIds": tripIds,
      "routeStopIndex": routeStopIndex,
      "interchange": interchange,
      "transfers": transfers,
      "stopIds": stopIndexOf,
      "stopNames": stopNames
    }

    val raptor = createRaptorAlgorithm(
      timetable,
      queueFactory,
      routeScannerFactory
    )
    [
      expect(raptor["timetable"]["routeStopIndex"]).toBe(routeStopIndex),
      expect(raptor["timetable"]["routes"]).toBe(routes),
      expect(raptor["timetable"]["transfers"]).toBe(transfers),
      expect(raptor["timetable"]["interchange"]).toBe(interchange),
      expect(raptor["queueFactory"]).toBe(queueFactory),
      expect(raptor["routeScannerFactory"]).toBe(routeScannerFactory)
    ]
  )
])

run(s)
