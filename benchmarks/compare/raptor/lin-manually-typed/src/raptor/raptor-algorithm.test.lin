import { expect, toBe, test, suite, run } from "std/test"
import { createRaptorAlgorithm, RouteStopIndex, RoutePaths, Interchange, TransfersByOrigin } from "./raptor-algorithm"
import { ScanResultsFactory } from "./scan-results-factory"
import { QueueFactory } from "./queue-factory"
import { RouteScannerFactory } from "./route-scanner"

// Only the constructor shape is unit-tested here. `scan` is integration-level (drives the
// RouteScanner / ScanResultsFactory) and is covered by the query specs.
val s = suite("raptor/raptor-algorithm", [
  test("createRaptorAlgorithm returns a record with the expected fields", () =>
    val routeStopIndex: RouteStopIndex = { "RouteA": { "StopA": 0 } }
    val routePath: RoutePaths = { "RouteA": ["StopA", "StopB"] }
    val transfers: TransfersByOrigin = { "StopA": [] }
    val interchange: Interchange = { "StopA": 0 }
    val scanResultsFactory: ScanResultsFactory = { "stops": [] }
    val queueFactory: QueueFactory = { "routesAtStop": {  }, "routeStopIndex": {  } }
    val routeScannerFactory: RouteScannerFactory = { "tripsByRoute": {  } }

    val raptor = createRaptorAlgorithm(
      routeStopIndex,
      routePath,
      transfers,
      interchange,
      scanResultsFactory,
      queueFactory,
      routeScannerFactory
    )
    [
      expect(raptor["routeStopIndex"]).toBe(routeStopIndex),
      expect(raptor["routePath"]).toBe(routePath),
      expect(raptor["transfers"]).toBe(transfers),
      expect(raptor["interchange"]).toBe(interchange),
      expect(raptor["scanResultsFactory"]).toBe(scanResultsFactory),
      expect(raptor["queueFactory"]).toBe(queueFactory),
      expect(raptor["routeScannerFactory"]).toBe(routeScannerFactory)
    ]
  )
])

run(s)
