import { expect, toBe, test, suite, run } from "std/test"
import { createRaptorAlgorithm } from "./raptor-algorithm"

// Only the constructor shape is unit-tested here. `scan` is integration-level (drives the
// unported RouteScanner / ScanResultsFactory) and is covered by the query specs. Blocked until
// the WIP raptor-algorithm.lin source and its imports compile.
val s = suite("raptor/raptor-algorithm", [
  test("createRaptorAlgorithm returns a record with the expected fields", () =>
    val routeStopIndex = { "RouteA": { "StopA": 0 } }
    val routePath = { "RouteA": ["StopA", "StopB"] }
    val transfers = { "StopA": [] }
    val interchange = { "StopA": 0 }
    val scanResultsFactory = { "kind": "scanResultsFactory" }
    val queueFactory = { "kind": "queueFactory" }
    val routeScannerFactory = { "kind": "routeScannerFactory" }

    val raptor = createRaptorAlgorithm(
      routeStopIndex,
      routePath,
      transfers,
      interchange,
      scanResultsFactory,
      queueFactory,
      routeScannerFactory
    )
    [
      expect(raptor["routeStopIndex"]).toBe(routeStopIndex),
      expect(raptor["routePath"]).toBe(routePath),
      expect(raptor["transfers"]).toBe(transfers),
      expect(raptor["interchange"]).toBe(interchange),
      expect(raptor["scanResultsFactory"]).toBe(scanResultsFactory),
      expect(raptor["queueFactory"]).toBe(queueFactory),
      expect(raptor["routeScannerFactory"]).toBe(routeScannerFactory)
    ]
  )
])

run(s)
