import { expect, toBe, test, suite, run } from "std/test"
import { createQueueFactory, getQueue } from "./queue-factory"

// Mirrors raptor-typescript/test/unit/raptor/QueueFactory.spec.ts. Blocked until the WIP
// queue-factory.lin source compiles.
val routesAtStop = {
  "StopA": ["RouteA", "RouteB"],
  "StopB": ["RouteB", "RouteC"]
}

val s = suite("raptor/queue-factory", [
  // RouteB sits earlier at StopB (index 1) than StopA (index 2), so it enqueues at StopB
  test("enqueues stops", () =>
    val routeStopIndex = {
      "RouteA": { "StopA": 1 },
      "RouteB": { "StopA": 2, "StopB": 1 },
      "RouteC": { "StopB": 1 }
    }
    val factory = createQueueFactory(routesAtStop, routeStopIndex)
    val actual = factory.getQueue(["StopA", "StopB"])
    [
      expect(actual).toBe({ "RouteA": "StopA", "RouteB": "StopB", "RouteC": "StopB" })
    ]
  ),

  // RouteB now sits earlier at StopA (index 1), so it picks StopA even though StopB is marked first
  test("picks the earliest stop on the route", () =>
    val routeStopIndex = {
      "RouteA": { "StopA": 1 },
      "RouteB": { "StopA": 1, "StopB": 2 },
      "RouteC": { "StopB": 1 }
    }
    val factory = createQueueFactory(routesAtStop, routeStopIndex)
    val actual = factory.getQueue(["StopB", "StopA"])
    [
      expect(actual).toBe({ "RouteA": "StopA", "RouteB": "StopA", "RouteC": "StopB" })
    ]
  )
])

run(s)
