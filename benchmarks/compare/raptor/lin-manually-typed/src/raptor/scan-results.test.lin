import { expect, toBe, test, suite, run } from "std/test"
import { Transfer, Trip } from "../gtfs/gtfs"
import { length } from "std/array"
import { Connection } from "./scan-results"
import { createScanResults, addRound, previousArrival, setTrip, setTransfer, bestArrival, getMarkedStops, finalize } from "./scan-results"
import { StopTimes } from "./raptor-algorithm"

// createScanResults(numStops: Int32, origins: StopTimes)
// Dense arrays of length numStops; stop id IS the array index.
// MAX_TIME fills every unset slot in round 0 and bestArrivals; later rounds are zero-filled.
val numStops = 5  // enough for stop indices 0..4

val freshResults = () =>
  createScanResults(numStops, {})

val freshResultsWithOrigins = (origins: StopTimes) =>
  createScanResults(numStops, origins)

val s = suite("raptor/scan-results", [
  test("createScanResults seeds the round counter", () =>
    val r = createScanResults(0, {})
    [
      expect(r["k"]).toBe(0)
    ]
  ),

  test("addRound increments k", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r["k"]).toBe(1)
    ]
  ),

  test("addRound seeds a fresh zero-filled arrivals array for the new round", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r["kArrivals"][r["k"]].length()).toBe(numStops)
    ]
  ),

  test("setTransfer records arrival and connection at the destination", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    val stop2: UInt32 = 2u32
    r.setTransfer(stop2, transfer, 500)
    [
      expect(r["bestArrivals"][stop2]).toBe(500),
      expect(r["kArrivals"][r["k"]][stop2]).toBe(500),
      expect(r["kConnections"][stop2][r["k"]]).toBe(transfer)
    ]
  ),

  test("setTrip records arrival and the trip connection", () =>
    val r = freshResults()
    r.addRound()
    val trip: Trip = {
      "tripId": "trip1",
      "serviceId": "1",
      "service": {
        "startDate": 20180101,
        "endDate": 20991231,
        "days": { 0: true, 1: true, 2: true, 3: true, 4: true, 5: true, 6: true },
        "dates": {}
      },
      "stopTimes": [
        { "stop": "StopA", "arrivalTime": 100, "departureTime": 100, "pickUp": true, "dropOff": true },
        { "stop": "StopB", "arrivalTime": 300, "departureTime": 300, "pickUp": true, "dropOff": true }
      ]
    }
    // arrival = stopTimes[1].arrivalTime (300) + interchange (5) = 305 at stop index 2
    val stop2: UInt32 = 2u32
    r.setTrip(stop2, trip, 0, 1, 5)
    val expectedConn: Connection = [trip, 0, 1]
    [
      expect(r["bestArrivals"][stop2]).toBe(305),
      expect(r["kArrivals"][r["k"]][stop2]).toBe(305),
      expect(r["kConnections"][stop2][r["k"]]).toBe(expectedConn)
    ]
  ),

  test("bestArrival reads back a recorded best arrival", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    val stop2: UInt32 = 2u32
    r.setTransfer(stop2, transfer, 777)
    [
      expect(r.bestArrival(stop2)).toBe(777)
    ]
  ),

  test("previousArrival reads the prior round's arrival", () =>
    val r = freshResults()
    // Round 1: record an arrival at stop 2.
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    val stop2: UInt32 = 2u32
    r.setTransfer(stop2, transfer, 250)
    // Round 2: previousArrival should now see round-1's stop-2 arrival.
    r.addRound()
    [
      expect(r.previousArrival(stop2)).toBe(250)
    ]
  ),

  test("getMarkedStops returns the stops marked this round", () =>
    val r = freshResults()
    r.addRound()
    val tA: Transfer = {
      "origin": "X",
      "destination": "StopA",
      "duration": 1,
      "startTime": 0,
      "endTime": 86400
    }
    val tB: Transfer = {
      "origin": "X",
      "destination": "StopB",
      "duration": 1,
      "startTime": 0,
      "endTime": 86400
    }
    val stop1: UInt32 = 1u32
    val stop2: UInt32 = 2u32
    r.setTransfer(stop1, tA, 10)
    r.setTransfer(stop2, tB, 20)
    [
      expect(r.getMarkedStops().length()).toBe(2)
    ]
  ),

  test("getMarkedStops is empty for a round with no arrivals", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r.getMarkedStops().length()).toBe(0)
    ]
  ),

  test("finalize returns the connections index and best arrivals", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    val stop2: UInt32 = 2u32
    r.setTransfer(stop2, transfer, 400)
    val out = r.finalize()
    [
      expect(out[0]).toBe(r["kConnections"]),
      expect(out[1]).toBe(r["bestArrivals"]),
      expect(out[1][stop2]).toBe(400)
    ]
  )
])

run(s)
