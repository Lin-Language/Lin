import { expect, toBe, test, suite, run } from "std/test"
import { Transfer, Trip } from "../gtfs/gtfs"
import { length } from "std/array"
import { Connection } from "./scan-results"
import { createScanResults, addRound, previousArrival, setTrip, setTransfer, bestArrival, getMarkedStops, finalize } from "./scan-results"

// No TypeScript spec exists. `createScanResults(stops, origins)` seeds every served stop; with no
// stops and no origins the maps are empty and round 0's `kArrivals` is seeded as `[{}]` — a
// one-element array holding an empty arrivals map. Stops are added dynamically below via setTrip /
// setTransfer, so an empty seed is fine.
val freshResults = () =>
  createScanResults([], {  })

val s = suite("raptor/scan-results", [
  test("createScanResults seeds the round counter and maps", () =>
    val r = createScanResults([], {  })
    [
      expect(r["k"]).toBe(0),
      expect(r["bestArrivals"]).toBe({  }),
      expect(r["kConnections"]).toBe({  })
    ]
  ),

  test("addRound increments k", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r["k"]).toBe(1)
    ]
  ),

  test("addRound seeds a fresh empty arrivals map for the new round", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r["kArrivals"][r["k"]]).toBe({  })
    ]
  ),

  test("setTransfer records arrival and connection at the destination", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    r.setTransfer(transfer, 500)
    [
      expect(r["bestArrivals"]["StopB"]).toBe(500),
      expect(r["kArrivals"][r["k"]]["StopB"]).toBe(500),
      expect(r["kConnections"]["StopB"][r["k"]]).toBe(transfer)
    ]
  ),

  test("setTrip records arrival and the trip connection", () =>
    val r = freshResults()
    r.addRound()
    val trip: Trip = {
      "tripId": "trip1",
      "serviceId": "1",
      "service": {
        "startDate": 20180101,
        "endDate": 20991231,
        "days": { 0: true, 1: true, 2: true, 3: true, 4: true, 5: true, 6: true },
        "dates": {  }
      },
      "stopTimes": [
        { "stop": "StopA", "arrivalTime": 100, "departureTime": 100, "pickUp": true, "dropOff": true },
        { "stop": "StopB", "arrivalTime": 300, "departureTime": 300, "pickUp": true, "dropOff": true }
      ]
    }
    // arrival = stopTimes[1].arrivalTime (300) + interchange (5) = 305 at StopB
    r.setTrip(trip, 0, 1, 5)
    val expectedConn: Connection = [trip, 0, 1]
    [
      expect(r["bestArrivals"]["StopB"]).toBe(305),
      expect(r["kArrivals"][r["k"]]["StopB"]).toBe(305),
      expect(r["kConnections"]["StopB"][r["k"]]).toBe(expectedConn)
    ]
  ),

  test("bestArrival reads back a recorded best arrival", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    r.setTransfer(transfer, 777)
    [
      expect(r.bestArrival("StopB")).toBe(777)
    ]
  ),

  test("previousArrival reads the prior round's arrival", () =>
    val r = freshResults()
    // Round 1: record an arrival at StopB.
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    r.setTransfer(transfer, 250)
    // Round 2: previousArrival should now see round-1's StopB arrival.
    r.addRound()
    [
      expect(r.previousArrival("StopB")).toBe(250)
    ]
  ),

  test("getMarkedStops returns the stops marked this round", () =>
    val r = freshResults()
    r.addRound()
    val tA: Transfer = {
      "origin": "X",
      "destination": "StopA",
      "duration": 1,
      "startTime": 0,
      "endTime": 86400
    }
    val tB: Transfer = {
      "origin": "X",
      "destination": "StopB",
      "duration": 1,
      "startTime": 0,
      "endTime": 86400
    }
    r.setTransfer(tA, 10)
    r.setTransfer(tB, 20)
    [
      expect(r.getMarkedStops().length()).toBe(2)
    ]
  ),

  test("getMarkedStops is empty for a round with no arrivals", () =>
    val r = freshResults()
    r.addRound()
    [
      expect(r.getMarkedStops().length()).toBe(0)
    ]
  ),

  test("finalize returns the connections index and best arrivals", () =>
    val r = freshResults()
    r.addRound()
    val transfer: Transfer = {
      "origin": "StopA",
      "destination": "StopB",
      "duration": 120,
      "startTime": 0,
      "endTime": 86400
    }
    r.setTransfer(transfer, 400)
    val out = r.finalize()
    [
      expect(out[0]).toBe(r["kConnections"]),
      expect(out[1]).toBe(r["bestArrivals"]),
      expect(out[1]["StopB"]).toBe(400)
    ]
  )
])

run(s)
