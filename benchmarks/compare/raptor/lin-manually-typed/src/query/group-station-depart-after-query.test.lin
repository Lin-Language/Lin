// GroupStationDepartAfterQuery.spec.ts — multi-origin / multi-destination plans
// with the default MultipleCriteriaFilter applied.
import { expect, toSatisfy, toBe, test, suite, run } from "std/test"
import { t, st, tf, j, setDefaultTrip, journeysEq } from "./testutil"
import { create } from "../raptor/raptor-algorithm-factory"
import { createGroupStationDepartAfterQuery, plan } from "./group-station-depart-after-query"
import { getResults } from "../results/journey-factory"
import { ResultsFactory } from "../results/results-factory"
import { createMultipleCriteriaFilter } from "../results/filter/journey-filter"
import { Trip } from "../gtfs/gtfs"
import { TransfersByOrigin } from "../raptor/raptor-algorithm"
import { Journey } from "../results/journey"
import { length } from "std/array"

val runPlan = (trips: Trip[], origins: String[], destinations: String[], time: UInt32): Journey[] =>
  val raptor = create(trips, {}, {}, null)
  val jf: ResultsFactory = getResults
  val filters = [createMultipleCriteriaFilter()]
  val query = createGroupStationDepartAfterQuery(raptor, jf, 1, filters)
  val date = { "year": 2019, "month": 4, "day": 18 }
  val result = plan(query, origins, destinations, date, time)
  setDefaultTrip(result)
  result

// As runPlan, but with a transfer index — exercises scanTransfers + the MULTI-ROUND scan while-loop,
// whose inner closure captures the raptor. A prior over-release (a sealed record passed to a `Named`
// param was wrongly full-released after the call) freed the captured raptor mid-scan → use-after-free
// (crash / corrupt reads / 0 journeys). This case is the fast regression for that fix.
val runPlanTransfer = (trips: Trip[], transfers: TransfersByOrigin, origins: String[], destinations: String[], time: UInt32): Journey[] =>
  val raptor = create(trips, transfers, {}, null)
  val jf: ResultsFactory = getResults
  val query = createGroupStationDepartAfterQuery(raptor, jf, 1, [createMultipleCriteriaFilter()])
  plan(query, origins, destinations, { "year": 2019, "month": 4, "day": 18 }, time)

// As runPlan but with a caller-chosen maxSearchDays — exercises the multi-day `searchDay` loop.
val runPlanDays = (trips: Trip[], origins: String[], destinations: String[], time: UInt32, maxDays: UInt8): Journey[] =>
  val raptor = create(trips, {}, {}, null)
  val jf: ResultsFactory = getResults
  val query = createGroupStationDepartAfterQuery(raptor, jf, maxDays, [createMultipleCriteriaFilter()])
  plan(query, origins, destinations, { "year": 2019, "month": 4, "day": 18 }, time)

// A journey that needs TWO service days: board A->B at 20:00 arriving 23:00, then the only B->C trip
// departs 06:00 the NEXT morning. So day 0's scan reaches B but not C; the journey only completes when
// the search is allowed to roll over to day 1. This pins the `searchDay` day-cap boundary, which was
// off by one (`maxSearchDays == i` searched maxSearchDays+1 days vs TS's `for i in 0..maxSearchDays`),
// inflating the cross-language RAPTOR benchmark with extra journeys from a day the reference never scans.
val twoDayTrips: Trip[] = [
  t([st("A", null, 72000u32), st("B", 82800u32, null)]),
  t([st("B", null, 21600u32), st("C", 28800u32, null)])
]

val s = suite("GroupStationDepartAfterQuery", [
  test("plans to multiple destinations", () => [
    expect(runPlan(
      [
        t([
          st("A", null, 1000u32),
          st("B", 1030u32, 1035u32),
          st("C", 1100u32, null)
        ]),
        t([
          st("A", null, 1200u32),
          st("B", 1230u32, 1235u32),
          st("D", 1300u32, null)
        ])
      ],
      ["A"],
      ["C", "D"],
      900u32
    )).toSatisfy(r =>
      journeysEq(r, [
        j([[st("A", null, 1000u32), st("B", 1030u32, 1035u32), st("C", 1100u32, null)]]),
        j([[st("A", null, 1200u32), st("B", 1230u32, 1235u32), st("D", 1300u32, null)]])
      ])
    )
  ]),

  test("plans from multiple origins", () => [
    expect(runPlan(
      [
        t([
          st("A", null, 1000u32),
          st("B", 1030u32, 1035u32),
          st("C", 1100u32, null)
        ]),
        t([
          st("A", null, 1200u32),
          st("_", 1230u32, 1235u32),
          st("D", 1300u32, null)
        ])
      ],
      ["A", "B"],
      ["C", "D"],
      900u32
    )).toSatisfy(r =>
      journeysEq(r, [
        j([[st("B", 1030u32, 1035u32), st("C", 1100u32, null)]]),
        j([[st("A", null, 1200u32), st("_", 1230u32, 1235u32), st("D", 1300u32, null)]])
      ])
    )
  ]),

  // Regression: a journey requiring a TRANSFER (A->B, walk B->C, C->D) drives scanTransfers and a
  // multi-round scan whose while-closure captures the raptor. The captured sealed raptor used to be
  // over-released (sealed record -> `Named` param spurious full-release) → freed mid-scan → UAF.
  test("plans a journey across a transfer (multi-round scan, no UAF)", () => [
    expect(runPlanTransfer(
      [
        t([st("A", null, 1000u32), st("B", 1100u32, null)]),
        t([st("C", null, 1500u32), st("D", 1600u32, null)])
      ],
      { "B": [tf("B", "C", 300)] },
      ["A"],
      ["D"],
      900u32
    ).length()).toBe(1)
  ]),

  // searchDay day-cap boundary (mirrors TS `for (i = 0; i < maxSearchDays; i++)`). With only ONE
  // search day the cross-day journey cannot complete, so the reference returns nothing.
  test("a two-service-day journey is NOT found within maxSearchDays=1", () => [
    expect(runPlanDays(twoDayTrips, ["A"], ["C"], 36000u32, 1u8).length()).toBe(0)
  ]),

  // Allowed a second search day, the journey rolls over to day 1 and completes.
  test("a two-service-day journey IS found within maxSearchDays=2", () => [
    expect(runPlanDays(twoDayTrips, ["A"], ["C"], 36000u32, 2u8).length()).toBe(1)
  ])
])
run(s)
