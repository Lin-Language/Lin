{
  "name": "lin-lang",
  "displayName": "Lin Language",
  "description": "Syntax highlighting, diagnostics, and type-aware completion for the Lin programming language",
  "version": "0.3.0",
  "publisher": "LinusN",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lin-Language/Lin"
  },
  "keywords": ["lin", "programming language", "compiler"],
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:lin",
    "onCommand:lin.build",
    "onCommand:lin.run",
    "onCommand:lin.test",
    "onCommand:lin.testFile",
    "onCommand:lin.testProject",
    "onCommand:lin.format",
    "onCommand:lin.installOnPath"
  ],
  "main": "./client.js",
  "contributes": {
    "languages": [
      {
        "id": "lin",
        "aliases": ["Lin", "lin"],
        "extensions": [".lin"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lin",
        "scopeName": "source.lin",
        "path": "./syntaxes/lin.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "lin.build",
        "title": "Build",
        "category": "Lin"
      },
      {
        "command": "lin.run",
        "title": "Run",
        "category": "Lin"
      },
      {
        "command": "lin.test",
        "title": "Test",
        "category": "Lin"
      },
      {
        "command": "lin.testFile",
        "title": "Test File",
        "category": "Lin"
      },
      {
        "command": "lin.testProject",
        "title": "Test Project",
        "category": "Lin"
      },
      {
        "command": "lin.format",
        "title": "Format",
        "category": "Lin"
      },
      {
        "command": "lin.installOnPath",
        "title": "Install `lin` on PATH (all terminals)",
        "category": "Lin"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
