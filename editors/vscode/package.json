{
  "name": "lin-lang",
  "displayName": "Lin Language",
  "description": "Syntax highlighting, diagnostics, and type-aware completion for the Lin programming language",
  "version": "0.3.0",
  "publisher": "LinusN",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lin-Language/Lin"
  },
  "homepage": "https://github.com/Lin-Language/Lin#readme",
  "bugs": {
    "url": "https://github.com/Lin-Language/Lin/issues"
  },
  "keywords": ["lin", "programming language", "compiler", "json", "pattern matching"],
  "galleryBanner": {
    "color": "#2b6cb0",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters",
    "Snippets",
    "Testing"
  ],
  "activationEvents": [
    "onLanguage:lin",
    "workspaceContains:**/*.lin"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile -- --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  },
  "contributes": {
    "configurationDefaults": {
      "[lin]": {
        "editor.defaultFormatter": "LinusN.lin-lang",
        "editor.inlayHints.enabled": "onUnlessPressed",
        "editor.semanticHighlighting.enabled": true
      }
    },
    "languages": [
      {
        "id": "lin",
        "aliases": ["Lin", "lin"],
        "extensions": [".lin"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/lin-file.svg",
          "dark": "./icons/lin-file-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "lin",
        "scopeName": "source.lin",
        "path": "./syntaxes/lin.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lin",
        "path": "./snippets/lin.json"
      }
    ],
    "commands": [
      {
        "command": "lin.build",
        "title": "Build",
        "category": "Lin",
        "icon": "$(package)"
      },
      {
        "command": "lin.run",
        "title": "Run",
        "category": "Lin",
        "icon": "$(play)"
      },
      {
        "command": "lin.test",
        "title": "Test",
        "category": "Lin",
        "icon": "$(beaker)"
      },
      {
        "command": "lin.testFile",
        "title": "Test File",
        "category": "Lin"
      },
      {
        "command": "lin.testProject",
        "title": "Test Project",
        "category": "Lin"
      },
      {
        "command": "lin.runTest",
        "title": "Run Test",
        "category": "Lin"
      },
      {
        "command": "lin.format",
        "title": "Format",
        "category": "Lin"
      },
      {
        "command": "lin.installOnPath",
        "title": "Install `lin` on PATH (all terminals)",
        "category": "Lin"
      }
    ],
    "submenus": [
      {
        "id": "lin.submenu",
        "label": "Lin"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "lin.runTest",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "lin.run",
          "when": "resourceLangId == lin",
          "group": "navigation@1"
        },
        {
          "command": "lin.build",
          "when": "resourceLangId == lin",
          "group": "navigation@2"
        },
        {
          "command": "lin.test",
          "when": "resourceLangId == lin",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "submenu": "lin.submenu",
          "when": "resourceLangId == lin",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "submenu": "lin.submenu",
          "when": "resourceExtname == .lin",
          "group": "navigation"
        }
      ],
      "lin.submenu": [
        {
          "command": "lin.run",
          "group": "1_run@1"
        },
        {
          "command": "lin.build",
          "group": "1_run@2"
        },
        {
          "command": "lin.test",
          "group": "1_run@3"
        },
        {
          "command": "lin.format",
          "group": "2_edit@1"
        }
      ]
    },
    "taskDefinitions": [
      {
        "type": "lin",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The lin subcommand to run.",
            "enum": ["build", "run", "test"]
          },
          "file": {
            "type": "string",
            "description": "The .lin file or directory to operate on. Defaults to the active file."
          },
          "args": {
            "type": "array",
            "description": "Extra arguments passed to the lin CLI.",
            "items": {
              "type": "string"
            }
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "lin",
        "owner": "lin",
        "source": "lin",
        "fileLocation": ["autoDetect", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^\\s*(?:\\u001b\\[[0-9;]*m)*(Error|Warning)(?:\\u001b\\[[0-9;]*m)*:(?:\\u001b\\[[0-9;]*m)*\\s+(.*?)(?:\\u001b\\[[0-9;]*m)*\\s*$",
            "severity": 1,
            "message": 2
          },
          {
            "regexp": "[\\u2500-\\u257f](?:\\u001b\\[[0-9;]*m)*\\[(?:\\u001b\\[[0-9;]*m)*\\s*(.+?):(\\d+):(\\d+)(?:\\u001b\\[[0-9;]*m)*\\s*(?:\\u001b\\[[0-9;]*m)*\\]",
            "file": 1,
            "line": 2,
            "column": 3
          }
        ]
      }
    ],
    "walkthroughs": [
      {
        "id": "linGetStarted",
        "title": "Get Started with Lin",
        "description": "Install the compiler, write your first program, and run it.",
        "steps": [
          {
            "id": "linInstall",
            "title": "Put `lin` on your PATH",
            "description": "The bundled compiler is on the integrated terminal's PATH already. To use it in any shell, run the install command.\n[Install `lin` on PATH](command:lin.installOnPath)",
            "media": {
              "markdown": "walkthroughs/install.md"
            },
            "completionEvents": ["onCommand:lin.installOnPath"]
          },
          {
            "id": "linHello",
            "title": "Write a Lin program",
            "description": "Create a `.lin` file and start coding with full language support.",
            "media": {
              "markdown": "walkthroughs/hello.md"
            }
          },
          {
            "id": "linRun",
            "title": "Run and test",
            "description": "Compile and run your program, or run its `*.test.lin` suites.\n[Run the active file](command:lin.run)",
            "media": {
              "markdown": "walkthroughs/run.md"
            },
            "completionEvents": ["onCommand:lin.run"]
          }
        ]
      }
    ]
  },
  "devDependencies": {
    "esbuild": "^0.21.5"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
